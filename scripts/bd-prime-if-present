#!/usr/bin/env bash
# @sinnix-package
# description: Print bd prime context only inside an active Beads workspace
# runtimeInputs: bash coreutils
set -euo pipefail

if ! command -v bd >/dev/null 2>&1; then
  exit 0
fi

# Context injection is best-effort: bd serializes on an embedded-Dolt lock,
# and under a multi-agent fanout a queued `bd where`/`bd prime` can sit for
# minutes — a prompt-submit hook must never block the session on that.
if ! timeout 10 bd where >/dev/null 2>&1; then
  exit 0
fi

timeout 20 bd prime "$@" || exit 0

#!/usr/bin/env bash
set -euo pipefail

KB_ROOT=${KB_ROOT:-/realm/knowledgebase}
PICKER=${PICKER:-tofi}

die() { echo "kb-capture: $*" >&2; exit 1; }

command -v zk >/dev/null 2>&1 || die "zk not found. Install with Nix (e.g., add pkgs.zk) or nix profile install nixpkgs#zk."
command -v "$PICKER" >/dev/null 2>&1 || die "picker '$PICKER' not found"
[ -d "$KB_ROOT" ] || die "KB root not found: $KB_ROOT"

pick_one() {
  local prompt="$1"; shift
  local input="$1"
  printf '%s\n' "$input" | "$PICKER" --prompt "$prompt: " --horizontal=false --fuzzy-match=true |
    sed 's/\r$//' |
    sed -e 's/^[[:space:]]\+//' -e 's/[[:space:]]\+$//'
}

prompt_text() {
  local prompt="$1"
  "$PICKER" --prompt "$prompt: " --horizontal=false <<< "" |
    sed 's/\r$//' |
    sed -e 's/^[[:space:]]\+//' -e 's/[[:space:]]\+$//'
}

# Build category list from top-level dirs
categories=$(find "$KB_ROOT" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' | sort)
[ -n "$categories" ] || categories="inbox\nnotes\nlogs"

category=$(pick_one "Category" "$categories")
[ -n "$category" ] || exit 0

title=$(prompt_text "Title")
[ -n "$title" ] || exit 0

# Tags: simple comma-separated input
tag_input=$(prompt_text "Tags (comma-separated, optional)")

args=(new --notebook "$KB_ROOT" --group "$category" --title "$title" --print-path)
if [ -n "$tag_input" ]; then args+=(--tag "$tag_input"); fi

note_path=$(zk "${args[@]}") || die "zk new failed"

# Open in VS Code / VSCodium
if command -v code >/dev/null 2>&1; then
  code --reuse-window "$note_path" >/dev/null 2>&1 &
elif command -v codium >/dev/null 2>&1; then
  codium --reuse-window "$note_path" >/dev/null 2>&1 &
fi

echo "Created: $note_path"

#!/usr/bin/env bash
# @sinnix-package
# description: Verify CLAUDE/AGENTS topology invariants across project repos
# runtimeInputs: coreutils findutils git gnugrep
set -euo pipefail

# Convention (2026-07): per-repo CLAUDE.md is the canonical instruction file,
# flat (no @-transclusion outside code fences), and AGENTS.md is a committed
# symlink pointing at CLAUDE.md. There is no render step.

ROOT="${1:-/realm/project}"
MAX_DEPTH="${2:-4}"

if [ ! -d "$ROOT" ]; then
  echo "error: root directory not found: $ROOT" >&2
  exit 1
fi

mapfile -t doc_dirs < <(
  find "$ROOT" -maxdepth "$MAX_DEPTH" \( -type f -o -type l \) \( -name "AGENTS.md" -o -name "CLAUDE.md" -o -name "AGENTS.override.md" \) -printf "%h\n" | sort -u
)

if [ "${#doc_dirs[@]}" -eq 0 ]; then
  echo "no AGENTS.md or CLAUDE.md found under $ROOT"
  exit 0
fi

declare -A repos_seen=()
for dir in "${doc_dirs[@]}"; do
  git_root="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -n "$git_root" ]; then
    repos_seen["$git_root"]=1
  else
    repos_seen["$dir"]=1
  fi
done

mapfile -t repos < <(printf '%s\n' "${!repos_seen[@]}" | sort)

# @-include lines outside fenced code blocks mean the file still relies on
# Claude-only transclusion and other agents would read an incomplete doc.
has_includes() {
  awk '
    /^[[:space:]]*(```|~~~)/ { fence = !fence; next }
    fence { next }
    /^[[:space:]]*@[.\/~]/ { found = 1; exit }
    END { exit found ? 0 : 1 }
  ' "$1"
}

checked=0
failed=0
for repo in "${repos[@]}"; do
  checked=$((checked + 1))
  repo_failed=0

  claude="$repo/CLAUDE.md"
  agents="$repo/AGENTS.md"
  override="$repo/AGENTS.override.md"

  if [ -L "$claude" ]; then
    echo "fail: $repo: CLAUDE.md must be a regular file, not a symlink"
    repo_failed=1
  elif [ ! -f "$claude" ]; then
    echo "fail: $repo: missing CLAUDE.md source"
    repo_failed=1
  elif has_includes "$claude"; then
    echo "fail: $repo: CLAUDE.md contains @-include lines; flatten it (AGENTS.md consumers cannot expand includes)"
    repo_failed=1
  fi

  if [ ! -L "$agents" ]; then
    if [ -e "$agents" ]; then
      echo "fail: $repo: AGENTS.md must be a symlink to CLAUDE.md (found regular file — legacy generated copy?)"
    else
      echo "fail: $repo: missing AGENTS.md symlink"
    fi
    repo_failed=1
  else
    target="$(readlink "$agents")"
    if [ "$target" != "CLAUDE.md" ]; then
      echo "fail: $repo: AGENTS.md symlink must point at CLAUDE.md (points at '$target')"
      repo_failed=1
    fi
  fi

  if [ -f "$override" ]; then
    echo "fail: $repo: legacy AGENTS.override.md present"
    repo_failed=1
  fi

  if git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    if [ -L "$agents" ] && ! git -C "$repo" ls-files --error-unmatch AGENTS.md >/dev/null 2>&1; then
      echo "fail: $repo: AGENTS.md symlink is not tracked by git (git add -f AGENTS.md)"
      repo_failed=1
    fi
  fi

  if [ "$repo_failed" -eq 0 ]; then
    echo "ok: $repo"
  else
    failed=$((failed + 1))
  fi
done

echo "checked=$checked failed=$failed"

if [ "$failed" -gt 0 ]; then
  exit 1
fi

#!/usr/bin/env bash
# @sinnix-package: skip
# Attach a scratchpad terminal to the persistent WeeChat tmux session.
#
# The session itself is created and supervised by the user service
# `weechat-scratchpad.service`, so IRC logs are captured from login
# regardless of whether this scratchpad is ever opened. This script only
# attaches; it recreates the session as a fallback if the service is down.

set -euo pipefail

SESSION_NAME="weechat-persistent"
SOCKET_PATH="/tmp/tmux-weechat-$UID"

if ! tmux -S "$SOCKET_PATH" has-session -t="$SESSION_NAME" 2>/dev/null; then
  tmux -S "$SOCKET_PATH" new-session -d -s "$SESSION_NAME" weechat
  tmux -S "$SOCKET_PATH" set-option -t "$SESSION_NAME" destroy-unattached off
fi

tmux -S "$SOCKET_PATH" attach-session -t "$SESSION_NAME"

#!/usr/bin/env bash
# @sinnix-package
# description: System health monitor with auto-derived checks
# runtimeInputs: coreutils findutils gawk python3 jq systemd util-linux gnugrep procps sudo libnotify smartmontools borgbackup
# sinnix-sentinel: System health monitor with auto-derived checks
set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────
POLICY_FILE="${SINNIX_HEALTH_POLICY:-/etc/sinnix/health-policy.json}"
HEALTH_FILE="${SINNIX_HEALTH_FILE:-/run/sinnix/health.json}"
PREV_HEALTH_FILE="${SINNIX_HEALTH_FILE:-/run/sinnix/health.json}.prev"
EVENT_LOG="${SINNIX_EVENT_LOG:-/var/log/sinnix-sentinel/events.jsonl}"
CORRECTIVE_ACTIONS="${SINNIX_CORRECTIVE_ACTIONS:-false}"
NOTIFICATIONS="${SINNIX_NOTIFICATIONS:-true}"
MCP_CHILD_THRESHOLD="${SINNIX_MCP_CHILD_THRESHOLD:-2}"
REBOOT_STATE_FILE="${SINNIX_REBOOT_STATE_FILE:-/var/lib/sinnix-sentinel/reboot-last-notified-system}"
VERBOSE=false
JSON_ONLY=false

usage() {
  cat <<'EOF'
Usage: sinnix-sentinel [--verbose] [--json] [--correct] [--no-correct] [--no-notify]
EOF
}

for arg in "$@"; do
  case "$arg" in
    -h|--help)
      usage
      exit 0
      ;;
    --verbose) VERBOSE=true ;;
    --json) JSON_ONLY=true ;;
    --correct) CORRECTIVE_ACTIONS=true ;;
    --no-correct) CORRECTIVE_ACTIONS=false ;;
    --no-notify) NOTIFICATIONS=false ;;
  esac
done

# ── Terminal colors ───────────────────────────────────────────────────
RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'; NC=$'\033[0m'; BOLD=$'\033[1m'

# ── State ─────────────────────────────────────────────────────────────
ok=0; warn=0; fail=0
declare -a CHECKS=()     
declare -a EVENTS=()
declare -a ACTION_EVENTS=()
declare -a NOTIFICATIONS_QUEUE=()  
NOW_TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)
NOW_EPOCH=$(date +%s)

# ── Helpers ───────────────────────────────────────────────────────────
json_escape() {
  jq -Rs '.' <<<"$1" | sed 's/^"//;s/"$//'
}

record_check() {
  local category="$1" name="$2" status="$3" detail="$4"
  case "$status" in
    ok)   ok=$((ok + 1)) ;;
    warn) warn=$((warn + 1)) ;;
    fail) fail=$((fail + 1)) ;;
  esac

  local esc_detail esc_name
  esc_detail=$(json_escape "$detail")
  esc_name=$(json_escape "$name")
  
  CHECKS+=("$(printf '{"category":"%s","name":"%s","status":"%s","detail":"%s"}' \
    "$category" "$esc_name" "$status" "$esc_detail")")

  if $VERBOSE; then
    local color="$NC" icon="[ok]"
    case "$status" in
      ok)   color="$GREEN"; icon="[ok]" ;;
      warn) color="$YELLOW"; icon="[!] " ;;
      fail) color="$RED"; icon="[FAIL]" ;;
    esac
    printf '  %s%s%s %s: %s\n' "$color" "$icon" "$NC" "$name" "$detail"
  fi
}

queue_notification() {
  local urgency="$1" message="$2"
  NOTIFICATIONS_QUEUE+=("$urgency|$message")
}

queue_action_event() {
  local event="$1" severity="$2" name="$3" unit="$4" scope="$5" detail="$6"
  local esc_name esc_unit esc_scope esc_detail
  esc_name=$(json_escape "$name")
  esc_unit=$(json_escape "$unit")
  esc_scope=$(json_escape "$scope")
  esc_detail=$(json_escape "$detail")
  ACTION_EVENTS+=("$(printf '{"timestamp":"%s","source":"sinnix-sentinel","event":"%s","severity":"%s","name":"%s","unit":"%s","scope":"%s","detail":"%s"}' \
    "$NOW_TS" "$event" "$severity" "$esc_name" "$esc_unit" "$esc_scope" "$esc_detail")")
}

send_notification() {
  local urgency="$1" message="$2"
  if ! command -v notify-send &>/dev/null; then
    return 0
  fi

  local notify_user="${SINNIX_NOTIFY_USER:-}"
  if [ -n "$notify_user" ] && id "$notify_user" &>/dev/null; then
    local notify_uid
    notify_uid="$(id -u "$notify_user" 2>/dev/null || true)"
    if [ -n "$notify_uid" ] && [ -S "/run/user/${notify_uid}/bus" ] && command -v runuser &>/dev/null; then
      runuser -u "$notify_user" -- env \
        DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${notify_uid}/bus" \
        XDG_RUNTIME_DIR="/run/user/${notify_uid}" \
        notify-send --urgency="$urgency" "sinnix sentinel" "$message" >/dev/null 2>&1 || true
      return 0
    fi
  fi

  notify-send --urgency="$urgency" "sinnix sentinel" "$message" >/dev/null 2>&1 || true
}

can_write_parent() {
  local path="$1"
  local parent
  parent="$(dirname "$path")"
  [ -d "$parent" ] || mkdir -p "$parent" 2>/dev/null || true
  [ -w "$parent" ]
}

notify_user="${SINNIX_NOTIFY_USER:-}"
user_manager_args=()
if [ -n "$notify_user" ]; then
  user_manager_args=(--machine="${notify_user}@.host" --user)
fi

run_scoped_systemctl() {
  local scope="$1"
  shift
  if [ "$scope" = "user" ]; then
    systemctl "${user_manager_args[@]}" "$@"
  else
    systemctl "$@"
  fi
}

unit_load_state() {
  local scope="$1" unit="$2"
  run_scoped_systemctl "$scope" show "$unit" --property=LoadState --value 2>/dev/null || true
}

pick_unit_scope() {
  local type="$1" unit="$2"

  if [ "$type" = "user" ] && [ ${#user_manager_args[@]} -gt 0 ]; then
    echo "user"
    return
  fi

  if [ "$type" = "timer" ] && [ ${#user_manager_args[@]} -gt 0 ]; then
    if [ "$(unit_load_state system "$unit")" = "loaded" ]; then
      echo "system"
      return
    fi

    if [ "$(unit_load_state user "$unit")" = "loaded" ]; then
      echo "user"
      return
    fi
  fi

  echo "system"
}

# ── Load policy ───────────────────────────────────────────────────────
if [ ! -f "$POLICY_FILE" ]; then
  echo "FATAL: health policy not found at $POLICY_FILE" >&2
  exit 1
fi
POLICY=$(cat "$POLICY_FILE")
if ! [[ "$MCP_CHILD_THRESHOLD" =~ ^[0-9]+$ ]]; then
  MCP_CHILD_THRESHOLD=2
fi

# ── Baseline state ────────────────────────────────────────────────────
BASELINE_FILE="${SINNIX_BASELINE_FILE:-/var/lib/sinnix-sentinel/baselines.json}"

read_baselines() {
  if [ -r "$BASELINE_FILE" ] && jq -e . "$BASELINE_FILE" >/dev/null 2>&1; then
    cat "$BASELINE_FILE"
  else
    echo '{}'
  fi
}

write_baselines() {
  local tmp="${BASELINE_FILE}.tmp"
  printf '%s\n' "$1" > "$tmp" && mv "$tmp" "$BASELINE_FILE" || true
}

# Compute median and stdev from space-separated numbers via awk
baseline_stats() {
  # Input: space-separated numbers via stdin
  # Output: "median stdev count"
  awk '{
    n=0; for(i=1;i<=NF;i++) if($i!=""){v[n++]=$i}
    if(n==0){print "0 0 0"; exit}
    asort(v)
    if(n%2==1) median=v[int(n/2)+1]
    else median=(v[n/2]+v[n/2+1])/2
    sum=0; for(i=1;i<=n;i++) sum+=v[i]
    mean=sum/n
    sumsq=0; for(i=1;i<=n;i++) sumsq+=(v[i]-mean)^2
    stdev=(n>1?sqrt(sumsq/(n-1)):0)
    printf "%.2f %.2f %d", median, stdev, n
  }'
}

# Append a value to a rolling key in baselines (keeps last 144 samples = 24h at 10min)
baseline_append() {
  local key="$1" value="$2" max_samples="${3:-144}"
  local baselines
  baselines=$(read_baselines)
  local existing
  existing=$(echo "$baselines" | jq -r --arg k "$key" '.[$k] // [] | join(" ")' 2>/dev/null || echo "")
  local samples="$existing $value"
  # Trim to max_samples
  samples=$(echo "$samples" | awk -v max="$max_samples" '{for(i=1;i<=NF;i++) printf "%s%s", $i, (i<NF?" ":"")}' | awk -v max="$max_samples" '{
    if(NF>max){for(i=NF-max+1;i<=NF;i++) printf "%s%s", $i, (i<NF?" ":"")}
    else print $0
  }')
  local new_baselines
  new_baselines=$(echo "$baselines" | jq --arg k "$key" --arg v "$samples" '.[$k] = ($v | split(" "))')
  write_baselines "$new_baselines"
}

# ── 1. Hardware ──────────────────────────────────────────────────────
$VERBOSE && printf '\n%s=== sinnix sentinel ===%s\n\n' "$BOLD" "$NC"
$VERBOSE && printf '\n%sHardware:%s\n' "$BOLD" "$NC"

# SMART Status
if command -v smartctl &>/dev/null; then
  smartctl_cmd=(smartctl)
  if [ "$(id -u)" -ne 0 ] && command -v sudo &>/dev/null; then
    smartctl_cmd=(sudo -n smartctl)
  fi

  smart_status="$("${smartctl_cmd[@]}" -H /dev/nvme0n1 2>&1 || true)"
  if grep -Ei "test result: (PASSED|OK)" <<<"$smart_status" >/dev/null; then
    record_check "hardware" "smart" "ok" "NVMe health passed"
  elif grep -Eqi "permission denied|a password is required|sudo:|not permitted" <<<"$smart_status"; then
    record_check "hardware" "smart" "warn" "NVMe SMART check skipped (insufficient permissions)"
  else
    record_check "hardware" "smart" "fail" "NVMe health CRITICAL or UNKNOWN"
    queue_notification "critical" "sentinel: NVMe SMART health check FAILED"
  fi
fi

# ── 2. Reboot Requirement ──────────────────────────────────────────────
$VERBOSE && printf '\n%sReboot:%s\n' "$BOLD" "$NC"

reboot_needed=0
reboot_reason=""
booted_kernel="$(readlink /run/booted-system/kernel 2>/dev/null || echo "unknown")"
current_kernel="$(readlink /run/current-system/kernel 2>/dev/null || echo "unknown")"
current_system="$(readlink /run/current-system 2>/dev/null || echo "unknown")"

if [ "$booted_kernel" != "unknown" ] && [ "$current_kernel" != "unknown" ] && [ "$booted_kernel" != "$current_kernel" ]; then
  reboot_needed=1
  reboot_reason="kernel updated"
fi

if [ -f /proc/driver/nvidia/version ]; then
  loaded_nvidia="$(
    awk '/NVRM version:/ {for (i = 1; i <= NF; i++) if ($i == "Module") {print $(i + 1); exit}}' \
      /proc/driver/nvidia/version 2>/dev/null || true
  )"
  current_nvidia=""
  if command -v nvidia-smi &>/dev/null; then
    current_nvidia="$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | sed -n '1p' || true)"
  fi

  if [ -n "$loaded_nvidia" ] && [ -z "$current_nvidia" ]; then
    reboot_needed=1
    reboot_reason="${reboot_reason:+${reboot_reason}; }nvidia driver check failed"
  elif [ -n "$loaded_nvidia" ] && [ -n "$current_nvidia" ] && [ "$loaded_nvidia" != "$current_nvidia" ]; then
    reboot_needed=1
    reboot_reason="${reboot_reason:+${reboot_reason}; }nvidia ${loaded_nvidia} -> ${current_nvidia}"
  fi
fi

if [ "$reboot_needed" -eq 1 ]; then
  record_check "reboot" "required" "warn" "$reboot_reason"
  last_notified_system="$(cat "$REBOOT_STATE_FILE" 2>/dev/null || true)"
  if [ "$current_system" != "unknown" ] && [ "$current_system" != "$last_notified_system" ]; then
    queue_notification "critical" "sentinel: reboot required (${reboot_reason})"
    if can_write_parent "$REBOOT_STATE_FILE"; then
      printf '%s\n' "$current_system" > "$REBOOT_STATE_FILE" || true
    fi
  fi
else
  record_check "reboot" "required" "ok" "no reboot needed"
  rm -f "$REBOOT_STATE_FILE" 2>/dev/null || true
fi

# ── 3. Services ───────────────────────────────────────────────────────
$VERBOSE && printf '\n%sServices:%s\n' "$BOLD" "$NC"

while IFS='|' read -r name unit type restartable; do
  scope="$(pick_unit_scope "$type" "$unit")"
  
  if [ "$type" = "timer" ]; then
    if run_scoped_systemctl "$scope" is-enabled "$unit" &>/dev/null; then
      next="$(run_scoped_systemctl "$scope" show "$unit" --property=NextElapseUSecRealtime --value 2>/dev/null || echo "")"
      record_check "services" "$name" "ok" "timer enabled${next:+ (next: $next)}"
    else
      record_check "services" "$name" "fail" "timer not enabled"
    fi
  else
    active_state="$(run_scoped_systemctl "$scope" show "$unit" --property=ActiveState --value 2>/dev/null || echo "unknown")"
    if [ "$active_state" = "active" ]; then
      mem="$(run_scoped_systemctl "$scope" show "$unit" --property=MemoryCurrent --value 2>/dev/null || echo "0")"
      mem_mb=$((mem / 1048576))
      record_check "services" "$name" "ok" "active${mem_mb:+ (${mem_mb}MB)}"
    else
      record_check "services" "$name" "fail" "$active_state"
      if [ "$CORRECTIVE_ACTIONS" = "true" ] && [ "$restartable" = "true" ]; then
        if run_scoped_systemctl "$scope" restart "$unit" 2>/dev/null; then
          queue_action_event "service.restart" "normal" "$name" "$unit" "$scope" "restarted from ${active_state}"
          queue_notification "normal" "sentinel: restarted $name"
        else
          queue_action_event "service.restart_failed" "critical" "$name" "$unit" "$scope" "restart failed from ${active_state}"
        fi
      fi
    fi
  fi
done < <(echo "$POLICY" | jq -r '.services[] | "\(.name)|\(.unit)|\(.type)|\(.restartable)"')

# ── 4. MCP Telemetry ──────────────────────────────────────────────────
$VERBOSE && printf '\n%sMCP:%s\n' "$BOLD" "$NC"

mcp_telemetry_json="$(
  MCP_CHILD_THRESHOLD="$MCP_CHILD_THRESHOLD" python3 - <<'PY'
import json
import os
import re
import subprocess

threshold = int(os.environ.get("MCP_CHILD_THRESHOLD", "1"))

agent_patterns = [
    ("codex", re.compile(r"\bcodex\b", re.IGNORECASE)),
    ("claude", re.compile(r"\bclaude(?:-code)?\b", re.IGNORECASE)),
    ("gemini", re.compile(r"\bgemini\b", re.IGNORECASE)),
    ("opencode", re.compile(r"\bopencode\b", re.IGNORECASE)),
    ("cursor", re.compile(r"\bcursor\b", re.IGNORECASE)),
    ("aider", re.compile(r"\baider\b", re.IGNORECASE)),
    ("qwen", re.compile(r"\bqwen\b", re.IGNORECASE)),
    ("goose", re.compile(r"\bgoose\b", re.IGNORECASE)),
    ("jules", re.compile(r"\bjules\b", re.IGNORECASE)),
]

def infer_mcp_type(cmd: str):
    lower = cmd.lower()
    if "context7" in lower:
        return "context7"
    if "firecrawl" in lower:
        return "firecrawl"
    if "playwright" in lower and "mcp" in lower:
        return "playwright"
    match = re.search(r"@modelcontextprotocol/server-([a-z0-9._-]+)", lower)
    if match:
        return match.group(1)
    match = re.search(r"\bmcp-([a-z0-9._-]+)\b", lower)
    if match:
        return match.group(1)
    return None

proc = subprocess.run(
    ["ps", "-eo", "pid=,ppid=,args=", "--no-headers"],
    check=True,
    text=True,
    capture_output=True,
)

pid_map = {}
for line in proc.stdout.splitlines():
    line = line.strip()
    if not line:
        continue
    parts = line.split(None, 2)
    if len(parts) < 3:
        continue
    pid = int(parts[0])
    ppid = int(parts[1])
    args = parts[2]
    pid_map[pid] = (ppid, args)

def infer_agent(start_ppid: int):
    seen = set()
    current = start_ppid
    while current and current not in seen:
        seen.add(current)
        if current not in pid_map:
            break
        parent_ppid, parent_args = pid_map[current]
        for label, rx in agent_patterns:
            if rx.search(parent_args):
                return f"{label}:{current}", parent_args
        current = parent_ppid
    parent_args = pid_map.get(start_ppid, (None, "unknown-parent"))[1]
    return f"unclassified:{start_ppid}", parent_args

pair_counts = {}
total = 0
for pid, (ppid, args) in pid_map.items():
    mcp_type = infer_mcp_type(args)
    if not mcp_type:
        continue
    total += 1
    agent_key, agent_cmd = infer_agent(ppid)
    key = (agent_key, mcp_type)
    if key not in pair_counts:
        pair_counts[key] = {
            "agent": agent_key,
            "mcp_type": mcp_type,
            "count": 0,
            "agent_cmd": agent_cmd,
            "sample_mcp_cmd": args,
        }
    pair_counts[key]["count"] += 1

pairs = sorted(pair_counts.values(), key=lambda x: (-x["count"], x["agent"], x["mcp_type"]))
violations = [p for p in pairs if p["count"] > threshold]

print(
    json.dumps(
        {
            "total": total,
            "pair_count": len(pairs),
            "agent_count": len({p["agent"] for p in pairs}),
            "pairs": pairs,
            "violations": violations,
        }
    )
)
PY
)"

mcp_total="$(jq -r '.total // 0' <<<"$mcp_telemetry_json")"
mcp_pair_count="$(jq -r '.pair_count // 0' <<<"$mcp_telemetry_json")"
mcp_agent_instance_count="$(jq -r '.agent_count // 0' <<<"$mcp_telemetry_json")"
mcp_violation_count="$(jq -r '.violations | length' <<<"$mcp_telemetry_json")"
mcp_hotspots="$(
  jq -r '[.pairs[] | "\(.agent) \(.mcp_type)=\(.count)x"] | .[:6] | join(" | ")' <<<"$mcp_telemetry_json"
)"
mcp_violation_detail="$(
  jq -r '[.violations[] | "\(.agent) \(.mcp_type)=\(.count)x"] | .[:6] | join(" | ")' <<<"$mcp_telemetry_json"
)"

record_check "mcp" "processes_total" "ok" \
  "${mcp_total} MCP process(es) across ${mcp_agent_instance_count} coding-agent instance(s) and ${mcp_pair_count} instance/type pair(s)"

if [ "$mcp_violation_count" -gt 0 ]; then
  record_check "mcp" "per_type_per_agent_fanout" "fail" \
    "${mcp_violation_count} agent/type pair(s) exceed threshold=${MCP_CHILD_THRESHOLD}; ${mcp_violation_detail}"
  queue_notification "critical" \
    "sentinel: MCP per-type fanout exceeded (threshold=${MCP_CHILD_THRESHOLD})"
else
  record_check "mcp" "per_type_per_agent_fanout" "ok" \
    "all agent/type pairs <= ${MCP_CHILD_THRESHOLD}; ${mcp_hotspots}"
fi

# ── 5. Captures ───────────────────────────────────────────────────────
$VERBOSE && printf '\n%sCaptures:%s\n' "$BOLD" "$NC"

while IFS='|' read -r name path max_stale; do
  if [ ! -d "$path" ]; then record_check "captures" "$name" "warn" "missing: $path"; continue; fi
  
  newest_ts=$(find "$path" -type f -printf '%T@\n' 2>/dev/null | sort -n | tail -n 1 || true)
  if [ -z "$newest_ts" ]; then record_check "captures" "$name" "warn" "empty"; continue; fi

  # Robust calculation via awk
  res=$(awk -v now="$NOW_EPOCH" -v newest="$newest_ts" -v max_h="$max_stale" 'BEGIN {
    age_s = now - newest;
    age_h = age_s / 3600;
    status = "ok";
    if (age_s > (max_h * 3600)) status = "warn";
    if (age_s > (max_h * 3600 * 4)) status = "fail";
    printf "%s|%.1fh fresh", status, age_h;
  }')
  
  record_check "captures" "$name" "${res%%|*}" "${res#*|}"
done < <(echo "$POLICY" | jq -r '.captures[] | "\(.name)|\(.path)|\(.maxStaleHours)"')

# ── 6. Storage ────────────────────────────────────────────────────────
$VERBOSE && printf '\n%sStorage:%s\n' "$BOLD" "$NC"

while IFS='|' read -r path warn_pct fail_pct; do
  if ! mountpoint -q "$path" 2>/dev/null; then record_check "mounts" "$path" "fail" "NOT MOUNTED"; continue; fi
  
  used_pct=$(df "$path" --output=pcent | tail -1 | tr -dc '0-9')
  avail=$(df -h "$path" --output=avail | tail -1 | xargs)

  status="ok"
  [ "$used_pct" -ge "$warn_pct" ] && status="warn"
  [ "$used_pct" -ge "$fail_pct" ] && status="fail"
  record_check "mounts" "$path" "$status" "${used_pct}% used ($avail free)"
done < <(echo "$POLICY" | jq -r '.mounts[] | "\(.path)|\(.warnPct)|\(.failPct)"')

# ── 7. Backups ────────────────────────────────────────────────────────
$VERBOSE && printf '\n%sBackups:%s\n' "$BOLD" "$NC"

snapshot_dirs=$(echo "$POLICY" | jq -r '.backups.snapshotDirs[]')
max_stale=$(echo "$POLICY" | jq -r '.backups.maxStaleHours // 2')
target_repos=$(echo "$POLICY" | jq -r 'if .backups.backupTargets then .backups.backupTargets[] else (.backups.backupTarget // empty) end')

for dir in $snapshot_dirs; do
  if [ ! -d "$dir" ]; then record_check "backups" "$dir" "warn" "missing"; continue; fi
  newest_name=$(sudo ls -A "$dir" 2>/dev/null | grep -v '^\.' | sort | tail -n 1 || true)
  if [ -z "$newest_name" ]; then record_check "backups" "$dir" "warn" "no snapshots"; continue; fi
  
  # Parse timestamp from name like ROOT.20260303T030000+0100
  ts_str=$(echo "$newest_name" | grep -oE '[0-9]{8}T[0-9]{6}[+-][0-9]{4}' || true)
  if [ -n "$ts_str" ]; then
    formatted="${ts_str:0:4}-${ts_str:4:2}-${ts_str:6:2} ${ts_str:9:2}:${ts_str:11:2}:${ts_str:13:2} ${ts_str:15:5}"
    newest_ts=$(date -d "$formatted" +%s 2>/dev/null || echo 0)
  else
    newest_ts=$(sudo stat -c %Y "$dir/$newest_name" 2>/dev/null || echo 0)
  fi
  
  res=$(newest_name="$newest_name" awk -v now="$NOW_EPOCH" -v ts="$newest_ts" -v max_h="$max_stale" 'BEGIN {
    age_s = now - ts;
    age_h = age_s / 3600;
    status = "ok";
    if (age_h > max_h) status = "warn";
    if (age_h > (max_h * 12)) status = "fail";
    printf "%s|latest=%s (%.1fh ago)", status, ENVIRON["newest_name"], age_h;
  }')
  record_check "backups" "$dir" "${res%%|*}" "${res#*|}"
done

# Borg Targets
for target_repo in $target_repos; do
  if [ -n "$target_repo" ] && sudo test -d "$target_repo"; then
    repo_name=$(basename "$target_repo")
    if sudo test -f "$target_repo/config"; then
      if ! command -v borg &>/dev/null; then record_check "backups" "$repo_name" "warn" "borg missing";
      else
        if sudo test -f "$target_repo/lock" || sudo test -d "$target_repo/lock.exclusive"; then
          record_check "backups" "$repo_name" "ok" "repository active (currently backing up)"
        else
          latest_json=$(sudo borg list --json --last 1 "$target_repo" 2>/dev/null || echo '{"archives":[]}')
          archive_name=$(echo "$latest_json" | jq -r '.archives[0].name // ""')
          archive_time=$(echo "$latest_json" | jq -r '.archives[0].time // ""')
          
          if [ -z "$archive_name" ]; then record_check "backups" "$repo_name" "warn" "empty repo";
          else
            ts=$(date -d "$archive_time" +%s 2>/dev/null || echo 0)
            res=$(awk -v now="$NOW_EPOCH" -v ts="$ts" -v max_h="$max_stale" 'BEGIN {
              age_h = (now - ts) / 3600;
              status = "ok";
              if (age_h > max_h) status = "warn";
              printf "%s|%.1f", status, age_h;
            }')
            status="${res%%|*}"
            [[ "$archive_name" == *".failed" ]] && status="warn"
            record_check "backups" "$repo_name" "$status" "latest=$archive_name (${res#*|}h ago)"
          fi
        fi
      fi
    else record_check "backups" "$repo_name" "warn" "not a borg repo"; fi
  elif [ -n "$target_repo" ]; then 
    repo_name=$(basename "$target_repo" || echo "borg")
    record_check "backups" "$repo_name" "fail" "target missing: $target_repo"
  fi
done

# ── 8. Memory ──────────────────────────────────────────────────────────
$VERBOSE && printf '\n%sMemory:%s\n' "$BOLD" "$NC"

mem_total_kb=$(awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
mem_avail_kb=$(awk '/MemAvailable/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
swap_total_kb=$(awk '/SwapTotal/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
swap_free_kb=$(awk '/SwapFree/{print $2}' /proc/meminfo 2>/dev/null || echo 0)

mem_total_gb=$(( mem_total_kb / 1024 / 1024 ))
mem_avail_gb=$(( mem_avail_kb / 1024 / 1024 ))
swap_used_gb=$(( (swap_total_kb - swap_free_kb) / 1024 / 1024 ))
swap_total_gb=$(( swap_total_kb / 1024 / 1024 ))

if [ "$mem_avail_gb" -lt 2 ]; then
  record_check "memory" "available" "fail" "${mem_avail_gb}G available — OOM risk"
  queue_notification "critical" "sentinel: memory critical — ${mem_avail_gb}G available"
elif [ "$mem_avail_gb" -lt 4 ]; then
  record_check "memory" "available" "warn" "${mem_avail_gb}G available of ${mem_total_gb}G"
else
  record_check "memory" "available" "ok" "${mem_avail_gb}G available of ${mem_total_gb}G"
fi

baseline_append "mem_avail_gb" "$mem_avail_gb"

if [ "$swap_total_gb" -gt 0 ] && [ "$swap_used_gb" -gt 0 ]; then
  swap_pct=$(( swap_used_gb * 100 / swap_total_gb ))
  if [ "$swap_pct" -gt 75 ]; then
    record_check "memory" "swap" "warn" "${swap_used_gb}G used of ${swap_total_gb}G (${swap_pct}%)"
  else
    record_check "memory" "swap" "ok" "${swap_used_gb}G used of ${swap_total_gb}G (${swap_pct}%)"
  fi
fi

# ── 9. Load ───────────────────────────────────────────────────────────
$VERBOSE && printf '\n%sLoad:%s\n' "$BOLD" "$NC"
load_1m=$(cut -d' ' -f1 /proc/loadavg 2>/dev/null || echo 0)
load_5m=$(cut -d' ' -f2 /proc/loadavg 2>/dev/null || echo 0)
load_15m=$(cut -d' ' -f3 /proc/loadavg 2>/dev/null || echo 0)

baseline_append "load_1m" "$load_1m"

# Compare against baseline
load_baseline_vals=$(echo "$(read_baselines)" | jq -r '.load_1m // [] | join(" ")' 2>/dev/null || echo "")
if [ -n "$load_baseline_vals" ]; then
  load_stats=$(echo "$load_baseline_vals" | baseline_stats)
  load_median=$(echo "$load_stats" | awk '{print $1}')
  load_stdev=$(echo "$load_stats" | awk '{print $2}')
  load_count=$(echo "$load_stats" | awk '{print $3}')

  if [ "$load_count" -ge 6 ]; then
    threshold=$(awk "BEGIN {print $load_median + 3 * $load_stdev}")
    spike=$(awk "BEGIN {print ($load_1m > $threshold) ? 1 : 0}")
    if [ "$spike" -eq 1 ]; then
      record_check "load" "1m" "warn" "$load_1m (baseline ${load_median}±${load_stdev}, 3σ spike)"
    else
      record_check "load" "1m" "ok" "$load_1m (baseline ${load_median}±${load_stdev})"
    fi
  else
    record_check "load" "1m" "ok" "$load_1m (building baseline: ${load_count} samples)"
  fi
else
  record_check "load" "1m" "ok" "$load_1m (collecting baseline)"
fi

# ── 10. Processes ─────────────────────────────────────────────────────
$VERBOSE && printf '\n%sProcesses:%s\n' "$BOLD" "$NC"

proc_total=0
proc_zombies=0
for pid_dir in /proc/[0-9]*; do
  [ -d "$pid_dir" ] || continue
  proc_total=$((proc_total + 1))
  state=$(awk '/^State:/{print $2}' "$pid_dir/status" 2>/dev/null || echo "")
  case "$state" in
    Z*|z*) proc_zombies=$((proc_zombies + 1)) ;;
  esac
done

if [ "$proc_zombies" -gt 5 ]; then
  record_check "processes" "zombies" "warn" "${proc_zombies} zombie processes"
else
  record_check "processes" "zombies" "ok" "${proc_zombies}"
fi

baseline_append "proc_total" "$proc_total"

proc_baseline_vals=$(echo "$(read_baselines)" | jq -r '.proc_total // [] | join(" ")' 2>/dev/null || echo "")
if [ -n "$proc_baseline_vals" ]; then
  proc_stats=$(echo "$proc_baseline_vals" | baseline_stats)
  proc_median=$(echo "$proc_stats" | awk '{print $1}')
  proc_stdev=$(echo "$proc_stats" | awk '{print $2}')
  proc_count=$(echo "$proc_stats" | awk '{print $3}')

  if [ "$proc_count" -ge 6 ]; then
    threshold=$(awk "BEGIN {print int($proc_median + 3 * $proc_stdev)}")
    if [ "$proc_total" -gt "$threshold" ] && [ "$proc_stdev" != "0.00" ]; then
      record_check "processes" "total" "warn" "$proc_total (baseline ${proc_median}±${proc_stdev}, explosion)"
    else
      record_check "processes" "total" "ok" "$proc_total (baseline ${proc_median}±${proc_stdev})"
    fi
  else
    record_check "processes" "total" "ok" "$proc_total (building baseline: ${proc_count} samples)"
  fi
else
  record_check "processes" "total" "ok" "$proc_total (collecting baseline)"
fi

# ── 11. Thermal ───────────────────────────────────────────────────────
$VERBOSE && printf '\n%sThermal:%s\n' "$BOLD" "$NC"
thermal_issues=0
for zone in /sys/class/thermal/thermal_zone[0-9]*/temp; do
  [ -f "$zone" ] || continue
  zone_name=$(basename "$(dirname "$zone")")
  temp_c=$(( $(cat "$zone") / 1000 ))
  if [ "$temp_c" -gt 85 ]; then
    thermal_issues=$((thermal_issues + 1))
    record_check "thermal" "$zone_name" "fail" "${temp_c}°C — overheating"
    queue_notification "critical" "sentinel: ${zone_name} at ${temp_c}°C"
  elif [ "$temp_c" -gt 75 ]; then
    thermal_issues=$((thermal_issues + 1))
    record_check "thermal" "$zone_name" "warn" "${temp_c}°C — elevated"
  fi
done
if [ "$thermal_issues" -eq 0 ]; then
  temp0=$(( $(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null || echo 0) / 1000 ))
  record_check "thermal" "all_zones" "ok" "all zones ≤75°C (zone0=${temp0}°C)"
fi

# ── 12. Disk Fill Rate ────────────────────────────────────────────────
$VERBOSE && printf '\n%sDisk Fill Rate:%s\n' "$BOLD" "$NC"

for mount_path in / /nix; do
  mount_name=$(echo "$mount_path" | sed 's|/|_root|;s|^_||')
  used_pct=$(df "$mount_path" --output=pcent 2>/dev/null | tail -1 | tr -dc '0-9' || echo 0)
  baseline_append "disk_${mount_name}_pct" "$used_pct"

  fill_vals=$(echo "$(read_baselines)" | jq -r --arg k "disk_${mount_name}_pct" '.[$k] // [] | join(" ")' 2>/dev/null || echo "")
  fill_count=$(echo "$fill_vals" | wc -w)
  if [ "$fill_count" -ge 12 ]; then
    first_val=$(echo "$fill_vals" | awk '{print $1}')
    last_val="$used_pct"
    span_hours=$(awk "BEGIN {printf \"%.1f\", $fill_count / 6}")  # 6 samples/hour at 10min interval
    delta_pct=$(awk "BEGIN {printf \"%.1f\", $last_val - $first_val}")
    rate_per_day=$(awk "BEGIN {printf \"%.1f\", ($delta_pct / $span_hours) * 24}")
    if [ "$(awk "BEGIN {print ($rate_per_day > 2) ? 1 : 0}")" -eq 1 ] && [ "$used_pct" -lt 95 ]; then
      days_left=$(awk "BEGIN {printf \"%.0f\", (100 - $used_pct) / $rate_per_day}")
      record_check "disk_rate" "$mount_name" "warn" "${used_pct}% used, filling at ${rate_per_day}%/day (~${days_left}d until full)"
    elif [ "$(awk "BEGIN {print ($rate_per_day > 0.5) ? 1 : 0}")" -eq 1 ]; then
      record_check "disk_rate" "$mount_name" "ok" "${used_pct}% used, ${rate_per_day}%/day (normal)"
    else
      record_check "disk_rate" "$mount_name" "ok" "${used_pct}% used, stable (${rate_per_day}%/day)"
    fi
  fi
done

# ── 13. Nix ────────────────────────────────────────────────────────────
$VERBOSE && printf '\n%sNix:%s\n' "$BOLD" "$NC"
nix_generations=$(sudo -n nix-env --list-generations --profile /nix/var/nix/profiles/system 2>/dev/null | wc -l || echo "?")
record_check "nix" "generations" "ok" "${nix_generations} system generations"

# Nix GC trigger: if root disk ≥92%, start nix-gc immediately
root_pct=$(df / --output=pcent 2>/dev/null | tail -1 | tr -dc '0-9' || echo 0)
if [ "$root_pct" -ge 92 ]; then
  if systemctl is-active nix-gc.service >/dev/null 2>&1; then
    record_check "nix" "gc_trigger" "warn" "root at ${root_pct}%, nix-gc already running"
  else
    if systemctl start nix-gc.service 2>/dev/null; then
      queue_action_event "nix.gc_triggered" "critical" "nix-gc" "nix-gc.service" "system" "root at ${root_pct}%"
      record_check "nix" "gc_trigger" "warn" "root at ${root_pct}% — triggered nix-gc"
      queue_notification "critical" "sentinel: disk ${root_pct}% — triggered nix-gc"
    else
      record_check "nix" "gc_trigger" "fail" "root at ${root_pct}% — failed to trigger nix-gc"
    fi
  fi
fi

# ── 14. Journal ────────────────────────────────────────────────────────
$VERBOSE && printf '\n%sJournal:%s\n' "$BOLD" "$NC"
while IFS=$'\t' read -r pattern severity window; do
  # Robust journalctl call (limit to current boot for performance)
  count=$(journalctl --boot --since "$window" --grep "$pattern" --quiet 2>/dev/null | wc -l || true)
  status="ok"; [ "$count" -gt 0 ] && status="$severity"
  record_check "journal" "$pattern" "$status" "$count matches in last $window"
done < <(echo "$POLICY" | jq -r '.journal[] | "\(.pattern)\t\(.severity)\t\(.window)"')

# ── Output ────────────────────────────────────────────────────────────
overall="ok"; [ "$warn" -gt 0 ] && overall="warn"; [ "$fail" -gt 0 ] && overall="fail"
checks_json=$(printf '%s\n' "${CHECKS[@]}" | paste -sd ',' -)
health_json=$(printf '{"timestamp":"%s","overall":"%s","summary":{"ok":%d,"warn":%d,"fail":%d},"checks":[%s]}' \
  "$NOW_TS" "$overall" "$ok" "$warn" "$fail" "$checks_json")

previous_health_json="null"
if [ -r "$HEALTH_FILE" ] && jq -e . "$HEALTH_FILE" >/dev/null 2>&1; then
  previous_health_json="$(cat "$HEALTH_FILE")"
fi

mapfile -t EVENTS < <(
  jq -c -n \
    --arg ts "$NOW_TS" \
    --argjson current "$health_json" \
    --argjson previous "$previous_health_json" '
      def severity(s):
        if s == "fail" then "critical"
        elif s == "warn" then "warning"
        else "normal"
        end;
      def key(c): "\((c.category // "unknown")):\((c.name // "unnamed"))";
      def to_map(checks):
        (checks // [])
        | map({ key: key(.), value: . })
        | from_entries;
      def overall_event:
        if $previous == null then
          [{
            timestamp: $ts,
            source: "sinnix-sentinel",
            event: "health.initialized",
            severity: severity($current.overall),
            overall: $current.overall,
            summary: $current.summary
          }]
        elif ($previous.overall // "unknown") != ($current.overall // "unknown") then
          [{
            timestamp: $ts,
            source: "sinnix-sentinel",
            event: "health.overall_transition",
            severity: severity($current.overall),
            overall_before: ($previous.overall // "unknown"),
            overall_after: ($current.overall // "unknown"),
            summary_before: ($previous.summary // {}),
            summary_after: ($current.summary // {})
          }]
        else
          []
        end;
      def check_events:
        if $previous == null then
          []
        else
          (to_map($previous.checks) as $before
           | to_map($current.checks) as $after
           | [($after | keys[]) as $k
              | ($before[$k] // null) as $prev
              | ($after[$k] // null) as $next
              | select($prev != null and $next != null and ($prev.status != $next.status))
              | {
                  timestamp: $ts,
                  source: "sinnix-sentinel",
                  event: "health.check_transition",
                  severity: severity($next.status),
                  category: $next.category,
                  name: $next.name,
                  status_before: $prev.status,
                  status_after: $next.status,
                  detail_before: ($prev.detail // ""),
                  detail_after: ($next.detail // "")
                }])
        end;
      (overall_event + check_events)[]
    '
)
EVENTS+=("${ACTION_EVENTS[@]}")

if [ "$previous_health_json" != "null" ]; then
  if can_write_parent "$PREV_HEALTH_FILE"; then
    printf '%s\n' "$previous_health_json" > "$PREV_HEALTH_FILE" || true
  fi
fi

$JSON_ONLY && echo "$health_json" | jq . && exit 0
if can_write_parent "$HEALTH_FILE"; then
  printf '%s\n' "$health_json" > "$HEALTH_FILE" || true
fi

if [ "${#EVENTS[@]}" -gt 0 ] && can_write_parent "$EVENT_LOG"; then
  printf '%s\n' "${EVENTS[@]}" >> "$EVENT_LOG" || true
fi

for event_json in "${EVENTS[@]}"; do
  event_type="$(jq -r '.event // ""' <<<"$event_json" 2>/dev/null || true)"
  event_severity="$(jq -r '.severity // "normal"' <<<"$event_json" 2>/dev/null || echo "normal")"
  urgency="normal"
  [ "$event_severity" = "critical" ] && urgency="critical"
  case "$event_type" in
    health.overall_transition)
      before="$(jq -r '.overall_before // "unknown"' <<<"$event_json" 2>/dev/null || echo "unknown")"
      after="$(jq -r '.overall_after // "unknown"' <<<"$event_json" 2>/dev/null || echo "unknown")"
      queue_notification "$urgency" "sentinel: overall health ${before} -> ${after}"
      ;;
    health.check_transition)
      after="$(jq -r '.status_after // "unknown"' <<<"$event_json" 2>/dev/null || echo "unknown")"
      category="$(jq -r '.category // "unknown"' <<<"$event_json" 2>/dev/null || echo "unknown")"
      if [ "$after" = "fail" ]; then
        name="$(jq -r '.name // "unknown"' <<<"$event_json" 2>/dev/null || echo "unknown")"
        queue_notification "critical" "sentinel: check failed (${category}/${name})"
      elif [ "$after" = "warn" ]; then
        name="$(jq -r '.name // "unknown"' <<<"$event_json" 2>/dev/null || echo "unknown")"
        queue_notification "warning" "sentinel: check warning (${category}/${name})"
      fi
      ;;
  esac
done

# Print one-line summary if not verbose/json
if ! $VERBOSE && ! $JSON_ONLY; then
  printf 'SENTINEL: %s (%d ok, %d fail, %d warn)\n' "${overall^^}" "$ok" "$fail" "$warn"
fi

if [ "$NOTIFICATIONS" = "true" ] && command -v notify-send &>/dev/null; then
  for notif in "${NOTIFICATIONS_QUEUE[@]}"; do
    send_notification "${notif%%|*}" "${notif#*|}"
  done
fi

$VERBOSE && printf '\n%sSENTINEL: %d passed, %d failed, %d warnings%s\n' \
  "$([ "$fail" -eq 0 ] && echo "$GREEN" || echo "$RED")" "$ok" "$fail" "$warn" "$NC"

exit $(( fail > 0 ))

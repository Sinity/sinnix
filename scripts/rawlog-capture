#!/usr/bin/env bash
# @sinnix-package
# description: Capture rawlog entries via gum UI
# runtimeInputs: coreutils gum
set -euo pipefail

# Raw log capture UI wrapper.
# Renders recent entries, collects a new note via gum, then
# forwards to the core rawlog appender.

DEFAULT_REALM_ROOT=${REALM_ROOT:-/realm/project}
KNOWLEDGEBASE_ROOT=${KNOWLEDGEBASE_ROOT:-${DEFAULT_REALM_ROOT}/knowledgebase}
LOG_FILE=${RAWLOG_FILE:-${KNOWLEDGEBASE_ROOT}/logs.raw-log.md}
LOG_DIR=$(dirname "$LOG_FILE")
RAWLOG_BIN=${RAWLOG_BIN:-$HOME/.local/bin/rawlog}
CANCEL_CODE=${RAWLOG_CANCEL_CODE:-130}
GUM_WIDTH=${GUM_WIDTH:-80}
RAWLOG_SPECIAL_WORKSPACE=${RAWLOG_SPECIAL_WORKSPACE:-scratch_rawlog}

if [ -n "${RAWLOG_HEIGHT_OVERRIDE:-}" ]; then
  GUM_HEIGHT=$RAWLOG_HEIGHT_OVERRIDE
else
  lines=$(tput lines 2>/dev/null || echo 24)
  lines=$(( lines - 3 ))
  if [ "$lines" -lt 8 ]; then
    lines=8
  fi
  GUM_HEIGHT=$lines
fi

die() { echo "rawlog-capture: $*" >&2; exit 1; }

[ -d "$LOG_DIR" ] || die "Log directory not found: $LOG_DIR"
[ -x "$RAWLOG_BIN" ] || die "rawlog script not executable at $RAWLOG_BIN"
command -v gum >/dev/null 2>&1 || die "gum CLI not available (need pkg gum)"

cancel_and_hide() {
  [ "${RAWLOG_NO_AUTOHIDE:-0}" = "1" ] && return
  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl dispatch togglespecialworkspace "$RAWLOG_SPECIAL_WORKSPACE" >/dev/null 2>&1 || true
  fi
}

if ! entry=$(gum write \
  --show-help \
  --width "$GUM_WIDTH" \
  --height "$GUM_HEIGHT" \
  --placeholder "Capture a rawlog entry…" \
); then
  cancel_and_hide
  exit "$CANCEL_CODE"
fi

entry=${entry%$'\n'}

[ -n "$entry" ] || {
  cancel_and_hide
  exit "$CANCEL_CODE"
}

if ! "$RAWLOG_BIN" "$entry"; then
  cancel_and_hide
  exit 1
fi

cancel_and_hide
exit 0

#!/usr/bin/env bash
# @sinnix-package
# description: Freeze, thaw, or inspect systemd unit cgroups directly
# runtimeInputs: bash coreutils systemd gnugrep sudo

set -euo pipefail

usage() {
  cat <<'EOF'
usage: sinnix-cgroup-freeze status|freeze|thaw [UNIT...]

Freeze/thaw writes directly to the unit cgroup's cgroup.freeze file, using the
ControlGroup reported by systemd. This is an operator actuator for pressure
experiments and emergency parking of background services when systemctl freeze
is blocked by a pending job.

Default units:
  borgbackup-job-realm.service
  borgbackup-job-persist.service
  borgbackup-maintenance.service
  borgbackup-check.service
EOF
}

die() {
  printf 'sinnix-cgroup-freeze: %s\n' "$*" >&2
  exit 1
}

action="${1:-}"
if [ -z "$action" ] || [ "$action" = "-h" ] || [ "$action" = "--help" ]; then
  usage
  exit 0
fi
shift

case "$action" in
  status | freeze | thaw) ;;
  *) die "unknown action: $action" ;;
esac

if [ "$#" -eq 0 ]; then
  set -- \
    borgbackup-job-realm.service \
    borgbackup-job-persist.service \
    borgbackup-maintenance.service \
    borgbackup-check.service
fi

if [ "$action" != "status" ] && [ "${EUID:-$(id -u)}" -ne 0 ]; then
  exec sudo -- "$0" "$action" "$@"
fi

cgroup_path_for_unit() {
  local unit="$1"
  local control_group
  control_group="$(systemctl show "$unit" --property=ControlGroup --value --no-pager 2>/dev/null || true)"
  if [ -z "$control_group" ] || [ "$control_group" = "/" ]; then
    return 1
  fi
  printf '/sys/fs/cgroup%s\n' "$control_group"
}

print_status() {
  local unit="$1"
  local root="$2"
  local active sub freezer state freeze memory_current io_read io_write
  active="$(systemctl show "$unit" --property=ActiveState --value --no-pager 2>/dev/null || true)"
  sub="$(systemctl show "$unit" --property=SubState --value --no-pager 2>/dev/null || true)"
  freezer="$(systemctl show "$unit" --property=FreezerState --value --no-pager 2>/dev/null || true)"
  state="$(cat "$root/cgroup.events" 2>/dev/null | tr '\n' ' ' || true)"
  freeze="$(cat "$root/cgroup.freeze" 2>/dev/null || true)"
  memory_current="$(cat "$root/memory.current" 2>/dev/null || true)"
  io_read="$(grep -h 'rbytes=' "$root/io.stat" 2>/dev/null | head -n1 || true)"
  io_write="$(grep -h 'wbytes=' "$root/io.stat" 2>/dev/null | head -n1 || true)"
  printf '%s active=%s sub=%s freezer=%s freeze=%s memory_current=%s cgroup_events="%s" io_read="%s" io_write="%s"\n' \
    "$unit" "${active:-unknown}" "${sub:-unknown}" "${freezer:-unknown}" "${freeze:-unknown}" \
    "${memory_current:-unknown}" "$state" "$io_read" "$io_write"
}

target_value=0
if [ "$action" = "freeze" ]; then
  target_value=1
fi

for unit in "$@"; do
  root="$(cgroup_path_for_unit "$unit" || true)"
  if [ -z "${root:-}" ] || [ ! -d "$root" ]; then
    printf '%s missing-control-group\n' "$unit" >&2
    continue
  fi

  case "$action" in
    status)
      print_status "$unit" "$root"
      ;;
    freeze | thaw)
      if [ ! -w "$root/cgroup.freeze" ]; then
        die "$unit cgroup.freeze is not writable at $root/cgroup.freeze"
      fi
      printf '%s' "$target_value" > "$root/cgroup.freeze"
      print_status "$unit" "$root"
      ;;
  esac
done

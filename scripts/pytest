#!/usr/bin/env bash
# Transparent pytest wrapper: bare `pytest` invocations run inside build.slice.
# Path stripping prevents recursive wrapping when this wrapper is named
# `pytest` and placed before the real pytest in PATH.

set -euo pipefail

# Strip our own bin dir from PATH so the inner call finds the real pytest,
# not this wrapper again.
self_bin="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
clean_path=""
IFS=: read -ra path_parts <<< "$PATH"
for part in "${path_parts[@]}"; do
  part_abs="$(cd "$part" 2>/dev/null && pwd || echo "$part")"
  if [ "$part_abs" != "$self_bin" ]; then
    clean_path="${clean_path}${clean_path:+:}${part}"
  fi
done

PATH="$clean_path" exec sinnix-scope build -- pytest "$@"

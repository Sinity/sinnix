#!/usr/bin/env bash
# Transparent pytest wrapper: all invocations run inside build.slice so
# the 300 MB/s I/O cap applies. Catches the agent case (`pytest ...` from
# PATH); leaves `python -m pytest`, `.venv/bin/pytest`, and `uv run pytest`
# to the Claude PreToolUse hook to wrap. See modules/performance.nix:181-186
# for the slice budget.
#
# Reentrant: if already in build.slice, runs the real pytest directly.
# Path stripping prevents recursive wrapping when this wrapper is named
# `pytest` and placed before the real pytest in PATH.

set -euo pipefail

# Already inside build.slice — run the real pytest directly.
if grep -q 'build.slice' /proc/self/cgroup 2>/dev/null; then
  self_bin="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  clean_path=""
  IFS=: read -ra path_parts <<< "$PATH"
  for part in "${path_parts[@]}"; do
    part_abs="$(cd "$part" 2>/dev/null && pwd || echo "$part")"
    if [ "$part_abs" != "$self_bin" ]; then
      clean_path="${clean_path}${clean_path:+:}${part}"
    fi
  done
  PATH="$clean_path" exec pytest "$@"
fi

# Strip our own bin dir from PATH so the inner call finds the real pytest,
# not this wrapper again.
self_bin="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
clean_path=""
IFS=: read -ra path_parts <<< "$PATH"
for part in "${path_parts[@]}"; do
  part_abs="$(cd "$part" 2>/dev/null && pwd || echo "$part")"
  if [ "$part_abs" != "$self_bin" ]; then
    clean_path="${clean_path}${clean_path:+:}${part}"
  fi
done

exec systemd-run --user --scope --quiet \
  --slice=build.slice \
  --same-dir \
  --setenv=PATH="$clean_path" \
  --setenv=HOME \
  --setenv=VIRTUAL_ENV \
  --setenv=PYTHONPATH \
  --setenv=PYTHONHOME \
  --setenv=PYTEST_ADDOPTS \
  --setenv=PYTEST_DISABLE_PLUGIN_AUTOLOAD \
  --setenv=UV_CACHE_DIR \
  --setenv=UV_PROJECT_ENVIRONMENT \
  --setenv=TMPDIR \
  --setenv=TERM \
  pytest "$@"

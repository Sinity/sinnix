#!/usr/bin/env bash
# @sinnix-package
# description: Compatibility wrapper for the retired Sinnix resource slices
# runtimeInputs: bash coreutils

set -euo pipefail

if [ "$#" -lt 3 ] || [ "$2" != "--" ]; then
  echo "usage: sinnix-scope <agent|build|background|nix-build> -- <command> [args...]" >&2
  exit 64
fi

case "$1" in
  agent|build|background|nix-build) ;;
  *)
    echo "sinnix-scope: unknown class: $1" >&2
    exit 64
    ;;
esac

shift 2
exec "$@"

#!/usr/bin/env bash
# @sinnix-package
# description: Place commands in Sinnix resource-control scopes
# runtimeInputs: bash coreutils gnugrep jq systemd util-linux

set -euo pipefail

if [ "$#" -lt 3 ] || [ "$2" != "--" ]; then
  echo "usage: sinnix-scope <agent|build|background|nix-build> -- <command> [args...]" >&2
  exit 64
fi

case "$1" in
  agent|build|background|nix-build) ;;
  *)
    echo "sinnix-scope: unknown class: $1" >&2
    exit 64
    ;;
  esac

class="$1"
shift 2

policy_file="${SINNIX_WORKLOAD_POLICY_FILE:-/etc/sinnix/workload-policy.json}"

policy_value() {
  local query="$1"
  local fallback="$2"
  if [ -r "$policy_file" ] && command -v jq >/dev/null 2>&1; then
    jq -er "$query // empty" "$policy_file" 2>/dev/null || printf '%s\n' "$fallback"
  else
    printf '%s\n' "$fallback"
  fi
}

policy_env_default() {
  local name="$1"
  local fallback="$2"
  policy_value ".commandClasses.\"$class\".envDefaults.\"$name\"" "$fallback"
}

case "$class" in
  agent) fallback_slice="agent.slice" ;;
  build) fallback_slice="build.slice" ;;
  background) fallback_slice="background.slice" ;;
  nix-build) fallback_slice="nix-build.slice" ;;
esac

slice="$(policy_value ".commandClasses.\"$class\".slice" "$fallback_slice")"
nice_level="$(policy_value ".commandClasses.\"$class\".nice" "")"
ionice_class="$(policy_value ".commandClasses.\"$class\".ioniceClass" "")"
ionice_priority="$(policy_value ".commandClasses.\"$class\".ionicePriority" "")"

scoped_command=("$@")
case "$class" in
  build)
    : "${CARGO_BUILD_JOBS:=$(policy_env_default CARGO_BUILD_JOBS 4)}"
    : "${CMAKE_BUILD_PARALLEL_LEVEL:=$(policy_env_default CMAKE_BUILD_PARALLEL_LEVEL 4)}"
    : "${NIX_BUILD_CORES:=$(policy_env_default NIX_BUILD_CORES 4)}"
    : "${SCCACHE_IDLE_TIMEOUT:=$(policy_env_default SCCACHE_IDLE_TIMEOUT 10)}"
    if [ "${MAKEFLAGS+x}" != x ]; then
      MAKEFLAGS="$(policy_env_default MAKEFLAGS -j4)"
    fi
    export CARGO_BUILD_JOBS CMAKE_BUILD_PARALLEL_LEVEL MAKEFLAGS NIX_BUILD_CORES SCCACHE_IDLE_TIMEOUT
    ;;
esac

if [ "$class" = build ] && [ -n "${SINEX_DEV_ROOT:-}" ]; then
  sinex_root="${SINEX_DEV_ROOT%/}"
  sinex_user="${USER:-$(id -un)}"
  sinex_hash="$(printf '%s' "$sinex_root" | sha256sum | cut -c1-12)"
  sinex_cache_base="/var/cache/sinex/$sinex_user/$sinex_hash"

  default_sinex_cache="$sinex_root/.sinex/cache"
  if [ "${SINEX_DEV_CACHE_ROOT:-}" = "$default_sinex_cache" ]; then
    SINEX_DEV_CACHE_ROOT="$sinex_cache_base"
    SINEX_CACHE_DIR="$SINEX_DEV_CACHE_ROOT"
    CARGO_TARGET_DIR="$SINEX_DEV_CACHE_ROOT/target"
    SINEX_TEST_RESULTS_DIR="$SINEX_CACHE_DIR/test-results"
    mkdir -p "$SINEX_DEV_CACHE_ROOT" "$CARGO_TARGET_DIR" "$SINEX_TEST_RESULTS_DIR"
    export SINEX_DEV_CACHE_ROOT SINEX_CACHE_DIR CARGO_TARGET_DIR SINEX_TEST_RESULTS_DIR
  fi

  default_sinex_dev_state="$sinex_root/.sinex"
  default_sinex_state="$default_sinex_dev_state/state"
  if [ "${SINEX_DEV_STATE_DIR:-}" = "$default_sinex_dev_state" ] && [ "${SINEX_STATE_DIR:-}" = "$default_sinex_state" ]; then
    SINEX_DEV_STATE_DIR="$sinex_cache_base/dev-state"
    SINEX_STATE_DIR="$SINEX_DEV_STATE_DIR/state"
    SINEX_NATS_DIR="$SINEX_STATE_DIR/nats"
    DATABASE_URL="postgresql:///sinex_dev?host=$SINEX_DEV_STATE_DIR/run"
    PGHOST="$SINEX_DEV_STATE_DIR/run"
    mkdir -p "$SINEX_DEV_STATE_DIR" "$SINEX_STATE_DIR" "$SINEX_NATS_DIR"
    export SINEX_DEV_STATE_DIR SINEX_STATE_DIR SINEX_NATS_DIR DATABASE_URL PGHOST
  fi
fi

if [ -n "$ionice_class" ] && command -v ionice >/dev/null 2>&1; then
  case "$ionice_class" in
    best-effort)
      scoped_command=(ionice -c 2 -n "${ionice_priority:-7}" -- "${scoped_command[@]}")
      ;;
    idle)
      scoped_command=(ionice -c 3 -- "${scoped_command[@]}")
      ;;
  esac
fi

if [ -n "$nice_level" ] && command -v nice >/dev/null 2>&1; then
  scoped_command=(nice -n "$nice_level" "${scoped_command[@]}")
fi

if grep -q "/$slice" /proc/self/cgroup 2>/dev/null; then
  exec "${scoped_command[@]}"
fi

if ! command -v systemd-run >/dev/null 2>&1; then
  exec "${scoped_command[@]}"
fi

env_args=()
for name in \
  AGENT_NAME AGENT_SESSION_ID \
  CARGO_HOME CARGO_TARGET_DIR CODEX_HOME \
  CARGO_BUILD_JOBS CMAKE_BUILD_PARALLEL_LEVEL MAKEFLAGS \
  DATABASE_URL \
  GEMINI_API_KEY GITHUB_TOKEN HOME LANG LC_ALL LOGNAME \
  NIX_BUILD_CORES NIX_CONFIG NIX_PATH NIXPKGS_ALLOW_UNFREE \
  PATH PGHOST PGPORT POLYLOGUE_ROOT PWD PYTHONHOME PYTHONPATH \
  RUSTC_WRAPPER RUST_LOG RUSTUP_HOME SCCACHE_DIR SCCACHE_IDLE_TIMEOUT SHELL \
  SINEX_CACHE_DIR SINEX_DEV_CACHE_ROOT SINEX_DEV_STATE_DIR SINEX_NATS_DIR SINEX_ROOT SINEX_STATE_DIR SINEX_TEST_RESULTS_DIR \
  TERM TERM_PROGRAM TMPDIR USER UV_CACHE_DIR UV_PROJECT_ENVIRONMENT VIRTUAL_ENV \
  XDG_CACHE_HOME XDG_CONFIG_HOME XDG_DATA_HOME XDG_RUNTIME_DIR XDG_STATE_HOME
do
  if [ "${!name+x}" = x ]; then
    env_args+=("--setenv=$name=${!name}")
  fi
done

if [ "${EUID:-$(id -u)}" -eq 0 ]; then
  unit="sinnix-${class}-$(date +%s%N)-$$"
  exec systemd-run \
    --scope \
    --quiet \
    --collect \
    --same-dir \
    --unit="$unit" \
    --slice="$slice" \
    "${env_args[@]}" \
    -- "${scoped_command[@]}"
fi

if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
  unit="sinnix-${class}-$(date +%s%N)-$$"
  exec systemd-run \
    --user \
    --scope \
    --quiet \
    --collect \
    --same-dir \
    --unit="$unit" \
    --slice="$slice" \
    "${env_args[@]}" \
    -- "${scoped_command[@]}"
fi

exec "${scoped_command[@]}"

#!/usr/bin/env bash
# @sinnix-package
# description: Skip heavyweight maintenance starts while another maintenance unit is active
# runtimeInputs: bash coreutils gawk systemd util-linux

set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "usage: sinnix-maintenance-gate <self-unit> [system:unit|user:unit|unit ...]" >&2
  exit 64
fi

self="$1"
shift

if [ "$#" -gt 0 ]; then
  units=("$@")
else
  units=(
    system:btrbk.service
    system:borgbackup-job-persist.service
    system:borgbackup-job-realm.service
    system:borgbackup-check.service
    system:nix-gc.service
    system:nix-optimise.service
    system:sinex-blob-gc.service
    system:sinex-blob-fsck.service
    system:sinex-dev-cache-prune.service
    system:sinex-document-scan.service
  )
fi

active_system_unit() {
  local unit="$1"
  systemctl is-active --quiet "$unit" 2>/dev/null
}

active_user_unit() {
  local unit="$1"
  local uid user

  if [ "$(id -u)" -ne 0 ]; then
    systemctl --user is-active --quiet "$unit" 2>/dev/null
    return $?
  fi

  while read -r uid user; do
    [ -n "$uid" ] || continue
    [ -d "/run/user/$uid" ] || continue
    if runuser -u "$user" -- env XDG_RUNTIME_DIR="/run/user/$uid" systemctl --user is-active --quiet "$unit" 2>/dev/null; then
      return 0
    fi
  done < <(loginctl list-users --no-legend 2>/dev/null | awk '{print $1, $2}')

  return 1
}

for unit in "${units[@]}"; do
  manager="system"
  name="$unit"
  case "$unit" in
    system:*)
      manager="system"
      name="${unit#system:}"
      ;;
    user:*)
      manager="user"
      name="${unit#user:}"
      ;;
  esac

  [ "$name" != "$self" ] || continue

  active=false
  case "$manager" in
    system)
      if active_system_unit "$name"; then
        active=true
      fi
      ;;
    user)
      if active_user_unit "$name"; then
        active=true
      fi
      ;;
    *)
      echo "sinnix-maintenance-gate: unknown unit manager '$manager' for $unit" >&2
      exit 64
      ;;
  esac

  if [ "$active" = true ]; then
    echo "sinnix-maintenance-gate: skipping $self because $manager unit $name is active" >&2
    exit 1
  fi
done

exit 0

#!/usr/bin/env bash
# combine-files — interactively merge selected text files into a single document.
# Usage: combine-files [--directory DIR] [--output FILE] [--format text|markdown]

set -euo pipefail
IFS=$'\n\t'

require() {
  for cmd in "$@"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      echo "combine-files: missing dependency '$cmd'" >&2
      exit 1
    fi
  done
}

require fd fzf bat file stat date getopt

directory="."
output_file="combined.md"
output_format="markdown"

print_help() {
  cat <<'EOF'
Usage: combine-files [options]

Interactively merge multiple text files into a single document.

Options:
  -d, --directory DIR   Directory to scan (default: current directory)
  -o, --output FILE     Output file (default: combined.md)
  -f, --format FORMAT   Output format: text, markdown (default: markdown)
  -h, --help            Show this help message
EOF
  exit 0
}

OPTIONS=d:o:f:h
LONGOPTS=directory:,output:,format:,help
! parsed=$(getopt --options="$OPTIONS" --longoptions="$LONGOPTS" --name "combine-files" -- "$@") && exit 2
eval set -- "$parsed"

while true; do
  case "$1" in
    -d|--directory) directory="$2"; shift 2 ;;
    -o|--output) output_file="$2"; shift 2 ;;
    -f|--format) output_format="$2"; shift 2 ;;
    -h|--help) print_help ;;
    --) shift; break ;;
    *) break ;;
  esac
done

detailed_args=("$@")

if [[ ! -d "$directory" ]]; then
  echo "combine-files: directory '$directory' does not exist" >&2
  exit 1
fi

directory=$(cd "$directory" && pwd -P)

selected=()

# Allow file list from remaining arguments.
if [[ ${#detailed_args[@]} -gt 0 ]]; then
  selected=("${detailed_args[@]}")
fi

# Allow file list from stdin when not interactive.
if [[ ${#selected[@]} -eq 0 && ! -t 0 ]]; then
  while IFS= read -r line; do
    line=${line//$'\r'/}
    line=${line##+([[:space:]])}
    line=${line%%+([[:space:]])}
    [[ -n "$line" ]] && selected+=("$line")
  done
fi

normalise_path() {
  local candidate="$1"
  if [[ "$candidate" != /* ]]; then
    candidate="$directory/$candidate"
  fi
  readlink -f -- "$candidate" 2>/dev/null || printf '%s\n' "$candidate"
}

if [[ ${#selected[@]} -eq 0 ]]; then
  mapfile -t candidates < <(
    fd --type f --hidden --absolute-path \
       --exclude .git --exclude .obsidian --exclude node_modules --exclude vendor --exclude build \
       . "$directory"
  )

  files=()
  for path in "${candidates[@]}"; do
    if file --mime-type -b "$path" | grep -q '^text/'; then
      files+=("$path")
    fi
  done

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "combine-files: no text files found under '$directory'" >&2
    exit 1
  fi

  echo "Select files to include (TAB to multi-select, ENTER to confirm):"
  mapfile -t selected < <(
    printf '%s\n' "${files[@]}" |
      fzf --multi --layout=reverse \
          --preview 'sz=$(stat -c%s {}); tk=$((sz/4)); printf "Size: %d bytes | Tokens: %d\n\n" "$sz" "$tk"; bat --style=numbers --color=always {}' \
          --preview-window=right:60%:wrap \
          --prompt="› "
  )
fi

if [[ ${#selected[@]} -eq 0 ]]; then
  echo "combine-files: nothing selected; aborting."
  exit 0
fi

resolved=()
for f in "${selected[@]}"; do
  resolved_path=$(normalise_path "$f")
  if [[ ! -f "$resolved_path" ]]; then
    echo "combine-files: skipped non-existent file '$f'" >&2
    continue
  fi
  if ! file --mime-type -b "$resolved_path" | grep -q '^text/'; then
    echo "combine-files: skipped non-text file '$f'" >&2
    continue
  fi
  resolved+=("$resolved_path")
done

if [[ ${#resolved[@]} -eq 0 ]]; then
  echo "combine-files: no valid text files selected" >&2
  exit 1
fi

selected=("${resolved[@]}")

current_date=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
total_files=${#selected[@]}
total_tokens=0
declare -A size_map token_map

for f in "${selected[@]}"; do
  size=$(stat -c%s "$f")
  tokens=$((size / 4))
  size_map["$f"]=$size
  token_map["$f"]=$tokens
  total_tokens=$((total_tokens + tokens))
done

: >"$output_file"

if [[ "$output_format" == "markdown" ]]; then
  {
    echo '---'
    echo "generated: $current_date"
    echo "base_directory: $directory"
    echo "total_files: $total_files"
    echo "total_tokens_est: $total_tokens"
    echo '---'
    echo
    echo "## Table of Contents"
    echo
  } >>"$output_file"

  i=1
  for f in "${selected[@]}"; do
    rel=${f#"$directory"/}
    echo "$i. [$rel](#file-$i)" >>"$output_file"
    i=$((i + 1))
  done

  echo >>"$output_file"
else
  {
    echo "COMBINED FILES"
    echo "Generated: $current_date"
    echo "Directory: $directory"
    echo "Files: $total_files"
    echo "Estimated tokens: $total_tokens"
    echo
  } >>"$output_file"
fi

i=1
for f in "${selected[@]}"; do
  rel=${f#"$directory"/}
  sz=${size_map["$f"]}
  tk=${token_map["$f"]}
  typ=$(file -b "$f" | cut -d, -f1)

  if [[ "$output_format" == "markdown" ]]; then
    {
      echo "<a id=\"file-$i\"></a>"
      echo "## File: $rel"
      echo
      echo "- Size: $sz bytes"
      echo "- Tokens: $tk"
      echo "- Type: $typ"
      echo
    } >>"$output_file"

    ext=${f##*.}
    case "$ext" in
      js|ts) lang=javascript ;;
      py) lang=python ;;
      rb) lang=ruby ;;
      sh|bash) lang=bash ;;
      nix) lang=nix ;;
      md) lang=markdown ;;
      html) lang=html ;;
      css) lang=css ;;
      json) lang=json ;;
      xml) lang=xml ;;
      lua) lang=lua ;;
      *) lang="" ;;
    esac

    {
      echo '```'"$lang"
      cat "$f"
      echo '```'
      echo
    } >>"$output_file"
  else
    {
      echo "========================================"
      echo "FILE: $rel"
      echo "Size: $sz bytes | Tokens: $tk | Type: $typ"
      echo "========================================"
      echo
      cat "$f"
      echo
    } >>"$output_file"
  fi

  i=$((i + 1))
done

echo "combine-files: wrote '$output_file' (${#selected[@]} files, est. ${total_tokens} tokens)"

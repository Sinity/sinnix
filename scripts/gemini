#!/usr/bin/env bash
# Optimized Gemini CLI launch
# Avoids npx overhead by finding the pre-installed bundle.

# Search for the bundle in common locations
LOCATIONS=(
  "$HOME/.npm/_npx/38c708f8d73fe4c9/node_modules/@google/gemini-cli/bundle/index.js"
  "/realm/project/sinnix/node_modules/@google/gemini-cli/bundle/index.js"
  "$(npm root -g 2>/dev/null || echo '/nonexistent')/@google/gemini-cli/bundle/index.js"
)

BUNDLE=""
for loc in "${LOCATIONS[@]}"; do
  if [[ -f "$loc" ]]; then
    BUNDLE="$loc"
    break
  fi
done

if [[ -z "$BUNDLE" ]]; then
  # If bundle is not found, fallback to npx (slow)
  exec npx -y @google/gemini-cli "$@"
fi

exec node "$BUNDLE" "$@"

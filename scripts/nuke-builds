#!/usr/bin/env bash
# @sinnix-package
# description: Emergency load shedding for runaway background, build, and LSP work
# runtimeInputs: coreutils systemd procps gnugrep libnotify util-linux
# Emergency load shedding for the F9 recovery binding.
#
# SAFETY: Uses pgrep without -f to match process names only (not full command line)
# This prevents killing everything running from /nix/store/

set -euo pipefail

SYSTEM_UNITS=(
  "borgbackup-job-persist.service"
  "borgbackup-job-realm.service"
  "btrbk.service"
  "btrbk.timer"
  "sinex-runtime.timer"
  "sinex-runtime.target"
  "nats.service"
  "postgresql.service"
)

USER_UNITS=(
  "polylogue-run.service"
  "polylogued.service"
  "polylogue-browser-capture.service"
)

# Build tools and compilers (exact process names)
BUILD_PROCS=(
  "gcc" "g++" "clang" "clang++" "rustc"
  "cc1" "cc1plus" "ld" "lld" "mold"
  "cargo" "cmake" "make" "ninja" "meson" "pytest"
  "nix-daemon" "nix-build" "nix"
)

# LSP servers (exact process names)
LSP_PROCS=(
  "rust-analyzer" "clangd" "pyright" "gopls"
  "tsserver" "nil" "lua-language-server"
  "bash-language-server" "yaml-language-server"
)

BACKGROUND_PROCS=(
  "borg" "borgmatic" "btrbk"
  "sinex-ingestd" "sinex-preflight" "sinex-gateway"
  "polylogued" "polylogue" ".polylogue-wrap"
)

ALL_PROCS=("${BUILD_PROCS[@]}" "${LSP_PROCS[@]}" "${BACKGROUND_PROCS[@]}")

stop_units() {
  local scope="$1"
  shift
  local -a units=("$@")
  local -a systemctl_cmd=()

  if [ "${#units[@]}" -eq 0 ]; then
    return
  fi

  if [ "$scope" = "system" ]; then
    systemctl_cmd=(systemctl)
  elif [ "${EUID:-$(id -u)}" -eq 0 ]; then
    local target_user target_uid
    target_user="${SUDO_USER:-sinity}"
    target_uid="$(id -u "$target_user" 2>/dev/null || true)"
    if [ -z "$target_uid" ] || [ ! -d "/run/user/$target_uid" ]; then
      return
    fi
    systemctl_cmd=(runuser -u "$target_user" -- env "XDG_RUNTIME_DIR=/run/user/$target_uid" systemctl --user)
  else
    systemctl_cmd=(systemctl --user)
  fi

  timeout 2s "${systemctl_cmd[@]}" stop --no-block "${units[@]}" 2>/dev/null || true
  sleep 0.5
  timeout 2s "${systemctl_cmd[@]}" kill --kill-who=all --signal=TERM "${units[@]}" 2>/dev/null || true
  sleep 1
  timeout 2s "${systemctl_cmd[@]}" kill --kill-who=all --signal=KILL "${units[@]}" 2>/dev/null || true
}

rearm_sinex_runtime_timer() {
  if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    return
  fi

  # Emergency shedding should pause Sinex runtime work, not leave capture
  # permanently manual. Re-arm the existing delayed timer so recovery follows
  # the normal startup path instead of immediately restarting the target.
  timeout 2s systemctl start sinex-runtime.timer 2>/dev/null || true
}

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$@" 2>/dev/null || true
  fi
}

echo "Emergency load shedding..."

stop_units user "${USER_UNITS[@]}"
if [ "${EUID:-$(id -u)}" -eq 0 ]; then
  stop_units system "${SYSTEM_UNITS[@]}"
  rearm_sinex_runtime_timer
fi

killed=0
for proc in "${ALL_PROCS[@]}"; do
  # Find PIDs matching exact process name (NOT -f which matches full command line!)
  pids=$(pgrep -x "$proc" 2>/dev/null || true)

  if [ -n "$pids" ]; then
    echo "  Killing $proc: $pids"

    # SIGTERM first (give 0.5s to cleanup)
    kill -TERM $pids 2>/dev/null || true
    sleep 0.5

    # SIGKILL stragglers
    for pid in $pids; do
      if kill -0 "$pid" 2>/dev/null; then
        kill -KILL "$pid" 2>/dev/null || true
        ((killed++)) || true
      fi
    done
  fi
done

if [ "$killed" -gt 0 ]; then
  notify "Emergency Shed" "Stopped background units and killed $killed processes" -u normal
  echo "Killed $killed processes"
else
  notify "Emergency Shed" "Stopped background units" -u normal
  echo "No matching processes found"
fi

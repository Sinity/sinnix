#!/usr/bin/env bash
# @sinnix-package: skip
set -euo pipefail

# Persistent rawlog capture loop for the kitty scratchpad.
# Delegates to rawlog-capture repeatedly so the window stays warm.

RAWLOG_CAPTURE_BIN=${RAWLOG_CAPTURE_BIN:-$HOME/.local/bin/rawlog-capture}
CANCEL_CODE=${RAWLOG_CANCEL_CODE:-130}
SUCCESS_BACKOFF_SECONDS=${RAWLOG_SUCCESS_BACKOFF_SECONDS:-1}

if [ ! -x "$RAWLOG_CAPTURE_BIN" ]; then
  echo "rawlog-loop: capture binary not executable: $RAWLOG_CAPTURE_BIN" >&2
  exit 1
fi

while true; do
  started_at=${SECONDS}
  # Clear the terminal so each capture starts fresh.
  printf '\033c'
  "$RAWLOG_CAPTURE_BIN"
  status=$?
  runtime=$((SECONDS - started_at))
  case "$status" in
    0)
      if (( runtime < SUCCESS_BACKOFF_SECONDS )); then
        sleep "$SUCCESS_BACKOFF_SECONDS"
      fi
      continue
      ;;
    "$CANCEL_CODE")
      exit 0
      ;;
    *)
      exit "$status"
      ;;
  esac
done

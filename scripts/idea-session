class IdeaSessionError(Exception):
    """Raised when session orchestration encounters a recoverable error."""


def command_exists(binary: str) -> bool:
    return shutil.which(binary) is not None


def ensure_base_assets() -> None:
    SESSION_BASE.mkdir(parents=True, exist_ok=True)
    CONFIG_HOME.mkdir(parents=True, exist_ok=True)
    if not BASE_AGENTS.exists():
        BASE_AGENTS.write_text(
            """# Session Guidance\nKeep `scratch.md` accurate, record next actions before you leave, and treat the session directory as disposable context.\n""",
            encoding="utf-8",
        )


def slugify(text: str) -> str:
    lowered = text.strip().lower()
    pieces: List[str] = []
    for word in lowered.split()[:5]:
        cleaned = "".join(ch for ch in word if ch.isalnum())
        if cleaned:
            pieces.append(cleaned)
    return "-".join(pieces) or "session"


def _run_picker(cmd: List[str], tmp_path: Path) -> Optional[str]:
    try:
        result = subprocess.run(cmd, check=False, text=True)
    except FileNotFoundError:
        return None
    if result.returncode != 0:
        return None
    if not tmp_path.exists():
        return None
    data = tmp_path.read_text(encoding="utf-8").strip()
    tmp_path.unlink(missing_ok=True)
    return data or None


def _yazi_pick(default: Path) -> Optional[Path]:
    if not command_exists("yazi"):
        return None
    with tempfile.NamedTemporaryFile(delete=False) as tmp:
        tmp_path = Path(tmp.name)
    selection = _run_picker(["yazi", "--chooser-file", str(tmp_path), str(default)], tmp_path)
    if selection:
        return Path(selection)
    return None


def _broot_pick(default: Path) -> Optional[Path]:
    if not command_exists("broot"):
        return None
    with tempfile.NamedTemporaryFile(delete=False) as tmp:
        tmp_path = Path(tmp.name)
    try:
        subprocess.run(["broot", "--outcmd", str(tmp_path), str(default)], check=False)
        if not tmp_path.exists():
            return None
        lines = tmp_path.read_text(encoding="utf-8").splitlines()
    finally:
        tmp_path.unlink(missing_ok=True)
    for line in reversed(lines):
        if line.startswith("cd "):
            parts = shlex.split(line, posix=True)
            if len(parts) == 2:
                return Path(parts[1])
    return None


def select_directory(default: Path) -> Path:
    default = default.expanduser()
    preference: List[str] = []
    if PATH_PICKER:
        preference.append(PATH_PICKER)
    preference.extend(["yazi", "broot"])

    for picker in preference:
        picker = picker.lower()
        if picker == "yazi":
            choice = _yazi_pick(default)
        elif picker == "broot":
            choice = _broot_pick(default)
        else:
            choice = None
        if choice is not None:
            return choice.expanduser().resolve()

    if command_exists("gum"):
        proc = subprocess.run(
            ["gum", "input", "--placeholder", "Path to primary working directory", "--value", str(default)],
            capture_output=True,
            text=True,
            check=False,
        )
        selection = proc.stdout.strip()
    else:
        try:
            selection = input(f"Primary working directory (default {default}): ")
        except EOFError:
            selection = ""

    if not selection:
        return default.resolve()
    try:
        return Path(selection).expanduser().resolve()
    except FileNotFoundError:
        return Path(selection).expanduser()


def gum_input(prompt: str, default: str = "") -> str:
    if command_exists("gum"):
        proc = subprocess.run(
            ["gum", "input", "--placeholder", prompt, "--value", default],
            capture_output=True,
            text=True,
            check=False,
        )
        return proc.stdout.strip() or default
    try:
        value = input(f"{prompt}: ")
    except EOFError:
        value = ""
    return (value or default).strip()


def gum_multiline(prompt: str) -> str:
    if command_exists("gum"):
        proc = subprocess.run(
            ["gum", "write", "--placeholder", prompt],
            capture_output=True,
            text=True,
            check=False,
        )
        return proc.stdout.strip()
    print(f"{prompt} (finish with an empty line):")
    lines: List[str] = []
    while True:
        try:
            line = input()
        except EOFError:
            break
        if line.strip() == "" and lines:
            break
        lines.append(line)
    return "\n".join(lines).strip()


def gum_choose(header: str, options: List[str], default: Optional[str] = None) -> Optional[str]:
    if not options:
        return None
    if command_exists("gum"):
        args = ["gum", "choose", "--height", "20", "--header", header]
        if default:
            args.extend(["--selected", default])
        proc = subprocess.run(args + options, capture_output=True, text=True, check=False)
        if proc.returncode != 0:
            return None
        return proc.stdout.strip()
    if command_exists("fzf"):
        proc = subprocess.run(
            ["fzf", "--prompt", f"{header}> "],
            input="\n".join(options),
            capture_output=True,
            text=True,
            check=False,
        )
        if proc.returncode != 0:
            return None
        return proc.stdout.strip()
    print("\n".join(options))
    try:
        choice = input(f"{header}> ")
    except EOFError:
        choice = ""
    return choice.strip() or default


def render_envrc(session_dir: Path) -> str:
    return textwrap.dedent(
        f"""
        export SESSION_ROOT=\"{session_dir}\"
        export SESSION_SLUG=\"{session_dir.name}\"
        if [ -L work ] || [ -d work ]; then
          SESSION_WORK=$(readlink -f work 2>/dev/null || true)
          if [ -n \"$SESSION_WORK\" ]; then
            export SESSION_WORK
            if [ -f \"$SESSION_WORK/.envrc\" ]; then
              source \"$SESSION_WORK/.envrc\"
            fi
          else
            unset SESSION_WORK
          fi
        else
          unset SESSION_WORK
        fi
        """
    ).strip() + "\n"


def get_session_work(session_dir: Path) -> Optional[str]:
    pointer = session_dir / "work.path"
    if pointer.exists():
        candidate = pointer.read_text(encoding="utf-8").strip()
        if candidate:
            resolved = Path(candidate).expanduser()
            if resolved.exists():
                return str(resolved)
    link = session_dir / "work"
    if link.exists():
        try:
            resolved_link = link.resolve()
        except OSError:
            return None
        if resolved_link.exists():
            return str(resolved_link)
    return None


def session_env(session_dir: Path) -> Dict[str, str]:
    env = os.environ.copy()
    env.setdefault("SESSION_ROOT", str(session_dir))
    env.setdefault("SESSION_SLUG", session_dir.name)
    work = get_session_work(session_dir)
    if work:
        env.setdefault("SESSION_WORK", work)
    return env


def resume_path(session_dir: Path) -> Path:
    return session_dir / "resume.json"


def load_resume(session_dir: Path) -> Dict[str, List[Dict[str, Any]]]:
    path = resume_path(session_dir)
    if path.exists():
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            data = {}
    else:
        data = {}
    commands: List[Dict[str, Any]] = []
    for entry in data.get("commands", []):
        if isinstance(entry, dict) and entry.get("cmd"):
            cmd_value = entry["cmd"]
            if isinstance(cmd_value, str):
                entry["cmd"] = shlex.split(cmd_value)
            elif isinstance(cmd_value, list):
                entry["cmd"] = [str(part) for part in cmd_value]
            else:
                continue
            commands.append(entry)
    data["commands"] = commands
    return data


def save_resume(session_dir: Path, data: Dict[str, List[Dict[str, Any]]]) -> None:
    resume_path(session_dir).write_text(
        json.dumps({"commands": data.get("commands", [])}, indent=2),
        encoding="utf-8",
    )


def count_resume_commands(session_dir: Path) -> int:
    return len(load_resume(session_dir).get("commands", []))


def run_resume_commands(session_dir: Path) -> None:
    data = load_resume(session_dir)
    commands = data.get("commands", [])
    if not commands:
        return
    env = session_env(session_dir)
    for entry in commands:
        cmd = entry.get("cmd")
        if not cmd:
            continue
        cmd_list = shlex.split(cmd) if isinstance(cmd, str) else [str(part) for part in cmd]
        cwd_value = entry.get("cwd")
        if cwd_value:
            cwd_path = Path(cwd_value).expanduser()
            if not cwd_path.is_absolute():
                cwd_path = (session_dir / cwd_path).resolve()
        else:
            cwd_path = session_dir
        if not cwd_path.exists():
            print(
                f"idea-session: skip resume command {' '.join(cmd_list)} (missing cwd {cwd_path})",
                file=sys.stderr,
            )
            continue
        try:
            subprocess.Popen(
                cmd_list,
                cwd=str(cwd_path),
                env=env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        except OSError as exc:
            print(f"idea-session: failed to run {' '.join(cmd_list)}: {exc}", file=sys.stderr)


def _build_command(session_dir: Path, exec_tail: str) -> str:
    return (
        "if [ -n \"${SESSION_WORK:-}\" ]; then cd \"${SESSION_WORK}\"; "
        f"elif [ -d '{session_dir}/work' ]; then cd '{session_dir}/work'; "
        f"else cd '{session_dir}'; fi; exec {exec_tail}"
    )


def write_workspace(session_dir: Path, slug: str, title: str, work_path: Optional[Path], timestamp: str) -> Path:
    workspace_path = session_dir / f"{slug}.code-workspace"
    action_command = _build_command(session_dir, "${SHELL:-/bin/bash}")
    tasks: List[Dict[str, Any]] = [
        {
            "label": "Session Action",
            "type": "shell",
            "command": "/usr/bin/env",
            "args": ["bash", "-lc", action_command],
            "options": {"cwd": "${workspaceFolder}"},
            "isBackground": False,
            "problemMatcher": [],
            "presentation": {"reveal": "always", "panel": "dedicated", "focus": True},
            "runOptions": {"runOn": "folderOpen"},
        }
    ]
    if command_exists("codex"):
        codex_command = _build_command(session_dir, "codex")
        tasks.append(
            {
                "label": "Session Codex",
                "type": "shell",
                "command": "/usr/bin/env",
                "args": ["bash", "-lc", codex_command],
                "options": {"cwd": "${workspaceFolder}"},
                "isBackground": False,
                "problemMatcher": [],
                "presentation": {"reveal": "always", "panel": "dedicated", "focus": False},
                "runOptions": {"runOn": "folderOpen"},
            }
        )

    folders = [{"name": "session", "path": "."}]
    if work_path is not None:
        folders.append({"name": f"work: {work_path.name}", "path": "work"})

    workspace = {
        "folders": folders,
        "settings": {
            "task.allowAutomaticTasks": "on",
            "window.title": f"session: {slug} — {title}",
            "terminal.integrated.enablePersistentSessions": True,
            "terminal.integrated.defaultProfile.linux": "session::action",
            "terminal.integrated.env.linux": {
                "SESSION_ROOT": str(session_dir),
                "SESSION_SLUG": slug,
                "SESSION_CREATED": timestamp,
                "SESSION_LABEL": title,
            },
            "terminal.integrated.profiles.linux": {
                "session::action": {
                    "path": "/usr/bin/env",
                    "args": ["bash", "-lc", action_command],
                    "icon": "terminal",
                }
            },
            "workbench.editor.enablePreview": False,
            "files.exclude": {"links": False, "*.code-workspace": False},
        },
        "extensions": {"recommendations": ["bierner.markdown-preview-github-styles"]},
        "tasks": {"version": "2.0.0", "tasks": tasks},
    }
    workspace_path.write_text(json.dumps(workspace, indent=2), encoding="utf-8")
    return workspace_path


def write_layout_templates(session_dir: Path, slug: str, persona: str) -> None:
    template = PERSONA_TEMPLATES.get(persona, PERSONA_TEMPLATES["focus"])
    layout_dir = session_dir / "layout"
    layout_dir.mkdir(exist_ok=True)
    hypr_text = template["hypr"].format(slug=slug).strip() + "\n"
    (layout_dir / "hypr.conf").write_text(hypr_text, encoding="utf-8")
    pypr_text = template["pypr"].format(slug=slug).strip() + "\n"
    (layout_dir / "pypr.toml").write_text(pypr_text, encoding="utf-8")


def apply_layout_template(session_dir: Path, slug: str) -> None:
    layout_dir = session_dir / "layout"
    hypr_conf = layout_dir / "hypr.conf"
    if hypr_conf.exists() and command_exists("hyprctl"):
        dest_dir = Path.home() / ".config/hypr/session"
        dest_dir.mkdir(parents=True, exist_ok=True)
        target = dest_dir / f"{slug}.conf"
        shutil.copyfile(hypr_conf, target)
        subprocess.run(["hyprctl", "keyword", "source", str(target)], check=False)
    pypr_conf = layout_dir / "pypr.toml"
    if pypr_conf.exists() and command_exists("pypr"):
        dest_dir = Path.home() / ".config/pypr/session"
        dest_dir.mkdir(parents=True, exist_ok=True)
        target = dest_dir / f"{slug}.toml"
        shutil.copyfile(pypr_conf, target)
        subprocess.run(["pypr", "reload"], check=False)


def create_session(persona: str = "focus") -> None:
    ensure_base_assets()
    idea = gum_input("Describe the session")
    if not idea:
        raise IdeaSessionError("Session description is required")

    slug_root = f"{datetime.now().strftime('%Y-%m-%d-%H%M')}-{slugify(idea)}"
    session_dir = SESSION_BASE / slug_root
    counter = 1
    while session_dir.exists():
        session_dir = SESSION_BASE / f"{slug_root}-{counter}"
        counter += 1
    slug = session_dir.name
    session_dir.mkdir(parents=True)
    (session_dir / "links").mkdir(exist_ok=True)

    work_path = select_directory(Path.cwd())
    resolved_work: Optional[Path]
    if work_path.exists():
        resolved_work = work_path
        (session_dir / "work").symlink_to(resolved_work)
    else:
        resolved_work = None

    timestamp = datetime.now().isoformat(timespec="seconds")
    (session_dir / "title.txt").write_text(idea + "\n", encoding="utf-8")
    (session_dir / "slug").write_text(slug + "\n", encoding="utf-8")
    (session_dir / "created").write_text(timestamp + "\n", encoding="utf-8")
    if resolved_work is not None:
        (session_dir / "work.path").write_text(str(resolved_work) + "\n", encoding="utf-8")

    scratch = textwrap.dedent(
        f"""
        # {idea}

        Created: {timestamp}

        ## Intent
        {idea}

        ## Next
        - [ ] 

        ## Notes
        """
    ).strip() + "\n"
    (session_dir / "scratch.md").write_text(scratch, encoding="utf-8")

    agents_sections: List[str] = []
    if BASE_AGENTS.exists():
        agents_sections.append(BASE_AGENTS.read_text(encoding="utf-8").strip())
    agents_sections.append("---\n\n## Session Focus\n" + idea)
    (session_dir / "AGENTS.md").write_text("\n\n".join(agents_sections) + "\n", encoding="utf-8")

    meta = {
        "slug": slug,
        "title": idea,
        "created": timestamp,
        "work_path": str(resolved_work) if resolved_work else None,
        "persona": persona,
        "links": [],
    }
    (session_dir / "session.meta.json").write_text(json.dumps(meta, indent=2), encoding="utf-8")

    (session_dir / ".envrc").write_text(render_envrc(session_dir), encoding="utf-8")
    save_resume(session_dir, {"commands": []})
    write_layout_templates(session_dir, slug, persona)

    workspace = write_workspace(session_dir, slug, idea, resolved_work, timestamp)
    if command_exists("direnv"):
        subprocess.run(["direnv", "allow", str(session_dir)], check=False)

    print(f"Created session {slug}")
    open_session(slug, workspace)


def handle_link(args: argparse.Namespace) -> None:
    ensure_base_assets()
    session_dir = SESSION_BASE / args.slug
    if not session_dir.exists():
        raise IdeaSessionError(f"Session {args.slug} not found")

    meta_path = session_dir / "session.meta.json"
    if meta_path.exists():
        meta = json.loads(meta_path.read_text(encoding="utf-8"))
    else:
        meta = {"slug": session_dir.name}
    existing_links = meta.get("links", [])

    if args.list:
        if not existing_links:
            print("No additional links registered.")
            return
        for entry in existing_links:
            alias = entry.get("alias", "") or "<unnamed>"
            target = entry.get("path", "")
            desc = entry.get("description", "")
            line = f"{alias} -> {target}"
            if desc:
                line += f" — {desc}"
            print(line)
        return

    links_dir = session_dir / "links"
    links_dir.mkdir(exist_ok=True)

    if args.remove:
        alias = args.remove
        remaining = [entry for entry in existing_links if entry.get("alias") != alias]
        if len(remaining) == len(existing_links):
            print(f"No link named {alias} to remove.")
            return
        meta["links"] = remaining
        (links_dir / alias).unlink(missing_ok=True)
        meta_path.write_text(json.dumps(meta, indent=2), encoding="utf-8")
        print(f"Removed link {alias}")
        return

    if not args.alias or not args.path:
        raise IdeaSessionError("link command requires --alias and --path unless using --list/--remove")

    target_path = Path(args.path).expanduser()
    if not target_path.exists():
        raise IdeaSessionError(f"Target path {target_path} does not exist")

    link_path = links_dir / args.alias
    link_path.unlink(missing_ok=True)
    link_path.symlink_to(target_path)

    entry = {
        "alias": args.alias,
        "path": str(target_path.resolve()),
        "description": args.description,
    }
    filtered = [e for e in existing_links if e.get("alias") != args.alias]
    filtered.append(entry)
    meta["links"] = filtered
    meta_path.write_text(json.dumps(meta, indent=2), encoding="utf-8")
    print(f"Linked {args.alias} -> {target_path}")


def handle_remember(args: argparse.Namespace) -> None:
    ensure_base_assets()
    session_dir = SESSION_BASE / args.slug
    if not session_dir.exists():
        raise IdeaSessionError(f"Session {args.slug} not found")

    resume = load_resume(session_dir)
    if args.list:
        commands = resume.get("commands", [])
        if not commands:
            print("No resume commands registered.")
            return
        for entry in commands:
            cmd_list = entry.get("cmd", [])
            cmd_str = " ".join(shlex.quote(str(part)) for part in cmd_list)
            cwd = entry.get("cwd") or str(session_dir)
            tag = entry.get("tag")
            added = entry.get("added", "")
            line = f"{cmd_str} (cwd={cwd})"
            if tag:
                line += f" tag={tag}"
            if added:
                line += f" added={added}"
            print(line)
        return

    if args.remove:
        tag_to_remove = args.remove
        commands = [entry for entry in resume.get("commands", []) if entry.get("tag") != tag_to_remove]
        resume["commands"] = commands
        save_resume(session_dir, resume)
        print(f"Removed resume command tagged {tag_to_remove}")
        return

    if args.clear:
        resume["commands"] = []
        save_resume(session_dir, resume)
        print(f"Cleared resume commands for {args.slug}")
        return

    if args.template:
        work = get_session_work(session_dir)
        if args.template == "browser":
            command = ["google-chrome"]
            if work:
                command.append(work)
        elif args.template == "codex":
            command = ["codex"]
        else:
            raise IdeaSessionError(f"Unknown template {args.template}")
    else:
        if not args.cmd:
            raise IdeaSessionError("Provide a command after '--' to register, or use --template/--list/--clear.")
        command = [str(part) for part in args.cmd]

    if args.cwd:
        cwd_path = Path(args.cwd).expanduser()
        if not cwd_path.is_absolute():
            cwd_path = (session_dir / cwd_path).resolve()
        else:
            cwd_path = cwd_path.resolve()
    else:
        cwd_path = session_dir

    entry = {
        "cmd": command,
        "cwd": str(cwd_path),
        "tag": args.tag,
        "added": datetime.now().isoformat(timespec="seconds"),
    }

    commands = resume.setdefault("commands", [])
    if any(existing.get("cmd") == entry["cmd"] and existing.get("cwd") == entry["cwd"] for existing in commands):
        print("Command already registered for this session; skipping.")
        return

    commands.append(entry)
    save_resume(session_dir, resume)
    print(f"Registered resume command for {args.slug}: {' '.join(command)}")


def collect_retrospective() -> str:
    wins = gum_multiline("Wins")
    frictions = gum_multiline("Frictions")
    next_steps = gum_multiline("Next steps")
    return textwrap.dedent(
        f"""
        # Retrospective
        Date: {datetime.now().isoformat(timespec='seconds')}

        ## Wins
        {wins or '-'}

        ## Frictions
        {frictions or '-'}

        ## Next
        {next_steps or '-'}
        """
    ).strip() + "\n"


def capture_artifacts(session_dir: Path, retrospective_text: str, summary_text: str) -> None:
    artifact_dir = session_dir / "artifacts"
    artifact_dir.mkdir(exist_ok=True)
    (artifact_dir / "RETROSPECTIVE.md").write_text(retrospective_text, encoding="utf-8")
    (artifact_dir / "SUMMARY.md").write_text(summary_text + "\n", encoding="utf-8")

    if SESSION_HISTORY_FILE:
        history_path = Path(SESSION_HISTORY_FILE).expanduser()
        if history_path.exists():
            shutil.copy(history_path, artifact_dir / "terminal-history.txt")
        else:
            print(f"idea-session: SESSION_HISTORY_FILE {history_path} not found", file=sys.stderr)

    if SESSION_CODEX_LOG:
        codex_path = Path(SESSION_CODEX_LOG).expanduser()
        if codex_path.exists():
            shutil.copy(codex_path, artifact_dir / codex_path.name)
        else:
            print(f"idea-session: SESSION_CODEX_LOG {codex_path} not found", file=sys.stderr)

    if SESSION_CODEX_LOG_DIR:
        codex_dir = Path(SESSION_CODEX_LOG_DIR).expanduser()
        target_dir = artifact_dir / "codex-logs"
        if codex_dir.exists() and codex_dir.is_dir():
            if target_dir.exists():
                shutil.rmtree(target_dir)
            shutil.copytree(codex_dir, target_dir)
        else:
            print(f"idea-session: SESSION_CODEX_LOG_DIR {codex_dir} not found", file=sys.stderr)


def export_summary(slug: str, summary_text: str, retrospective_text: str, archive_path: Path) -> None:
    SESSION_EXPORT_ROOT.mkdir(parents=True, exist_ok=True)
    export_file = SESSION_EXPORT_ROOT / f"{slug}.md"
    composite = textwrap.dedent(
        f"""
        # {slug}

        ## Summary
        {summary_text or '-'}

        {retrospective_text.strip()}

        ---
        Archived at: {archive_path}
        """
    ).strip() + "\n"
    export_file.write_text(composite, encoding="utf-8")


def handle_close(args: argparse.Namespace) -> None:
    ensure_base_assets()
    session_dir = SESSION_BASE / args.slug
    if not session_dir.exists():
        raise IdeaSessionError(f"Session {args.slug} not found")

    meta_path = session_dir / "session.meta.json"
    if meta_path.exists():
        meta = json.loads(meta_path.read_text(encoding="utf-8"))
    else:
        meta = {"slug": session_dir.name}

    SESSION_ARCHIVE_ROOT.mkdir(parents=True, exist_ok=True)
    timestamp = datetime.now().strftime("%Y-%m-%d-%H%M")
    archive_dir = SESSION_ARCHIVE_ROOT / f"{timestamp}-{session_dir.name}"
    counter = 1
    while archive_dir.exists():
        archive_dir = SESSION_ARCHIVE_ROOT / f"{timestamp}-{session_dir.name}-{counter}"
        counter += 1

    if args.dry_run:
        print(f"Would move {session_dir} -> {archive_dir}")
        return

    summary_text = (args.summary or gum_multiline("Session summary")).strip()
    retrospective_text = collect_retrospective()

    capture_artifacts(session_dir, retrospective_text, summary_text or "Session closed.")

    (session_dir / "SUMMARY.md").write_text((summary_text or "Session closed.") + "\n", encoding="utf-8")
    (session_dir / "RETROSPECTIVE.md").write_text(retrospective_text, encoding="utf-8")

    meta["closed"] = datetime.now().isoformat(timespec="seconds")
    meta_path.write_text(json.dumps(meta, indent=2), encoding="utf-8")

    export_summary(args.slug, summary_text, retrospective_text, archive_dir)
    session_dir.rename(archive_dir)
    print(f"Session archived to {archive_dir}")


def open_session(slug: str, workspace: Optional[Path] = None) -> None:
    ensure_base_assets()
    session_dir = SESSION_BASE / slug
    if not session_dir.exists():
        raise IdeaSessionError(f"Session {slug} not found")

    meta_path = session_dir / "session.meta.json"
    meta = json.loads(meta_path.read_text(encoding="utf-8")) if meta_path.exists() else {}

    if workspace is None:
        candidates = sorted(session_dir.glob("*.code-workspace"))
        if not candidates:
            raise IdeaSessionError("No workspace file found")
        workspace = candidates[0]

    if command_exists("hyprctl"):
        subprocess.run(["hyprctl", "dispatch", "workspace", f"name:{slug}"], check=False)

    args = [str(workspace)]
    for extra in (session_dir / "scratch.md", session_dir / "AGENTS.md"):
        if extra.exists():
            args.append(str(extra))

    launcher = shutil.which("code") or shutil.which("codium")
    if launcher is None:
        raise IdeaSessionError("Neither code nor codium is available")

    subprocess.Popen([launcher, "--new-window", *args], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    run_resume_commands(session_dir)
    apply_layout_template(session_dir, slug)


def list_sessions() -> List[str]:
    ensure_base_assets()
    entries: List[tuple] = []
    for directory in SESSION_BASE.iterdir():
        if not directory.is_dir():
            continue
        title_file = directory / "title.txt"
        title = title_file.read_text(encoding="utf-8").splitlines()[0] if title_file.exists() else ""
        persona = "focus"
        meta_file = directory / "session.meta.json"
        if meta_file.exists():
            try:
                persona = json.loads(meta_file.read_text(encoding="utf-8")).get("persona", "focus")
            except json.JSONDecodeError:
                persona = "focus"
        resume_count = count_resume_commands(directory)
        label = f"{directory.name} — {title}" if title else directory.name
        label = f"{label} [{persona}]"
        if resume_count:
            label = f"{label} (resume:{resume_count})"
        entries.append((directory.stat().st_mtime, label))
    entries.sort(reverse=True)
    return [label for _, label in entries]


def menu() -> None:
    options = ["Create new session", *list_sessions(), "Exit"]
    choice = gum_choose("Idea Sessions", options)
    if choice in (None, "Exit"):
        return
    if choice == "Create new session":
        persona_choice = gum_choose("Persona", list(PERSONA_TEMPLATES.keys()), default="focus") or "focus"
        create_session(persona=persona_choice)
        return
    slug = choice.split(" — ", 1)[0]
    slug = slug.split(" [", 1)[0]
    open_session(slug)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Idea session orchestrator")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("menu")
    new_parser = sub.add_parser("new")
    new_parser.add_argument("--persona", choices=list(PERSONA_TEMPLATES.keys()), default="focus")

    open_parser = sub.add_parser("open")
    open_parser.add_argument("slug")

    sub.add_parser("list")

    remember_parser = sub.add_parser("remember")
    remember_parser.add_argument("slug")
    rem_group = remember_parser.add_mutually_exclusive_group()
    rem_group.add_argument("--list", action="store_true", help="List registered resume commands")
    rem_group.add_argument("--clear", action="store_true", help="Clear all resume commands")
    remember_parser.add_argument("--remove", metavar="TAG", help="Remove a resume command by tag")
    remember_parser.add_argument("--cwd", help="Working directory for the command")
    remember_parser.add_argument("--tag", help="Optional label for the command")
    remember_parser.add_argument("--template", choices=["browser", "codex"], help="Register a predefined command template")
    remember_parser.add_argument(
        "cmd",
        nargs=argparse.REMAINDER,
        help="Command to register (use -- to separate, e.g. idea-session remember <slug> -- firefox)",
    )

    link_parser = sub.add_parser("link")
    link_parser.add_argument("slug")
    link_parser.add_argument("--alias", help="Name for the link entry")
    link_parser.add_argument("--path", help="Filesystem path to link")
    link_parser.add_argument("--description", help="Optional description for the link")
    link_parser.add_argument("--list", action="store_true", help="List existing links")
    link_parser.add_argument("--remove", help="Remove a link by alias")

    close_parser = sub.add_parser("close")
    close_parser.add_argument("slug")
    close_parser.add_argument("--summary", help="Write a closing note to SUMMARY.md")
    close_parser.add_argument("--dry-run", action="store_true", help="Preview archive path without moving")

    return parser


def main(argv: List[str]) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        if args.command == "new":
            create_session(persona=args.persona)
        elif args.command == "open":
            open_session(args.slug)
        elif args.command == "list":
            for line in list_sessions():
                print(line)
        elif args.command == "remember":
            handle_remember(args)
        elif args.command == "link":
            handle_link(args)
        elif args.command == "close":
            handle_close(args)
        else:
            menu()
    except IdeaSessionError as exc:
        print(f"idea-session: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))

#!/usr/bin/env bash
set -euo pipefail

# Determine where to look for .code-workspace files.
# Prefer explicit WS_DIR, then FLAKE repo root, then fallback path.
WS_DIR=${WS_DIR:-${FLAKE:-/realm/project/sinnix}}

entries=()
add() { entries+=("$1") ; }

[ -f "$WS_DIR/sinnix.code-workspace" ] && add "Sinnix → $WS_DIR/sinnix.code-workspace"
[ -f "$WS_DIR/sinex.code-workspace" ] && add "Sinex → $WS_DIR/sinex.code-workspace"
[ -f "$WS_DIR/knowledgebase.code-workspace" ] && add "Knowledgebase → $WS_DIR/knowledgebase.code-workspace"

# Fallback if none found
[ ${#entries[@]} -eq 0 ] && entries+=("Open current folder → .")

menu_input=$(printf "%s\n" "${entries[@]}")

pick_menu() {
  local prompt="$1" input="$2"
  if command -v rofi >/dev/null 2>&1; then
    echo "$input" | rofi -dmenu -p "$prompt"
  elif command -v wofi >/dev/null 2>&1; then
    echo "$input" | wofi --dmenu --prompt "$prompt"
  elif command -v tofi >/dev/null 2>&1; then
    echo "$input" | tofi --prompt "$prompt: " --horizontal=false --fuzzy-match=true | sed 's/\r$//'
  elif command -v fzf >/dev/null 2>&1; then
    echo "$input" | fzf --prompt "$prompt> "
  else
    printf "%s\n> " "$prompt"; echo "$input" | nl -ba; read -r choice; echo "$choice"
  fi
}

choice=$(pick_menu "Workspace" "$menu_input")
[ -z "$choice" ] && exit 0

target=${choice#*→ }
target=$(echo "$target" | xargs)

open_code() {
  if command -v code >/dev/null 2>&1; then
    code --reuse-window "$1" >/dev/null 2>&1 &
  elif command -v codium >/dev/null 2>&1; then
    codium --reuse-window "$1" >/dev/null 2>&1 &
  else
    echo "No VS Code or VSCodium found." >&2; exit 1
  fi
}

open_code "$target"

#!/usr/bin/env bash
set -euo pipefail

shell_bin="${SHELL:-}"
if [[ -z "$shell_bin" || ! -x "$shell_bin" ]]; then
  shell_bin="$(command -v zsh)"
fi

capture_root="${SINNIX_CAPTURE_ROOT:-/realm/data/captures/asciinema}"
capture_disabled="${SINNIX_CAPTURE_DISABLE:-}"

json_escape() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

json_string() {
  printf '"%s"' "$(json_escape "${1:-}")"
}

json_nullable_string() {
  if [[ -n "${1:-}" ]]; then
    json_string "$1"
  else
    printf 'null'
  fi
}

json_nullable_int() {
  if [[ -n "${1:-}" ]]; then
    printf '%s' "$1"
  else
    printf 'null'
  fi
}

now_ms() {
  local raw="${EPOCHREALTIME:-}"

  if [[ -z "$raw" ]]; then
    raw="$(printf '%(%s)T' -1).000"
  fi

  raw="${raw//,/.}"

  local sec="${raw%%.*}"
  local frac="${raw#*.}"

  if [[ "$frac" == "$raw" ]]; then
    frac="0"
  fi

  frac="${frac}000"
  printf '%s%s' "$sec" "${frac:0:3}"
}

guess_project_root() {
  local cwd="$1"
  if [[ "$cwd" == /realm/project/* ]]; then
    local suffix="${cwd#/realm/project/}"
    local name="${suffix%%/*}"
    if [[ -n "$name" ]]; then
      printf '/realm/project/%s' "$name"
      return 0
    fi
  fi
  printf ''
}

find_repo_root() {
  local dir="$1"

  while [[ -n "$dir" && "$dir" != "/" ]]; do
    if [[ -d "$dir/.git" || -f "$dir/.git" ]]; then
      printf '%s' "$dir"
      return 0
    fi

    dir="${dir%/*}"
    if [[ -z "$dir" ]]; then
      dir="/"
    fi
  done

  return 1
}

repo_branch() {
  local repo_root="$1"
  if [[ -z "$repo_root" ]] || ! command -v git >/dev/null 2>&1; then
    return 0
  fi
  git -C "$repo_root" symbolic-ref --quiet --short HEAD 2>/dev/null \
    || git -C "$repo_root" rev-parse --short HEAD 2>/dev/null \
    || true
}

repo_commit() {
  local repo_root="$1"
  if [[ -z "$repo_root" ]] || ! command -v git >/dev/null 2>&1; then
    return 0
  fi
  git -C "$repo_root" rev-parse HEAD 2>/dev/null || true
}

repo_dirty() {
  local repo_root="$1"
  if [[ -z "$repo_root" ]] || ! command -v git >/dev/null 2>&1; then
    return 0
  fi
  if [[ -n "$(git -C "$repo_root" status --porcelain --ignore-submodules=dirty 2>/dev/null)" ]]; then
    printf 'true'
  else
    printf 'false'
  fi
}

while IFS='=' read -r name _; do
  case "$name" in
    SINNIX_CAPTURE_*)
      unset "$name"
      ;;
  esac
done < <(env)
unset SINNIX_CAPTURE_ACTIVE SINNIX_CAPTURE_CAST_FILE ASCIINEMA_SESSION || true

if [[ -n "$capture_disabled" || -n "${TMUX:-}" || ! -t 0 || -z "${KITTY_PID:-}" ]]; then
  exec "$shell_bin"
fi

if ! command -v asciinema >/dev/null 2>&1 || ! command -v setsid >/dev/null 2>&1; then
  exec "$shell_bin"
fi

tty_path="$(tty 2>/dev/null || true)"
if [[ "$tty_path" == "not a tty" ]]; then
  tty_path=""
fi

tty_slug="${tty_path//\//_}"
if [[ -z "$tty_slug" ]]; then
  tty_slug="unknown_tty"
fi

started_at_ms="$(now_ms)"
host_name="${HOSTNAME:-}"
if [[ -z "$host_name" ]]; then
  host_name="$(hostname)"
fi

capture_day="$(printf '%(%Y/%m/%d)T' -1)"
session_id="${host_name}-${tty_slug}-${started_at_ms}"
session_dir="${capture_root}/${capture_day}/${session_id}"
cast_path="${session_dir}/session.cast"
start_cwd="$(pwd -P)"
start_repo_root="$(find_repo_root "$start_cwd" || true)"
start_project_root="$(guess_project_root "$start_cwd")"
start_repo_branch="$(repo_branch "$start_repo_root")"
start_repo_commit="$(repo_commit "$start_repo_root")"
start_repo_dirty="$(repo_dirty "$start_repo_root")"

mkdir -p "$session_dir"

export SINNIX_CAPTURE_ACTIVE=1
export SINNIX_CAPTURE_CAST_FILE="$cast_path"
export SINNIX_CAPTURE_SESSION_ID="$session_id"
export SINNIX_CAPTURE_SESSION_DIR="$session_dir"
export SINNIX_CAPTURE_SESSION_FILE="${session_dir}/session.json"
export SINNIX_CAPTURE_EVENTS_FILE="${session_dir}/events.jsonl"
export SINNIX_CAPTURE_STARTED_AT_MS="$started_at_ms"
export SINNIX_CAPTURE_HOST="$host_name"
export SINNIX_CAPTURE_USER="${USER:-}"
export SINNIX_CAPTURE_TTY="$tty_path"
export SINNIX_CAPTURE_TERMINAL="kitty"
export SINNIX_CAPTURE_SHELL="$shell_bin"
export SINNIX_CAPTURE_TERM_TYPE="${TERM:-}"
export SINNIX_CAPTURE_START_CWD="$start_cwd"
export SINNIX_CAPTURE_START_REPO_ROOT="$start_repo_root"
export SINNIX_CAPTURE_START_REPO_BRANCH="$start_repo_branch"
export SINNIX_CAPTURE_START_REPO_COMMIT="$start_repo_commit"
export SINNIX_CAPTURE_START_REPO_DIRTY="$start_repo_dirty"
export SINNIX_CAPTURE_PROJECT_ROOT="$start_project_root"

{
  printf '{\n'
  printf '  "schema": %s,\n' "$(json_string "terminal-session-v1")"
  printf '  "schema_generation": %s,\n' "$(json_string "terminal-session-v1")"
  printf '  "session_id": %s,\n' "$(json_nullable_string "$session_id")"
  printf '  "cast_path": %s,\n' "$(json_nullable_string "$cast_path")"
  printf '  "events_path": %s,\n' "$(json_nullable_string "${session_dir}/events.jsonl")"
  printf '  "host": %s,\n' "$(json_nullable_string "$host_name")"
  printf '  "user": %s,\n' "$(json_nullable_string "${USER:-}")"
  printf '  "tty": %s,\n' "$(json_nullable_string "$tty_path")"
  printf '  "terminal": %s,\n' "$(json_string "kitty")"
  printf '  "shell": %s,\n' "$(json_nullable_string "$shell_bin")"
  printf '  "term_type": %s,\n' "$(json_nullable_string "${TERM:-}")"
  printf '  "start_cwd": %s,\n' "$(json_nullable_string "$start_cwd")"
  printf '  "final_cwd": null,\n'
  printf '  "project_root": %s,\n' "$(json_nullable_string "$start_project_root")"
  printf '  "final_project_root": null,\n'
  printf '  "repo_root": %s,\n' "$(json_nullable_string "$start_repo_root")"
  printf '  "final_repo_root": null,\n'
  printf '  "repo_branch": %s,\n' "$(json_nullable_string "$start_repo_branch")"
  printf '  "final_repo_branch": null,\n'
  printf '  "repo_commit": %s,\n' "$(json_nullable_string "$start_repo_commit")"
  printf '  "final_repo_commit": null,\n'
  printf '  "repo_dirty": %s,\n' "$(json_nullable_string "$start_repo_dirty")"
  printf '  "final_repo_dirty": null,\n'
  printf '  "started_at_ms": %s,\n' "$(json_nullable_int "$started_at_ms")"
  printf '  "finished_at_ms": null,\n'
  printf '  "duration_ms": null,\n'
  printf '  "active_ms": 0,\n'
  printf '  "idle_ms": 0,\n'
  printf '  "command_count": 0,\n'
  printf '  "event_count": 0,\n'
  printf '  "exit_code": null,\n'
  printf '  "exit_reason": %s,\n' "$(json_string "recorder_starting")"
  printf '  "recorder_exit_code": null,\n'
  printf '  "cleanup_escalated": false\n'
  printf '}\n'
} > "${session_dir}/session.json"

cleanup_escalated=false

update_session_file() {
  local recorder_exit_code="$1"
  local session_file="${SINNIX_CAPTURE_SESSION_FILE:-}"

  if [[ -z "$session_file" || ! -f "$session_file" ]] || ! command -v jq >/dev/null 2>&1; then
    return 0
  fi

  local tmp_file="${session_file}.tmp"
  jq \
    --argjson recorder_exit_code "$recorder_exit_code" \
    --argjson cleanup_escalated "$cleanup_escalated" \
    '.recorder_exit_code = $recorder_exit_code | .cleanup_escalated = $cleanup_escalated' \
    "$session_file" > "$tmp_file"
  mv "$tmp_file" "$session_file"
}

if asciinema rec \
  --stdin \
  --quiet \
  --return \
  --output-format asciicast-v3 \
  --capture-env SHELL,TERM,SINNIX_CAPTURE_SESSION_ID,SINNIX_CAPTURE_HOST,SINNIX_CAPTURE_USER,SINNIX_CAPTURE_TTY,SINNIX_CAPTURE_TERMINAL,SINNIX_CAPTURE_START_CWD,SINNIX_CAPTURE_START_REPO_ROOT,SINNIX_CAPTURE_START_REPO_BRANCH,SINNIX_CAPTURE_START_REPO_COMMIT,SINNIX_CAPTURE_START_REPO_DIRTY,SINNIX_CAPTURE_PROJECT_ROOT \
  --command "$shell_bin" \
  "$cast_path"
then
  status=0
else
  status=$?
fi
update_session_file "$status"
exit "$status"

#!/usr/bin/env bash
# @sinnix-package: skip
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  hdr-screenshot probe
  hdr-screenshot area [--dir DIR] [--no-notify]
  hdr-screenshot output [--dir DIR] [--no-notify]

Captures the selected area or focused output, saves it, and copies it to the
clipboard. On Hyprland HDR outputs, temporarily switches the focused output to
SDR for capture because the HDR screencopy path can produce black frames.
EOF
}

die() {
  printf 'hdr-screenshot: %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

target_dir="${HOME}/Pictures/Screenshots"
notify=1

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

subcommand="$1"
shift

while [ $# -gt 0 ]; do
  case "$1" in
    --dir)
      [ $# -ge 2 ] || die "--dir requires a value"
      target_dir="$2"
      shift 2
      ;;
    --no-notify)
      notify=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

case "$subcommand" in
  probe)
    need_cmd grimblast
    grimblast check
    ;;
  area|output)
    need_cmd date
    need_cmd grim
    need_cmd hyprctl
    need_cmd jq
    need_cmd wl-copy
    if [ "$subcommand" = "area" ]; then
      need_cmd slurp
    fi

    mkdir -p "$target_dir"
    path="${target_dir}/$(date +'%Y-%m-%d-At-%Hh%Mm%Ss').png"

    monitor_json="$(hyprctl -j monitors | jq -c 'map(select(.focused == true))[0]')"
    [ -n "$monitor_json" ] && [ "$monitor_json" != "null" ] || die "no focused monitor found"

    monitor="$(jq -r '.name' <<<"$monitor_json")"
    width="$(jq -r '.width' <<<"$monitor_json")"
    height="$(jq -r '.height' <<<"$monitor_json")"
    refresh="$(jq -r '.refreshRate | round | tostring' <<<"$monitor_json")"
    x="$(jq -r '.x' <<<"$monitor_json")"
    y="$(jq -r '.y' <<<"$monitor_json")"
    scale="$(jq -r '.scale' <<<"$monitor_json")"
    cm="$(jq -r '.colorManagementPreset // ""' <<<"$monitor_json")"
    sdr_brightness="$(jq -r '.sdrBrightness // 1.0' <<<"$monitor_json")"
    sdr_saturation="$(jq -r '.sdrSaturation // 1.0' <<<"$monitor_json")"

    restore_rule="$monitor,${width}x${height}@${refresh},${x}x${y},${scale},bitdepth,10,cm,hdr,sdrbrightness,${sdr_brightness},sdrsaturation,${sdr_saturation}"
    capture_rule="$monitor,${width}x${height}@${refresh},${x}x${y},${scale},bitdepth,8,cm,srgb"

    restore_monitor() {
      if [ "$cm" = "hdr" ]; then
        hyprctl keyword monitor "$restore_rule" >/dev/null 2>&1 || true
      fi
    }

    if [ "$cm" = "hdr" ]; then
      trap restore_monitor EXIT
      hyprctl keyword monitor "$capture_rule" >/dev/null
      sleep 0.2
    fi

    case "$subcommand" in
      area)
        geom="$(slurp)"
        [ -n "$geom" ] || die "area selection cancelled"
        grim -g "$geom" "$path"
        ;;
      output)
        grim -c -o "$monitor" "$path"
        ;;
    esac

    restore_monitor
    trap - EXIT

    [ -s "$path" ] || die "capture did not produce an image"
    wl-copy --type image/png <"$path"
    if [ "$notify" -eq 1 ]; then
      notify-send -t 2000 "Screenshot saved" "$path" || true
    fi
    printf '%s\n' "$path"
    ;;
  *)
    usage
    die "unknown subcommand: $subcommand"
    ;;
esac

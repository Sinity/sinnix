#!/usr/bin/env bash
set -euo pipefail

if (( $# == 0 )); then
  exec nix
fi

command_name=$1
shift

is_heavy_cmd=0
case "$command_name" in
  build|develop|run|shell|flake|copy|copy-closure|build-remote)
    is_heavy_cmd=1
    ;;
esac

if (( is_heavy_cmd == 0 )); then
  exec nix "$command_name" "$@"
fi

safe_jobs=""
safe_cores=""
if [[ "${NIX_SAFE_MAX_JOBS:-}" =~ ^[0-9]+$ && ${NIX_SAFE_MAX_JOBS:-0} -gt 0 ]]; then
  safe_jobs="$NIX_SAFE_MAX_JOBS"
fi
if [[ "${NIX_SAFE_CORES:-}" =~ ^[0-9]+$ && ${NIX_SAFE_CORES:-0} -ge 0 ]]; then
  safe_cores="$NIX_SAFE_CORES"
fi

if [[ -z "$safe_jobs" || -z "$safe_cores" ]]; then
  cpu_count="$(nproc)"
  if (( cpu_count >= 12 )); then
    default_jobs=2
    default_cores=8
  elif (( cpu_count >= 6 )); then
    default_jobs=2
    default_cores=2
  else
    default_jobs=1
    default_cores=1
  fi

  if [[ -z "$safe_jobs" ]]; then
    safe_jobs="$default_jobs"
  fi
  if [[ -z "$safe_cores" ]]; then
    safe_cores="$default_cores"
  fi
fi

args=()
max_jobs_set=0
cores_set=0
while (($#)); do
  case "$1" in
    --max-jobs=*)
      max_jobs_set=1
      args+=("$1")
      shift
      ;;
    --max-jobs)
      max_jobs_set=1
      if (($# < 2)); then
        args+=("$1")
        shift
        break
      fi
      args+=("$1" "$2")
      shift 2
      ;;
    --cores=*)
      cores_set=1
      args+=("$1")
      shift
      ;;
    --cores)
      cores_set=1
      if (($# < 2)); then
        args+=("$1")
        shift
        break
      fi
      args+=("$1" "$2")
      shift 2
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if (( max_jobs_set == 0 )) && [[ -n "$safe_jobs" ]]; then
  args+=(--max-jobs "$safe_jobs")
fi

if (( cores_set == 0 )) && [[ -n "$safe_cores" ]]; then
  args+=(--cores "$safe_cores")
fi

if [[ -z "${NIX_SAFE_SCOPED:-}" ]] && command -v systemd-run >/dev/null 2>&1; then
  # Keep the runtime budget self-contained here as well as in host slice
  # policy. The wrapper is used *before* a new system generation is switched,
  # so relying on slice defaults alone can silently drop the protections.
  if (( EUID == 0 )); then
    exec systemd-run \
      --scope \
      --quiet \
      --collect \
      --slice=nix-build.slice \
      -p CPUQuota=1800% \
      -p CPUWeight=20 \
      -p IOWeight=50 \
      -p MemoryHigh=18G \
      -p MemoryMax=20G \
      -p MemorySwapMax=0 \
      --nice=10 \
      -p ManagedOOMMemoryPressure=kill \
      -p ManagedOOMMemoryPressureLimit=50% \
      --setenv=NIX_SAFE_SCOPED=1 \
      nix "$command_name" "${args[@]}"
  elif [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
    exec systemd-run \
      --user \
      --scope \
      --quiet \
      --collect \
      --slice=background.slice \
      -p CPUQuota=1800% \
      -p CPUWeight=20 \
      -p IOWeight=50 \
      -p MemoryHigh=18G \
      -p MemoryMax=20G \
      -p MemorySwapMax=0 \
      --nice=10 \
      -p ManagedOOMMemoryPressure=kill \
      -p ManagedOOMMemoryPressureLimit=50% \
      --setenv=NIX_SAFE_SCOPED=1 \
      nix "$command_name" "${args[@]}"
  fi
fi

exec nix "$command_name" "${args[@]}"

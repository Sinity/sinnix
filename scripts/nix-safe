#!/usr/bin/env bash
# @sinnix-package
# description: Nix wrapper that only applies explicit job/core overrides when requested
# runtimeInputs: bash coreutils @sinnix-scope
set -euo pipefail

if (( $# == 0 )); then
  exec nix
fi

command_name=$1
shift

is_heavy_cmd=0
case "$command_name" in
  build|develop|run|shell|flake|copy|copy-closure|build-remote)
    is_heavy_cmd=1
    ;;
esac

if (( is_heavy_cmd == 0 )); then
  exec nix "$command_name" "$@"
fi

safe_jobs="${NIX_SAFE_MAX_JOBS:-2}"
safe_cores="${NIX_SAFE_CORES:-12}"
safe_eval_cache="${NIX_SAFE_EVAL_CACHE:-false}"

if [[ "$safe_jobs" != "auto" && ! "$safe_jobs" =~ ^[1-9][0-9]*$ ]]; then
  safe_jobs="auto"
fi
if [[ ! "$safe_cores" =~ ^[0-9]+$ ]]; then
  safe_cores="0"
fi

args=()
max_jobs_set=0
cores_set=0
while (($#)); do
  case "$1" in
    --max-jobs=*)
      max_jobs_set=1
      args+=("$1")
      shift
      ;;
    --max-jobs)
      max_jobs_set=1
      if (($# < 2)); then
        args+=("$1")
        shift
        break
      fi
      args+=("$1" "$2")
      shift 2
      ;;
    --cores=*)
      cores_set=1
      args+=("$1")
      shift
      ;;
    --cores)
      cores_set=1
      if (($# < 2)); then
        args+=("$1")
        shift
        break
      fi
      args+=("$1" "$2")
      shift 2
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if (( max_jobs_set == 0 )) && [[ -n "$safe_jobs" ]]; then
  args+=(--max-jobs "$safe_jobs")
fi

if (( cores_set == 0 )) && [[ -n "$safe_cores" ]]; then
  args+=(--cores "$safe_cores")
fi

if [[ "$safe_eval_cache" != "true" && "$safe_eval_cache" != "1" && "$safe_eval_cache" != "yes" ]]; then
  if [[ -n "${NIX_CONFIG:-}" ]]; then
    export NIX_CONFIG="${NIX_CONFIG}"$'\n'"eval-cache = false"
  else
    export NIX_CONFIG="eval-cache = false"
  fi
fi

if [[ -z "${NIX_SAFE_SCOPED:-}" ]] && command -v sinnix-scope >/dev/null 2>&1; then
  export NIX_SAFE_SCOPED=1
  exec sinnix-scope nix-build -- nix "$command_name" "${args[@]}"
fi

exec nix "$command_name" "${args[@]}"

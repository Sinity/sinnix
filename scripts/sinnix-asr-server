#!/usr/bin/env python3
# @sinnix-package: skip
"""Cloud-first ASR HTTP router for Sinnix audio capture.

Provider contract: POST /transcribe with a wav file, return one normalized JSON
object: text, provider, model, language, segments, words, speakers.
"""

from __future__ import annotations

import argparse
import os
import sys
import tempfile
import time
from contextlib import asynccontextmanager
from pathlib import Path
from typing import Any, AsyncIterator

import requests
import uvicorn
from fastapi import FastAPI, File, UploadFile
from fastapi.responses import JSONResponse

PROVIDER = os.environ.get("SINNIX_ASR_PROVIDER", "openai")
MODEL_NAME = os.environ.get("SINNIX_ASR_MODEL", "small")
DEVICE = os.environ.get("SINNIX_ASR_DEVICE", "auto")
COMPUTE_TYPE = os.environ.get("SINNIX_ASR_COMPUTE_TYPE", "auto")
LANGUAGE = os.environ.get("SINNIX_ASR_LANGUAGE", "en") or None
ENABLE_DIARIZATION = os.environ.get("SINNIX_ASR_DIARIZATION", "false").lower() in {"1", "true", "yes", "on"}

OPENAI_MODEL = os.environ.get("SINNIX_OPENAI_TRANSCRIBE_MODEL", "gpt-4o-mini-transcribe")
OPENAI_ENDPOINT = os.environ.get("SINNIX_OPENAI_TRANSCRIBE_ENDPOINT", "https://api.openai.com/v1/audio/transcriptions")

DEEPGRAM_MODEL = os.environ.get("SINNIX_DEEPGRAM_MODEL", "nova-3")
DEEPGRAM_ENDPOINT = os.environ.get("SINNIX_DEEPGRAM_ENDPOINT", "https://api.deepgram.com/v1/listen")

ASSEMBLYAI_MODEL = os.environ.get("SINNIX_ASSEMBLYAI_MODEL", "universal-2")
ASSEMBLYAI_BASE = os.environ.get("SINNIX_ASSEMBLYAI_BASE_URL", "https://api.assemblyai.com/v2")
ASSEMBLYAI_POLL_SECONDS = float(os.environ.get("SINNIX_ASSEMBLYAI_POLL_SECONDS", "1.0"))
ASSEMBLYAI_TIMEOUT_SECONDS = float(os.environ.get("SINNIX_ASSEMBLYAI_TIMEOUT_SECONDS", "120"))

COHERE_API_MODEL = os.environ.get("SINNIX_COHERE_TRANSCRIBE_API_MODEL", "cohere-transcribe-03-2026")
COHERE_ENDPOINT = os.environ.get("SINNIX_COHERE_TRANSCRIBE_ENDPOINT", "https://api.cohere.com/v2/audio/transcriptions")

whisper_model: Any | None = None


@asynccontextmanager
async def lifespan(_app: FastAPI) -> AsyncIterator[None]:
    load_model()
    yield


app = FastAPI(title="Sinnix ASR Router", lifespan=lifespan)


def read_secret(name: str, file_name: str) -> str | None:
    value = os.environ.get(name)
    if value:
        return value.strip()

    path = os.environ.get(file_name)
    if not path:
        return None

    try:
        return Path(path).read_text(encoding="utf-8").strip()
    except OSError:
        return None


def require_secret(name: str, file_name: str) -> str:
    secret = read_secret(name, file_name)
    if not secret:
        raise RuntimeError(f"{name} or {file_name} is required for provider {PROVIDER}")
    return secret


def load_model() -> None:
    global whisper_model
    if PROVIDER != "local" or whisper_model is not None:
        return
    from faster_whisper import WhisperModel

    whisper_model = WhisperModel(MODEL_NAME, device=DEVICE, compute_type=COMPUTE_TYPE)


def normalize_openai(payload: dict[str, Any]) -> dict[str, Any]:
    return {
        "text": (payload.get("text") or "").strip(),
        "language": LANGUAGE,
        "language_probability": None,
        "segments": payload.get("segments") or [],
        "words": payload.get("words") or [],
        "speakers": [],
        "provider": "openai",
        "model": OPENAI_MODEL,
        "raw": payload,
    }


def transcribe_openai(path: str, content_type: str) -> dict[str, Any]:
    api_key = require_secret("OPENAI_API_KEY", "OPENAI_API_KEY_FILE")
    data: dict[str, str] = {
        "model": OPENAI_MODEL,
        "response_format": "json",
    }
    if LANGUAGE:
        data["language"] = LANGUAGE
    with Path(path).open("rb") as audio:
        response = requests.post(
            OPENAI_ENDPOINT,
            headers={"Authorization": f"Bearer {api_key}"},
            data=data,
            files={"file": (Path(path).name, audio, content_type)},
            timeout=120,
        )
    response.raise_for_status()
    return normalize_openai(response.json())


def normalize_deepgram(payload: dict[str, Any]) -> dict[str, Any]:
    channel = ((payload.get("results") or {}).get("channels") or [{}])[0]
    alt = (channel.get("alternatives") or [{}])[0]
    words = alt.get("words") or []
    speakers = sorted({word.get("speaker") for word in words if word.get("speaker") is not None})
    return {
        "text": (alt.get("transcript") or "").strip(),
        "language": LANGUAGE,
        "language_probability": None,
        "segments": [],
        "words": words,
        "speakers": speakers,
        "provider": "deepgram",
        "model": DEEPGRAM_MODEL,
        "raw": payload,
    }


def transcribe_deepgram(path: str, content_type: str) -> dict[str, Any]:
    api_key = require_secret("DEEPGRAM_API_KEY", "DEEPGRAM_API_KEY_FILE")
    params: dict[str, str] = {
        "model": DEEPGRAM_MODEL,
        "smart_format": "true",
        "punctuate": "true",
    }
    if LANGUAGE:
        params["language"] = LANGUAGE
    if ENABLE_DIARIZATION:
        params["diarize"] = "true"
    with Path(path).open("rb") as audio:
        response = requests.post(
            DEEPGRAM_ENDPOINT,
            headers={"Authorization": f"Token {api_key}", "Content-Type": content_type},
            params=params,
            data=audio,
            timeout=120,
        )
    response.raise_for_status()
    return normalize_deepgram(response.json())


def normalize_assemblyai(payload: dict[str, Any]) -> dict[str, Any]:
    words = payload.get("words") or []
    utterances = payload.get("utterances") or []
    speakers = sorted({utt.get("speaker") for utt in utterances if utt.get("speaker") is not None})
    return {
        "text": (payload.get("text") or "").strip(),
        "language": payload.get("language_code") or LANGUAGE,
        "language_probability": None,
        "segments": utterances,
        "words": words,
        "speakers": speakers,
        "provider": "assemblyai",
        "model": ASSEMBLYAI_MODEL,
        "raw": payload,
    }


def transcribe_assemblyai(path: str, content_type: str) -> dict[str, Any]:
    api_key = require_secret("ASSEMBLYAI_API_KEY", "ASSEMBLYAI_API_KEY_FILE")
    headers = {"authorization": api_key}
    with Path(path).open("rb") as audio:
        upload = requests.post(
            f"{ASSEMBLYAI_BASE.rstrip('/')}/upload",
            headers=headers,
            data=audio,
            timeout=120,
        )
    upload.raise_for_status()
    audio_url = upload.json()["upload_url"]
    body: dict[str, Any] = {
        "audio_url": audio_url,
        "speech_model": ASSEMBLYAI_MODEL,
        "speaker_labels": ENABLE_DIARIZATION,
    }
    if LANGUAGE:
        body["language_code"] = LANGUAGE
    submit = requests.post(
        f"{ASSEMBLYAI_BASE.rstrip('/')}/transcript",
        headers=headers,
        json=body,
        timeout=30,
    )
    submit.raise_for_status()
    transcript_id = submit.json()["id"]
    deadline = time.monotonic() + ASSEMBLYAI_TIMEOUT_SECONDS
    while time.monotonic() < deadline:
        status = requests.get(
            f"{ASSEMBLYAI_BASE.rstrip('/')}/transcript/{transcript_id}",
            headers=headers,
            timeout=30,
        )
        status.raise_for_status()
        payload = status.json()
        if payload.get("status") == "completed":
            return normalize_assemblyai(payload)
        if payload.get("status") == "error":
            raise RuntimeError(payload.get("error") or "AssemblyAI transcription failed")
        time.sleep(ASSEMBLYAI_POLL_SECONDS)
    raise RuntimeError(f"AssemblyAI timed out after {ASSEMBLYAI_TIMEOUT_SECONDS:.0f}s")


def transcribe_cohere_api(path: str, content_type: str) -> dict[str, Any]:
    api_key = require_secret("COHERE_API_KEY", "COHERE_API_KEY_FILE")
    data = {"model": COHERE_API_MODEL}
    if LANGUAGE:
        data["language"] = LANGUAGE
    with Path(path).open("rb") as audio:
        response = requests.post(
            COHERE_ENDPOINT,
            headers={"Authorization": f"Bearer {api_key}"},
            data=data,
            files={"file": (Path(path).name, audio, content_type)},
            timeout=120,
        )
    response.raise_for_status()
    payload = response.json()
    return {
        "text": (payload.get("text") or "").strip(),
        "language": LANGUAGE,
        "language_probability": None,
        "segments": [],
        "words": [],
        "speakers": [],
        "provider": "cohere-api",
        "model": COHERE_API_MODEL,
        "raw": payload,
    }


def transcribe_local(path: str) -> dict[str, Any]:
    if whisper_model is None:
        raise RuntimeError("local model not loaded")
    segments_iter, info = whisper_model.transcribe(
        path,
        beam_size=5,
        vad_filter=True,
        vad_parameters={"min_silence_duration_ms": 600},
        language=LANGUAGE,
    )
    segments = [
        {"start": segment.start, "end": segment.end, "text": segment.text}
        for segment in segments_iter
    ]
    text = " ".join(segment["text"].strip() for segment in segments).strip()
    return {
        "text": text,
        "language": info.language,
        "language_probability": info.language_probability,
        "segments": segments,
        "words": [],
        "speakers": [],
        "provider": "local",
        "model": MODEL_NAME,
        "raw": None,
    }


@app.get("/health")
def health() -> dict[str, Any]:
    return {
        "status": "ok",
        "provider": PROVIDER,
        "model": {
            "local": MODEL_NAME,
            "openai": OPENAI_MODEL,
            "deepgram": DEEPGRAM_MODEL,
            "assemblyai": ASSEMBLYAI_MODEL,
            "cohere-api": COHERE_API_MODEL,
        }.get(PROVIDER, MODEL_NAME),
        "language": LANGUAGE,
        "diarization": ENABLE_DIARIZATION,
    }


@app.get("/providers")
def providers() -> dict[str, Any]:
    return {
        "default": PROVIDER,
        "available": ["openai", "deepgram", "assemblyai", "cohere-api", "local"],
    }


@app.post("/transcribe")
async def transcribe(file: UploadFile = File(...)) -> JSONResponse:
    suffix = Path(file.filename or "audio.wav").suffix or ".wav"
    with tempfile.NamedTemporaryFile(suffix=suffix, delete=False) as tmp:
        tmp.write(await file.read())
        tmp_path = tmp.name

    content_type = file.content_type or "audio/wav"
    try:
        if PROVIDER == "openai":
            payload = transcribe_openai(tmp_path, content_type)
        elif PROVIDER == "deepgram":
            payload = transcribe_deepgram(tmp_path, content_type)
        elif PROVIDER == "assemblyai":
            payload = transcribe_assemblyai(tmp_path, content_type)
        elif PROVIDER == "cohere-api":
            payload = transcribe_cohere_api(tmp_path, content_type)
        elif PROVIDER == "local":
            payload = transcribe_local(tmp_path)
        else:
            return JSONResponse({"error": f"unsupported provider: {PROVIDER}"}, status_code=400)
        return JSONResponse(payload)
    except requests.HTTPError as exc:
        body = exc.response.text[:1000] if exc.response is not None else str(exc)
        return JSONResponse({"error": f"{PROVIDER} transcription failed: {body}"}, status_code=502)
    except Exception as exc:  # noqa: BLE001 - normalize daemon-facing failures
        return JSONResponse({"error": f"{PROVIDER} transcription failed: {exc}"}, status_code=502)
    finally:
        Path(tmp_path).unlink(missing_ok=True)


if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=7778)
    args = parser.parse_args()
    uvicorn.run(app, host=args.host, port=args.port)

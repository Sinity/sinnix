#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
launch-trigger-capture - persistent launch-boundary diagnostics for suspected reset triggers

Usage:
  launch-trigger-capture MODE [options] -- CMD [ARG...]

Modes:
  hyprland  capture the tty -> Hyprland launch boundary
  chrome    capture a Google Chrome launch boundary
  command   capture an arbitrary command launch boundary

Options:
  --label NAME      append a short label to the capture directory
  --root DIR        override capture root (default: $SINNIX_TRIGGER_CAPTURE_ROOT or /realm/data/captures/launch-trigger)
  --strace          run the target under strace -ff -ttt -yy -s 256
  --wayland-debug   export WAYLAND_DEBUG=1 for the target process
  -h, --help        show this help

Examples:
  launch-trigger-capture hyprland -- uwsm start hyprland-uwsm.desktop
  launch-trigger-capture chrome -- google-chrome-stable https://example.com
  launch-trigger-capture command -- gpu-transition-lab dmabuf
EOF
}

sanitize_fragment() {
  printf '%s' "$1" | tr -cs '[:alnum:]._+-' '-' | sed 's/^-//; s/-$//'
}

if [[ $# -eq 0 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

MODE="$1"
shift

case "$MODE" in
  hyprland|chrome|command) ;;
  *)
    echo "Unknown mode: $MODE" >&2
    usage >&2
    exit 2
    ;;
esac

LABEL=""
ROOT_DIR="${SINNIX_TRIGGER_CAPTURE_ROOT:-/realm/data/captures/launch-trigger}"
ENABLE_STRACE=0
ENABLE_WAYLAND_DEBUG=0
PROCESS_WATCH_INTERVAL_SEC="0.05"
GPU_POLL_INTERVAL_SEC="0.1"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --label)
      [[ $# -ge 2 ]] || { echo "--label requires a value" >&2; exit 2; }
      LABEL="$2"
      shift 2
      ;;
    --root)
      [[ $# -ge 2 ]] || { echo "--root requires a value" >&2; exit 2; }
      ROOT_DIR="$2"
      shift 2
      ;;
    --strace)
      ENABLE_STRACE=1
      shift
      ;;
    --wayland-debug)
      ENABLE_WAYLAND_DEBUG=1
      shift
      ;;
    --)
      shift
      break
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  echo "launch-trigger-capture requires a target command after --" >&2
  exit 2
fi

if [[ "$MODE" == "chrome" || "$MODE" == "hyprland" ]]; then
  ENABLE_STRACE=1
fi

mkdir -p "$ROOT_DIR"

TS="$(date +%Y%m%d-%H%M%S)"
RUN_NAME="${TS}-${MODE}"
if [[ -n "$LABEL" ]]; then
  RUN_NAME="${RUN_NAME}-$(sanitize_fragment "$LABEL")"
fi
RUN_DIR="${ROOT_DIR}/${RUN_NAME}"
mkdir -p "$RUN_DIR"
ln -sfn "$RUN_DIR" "${ROOT_DIR}/latest"
ln -sfn "$RUN_DIR" "${ROOT_DIR}/latest-${MODE}"

RUN_META="${RUN_DIR}/meta.env"
STATUS_FILE="${RUN_DIR}/status.env"
RUN_LOG="${RUN_DIR}/run.log"
CHILD_PID_FILE="${RUN_DIR}/child.pid"
MONITOR_PIDS=()

{
  printf 'MODE=%q\n' "$MODE"
  printf 'RUN_DIR=%q\n' "$RUN_DIR"
  printf 'START_LOCAL=%q\n' "$(date +'%Y-%m-%d %H:%M:%S')"
  printf 'START_CSV=%q\n' "$(date +'%Y-%m-%dT%H:%M:%S')"
  printf 'HOSTNAME=%q\n' "$(hostname)"
  printf 'KERNEL=%q\n' "$(uname -r)"
  printf 'BOOT_ID=%q\n' "$(cat /proc/sys/kernel/random/boot_id)"
  printf 'ENABLE_STRACE=%q\n' "$ENABLE_STRACE"
  printf 'ENABLE_WAYLAND_DEBUG=%q\n' "$ENABLE_WAYLAND_DEBUG"
  printf 'PROCESS_WATCH_INTERVAL_SEC=%q\n' "$PROCESS_WATCH_INTERVAL_SEC"
  printf 'GPU_POLL_INTERVAL_SEC=%q\n' "$GPU_POLL_INTERVAL_SEC"
} > "$RUN_META"

printf '%s\0' "$@" > "${RUN_DIR}/argv.null"
printf '%q ' "$@" > "${RUN_DIR}/argv.shell"
printf '\n' >> "${RUN_DIR}/argv.shell"
env | sort > "${RUN_DIR}/environment.txt"

record_stage() {
  local stage="$1"
  local now_local now_csv
  now_local="$(date +'%Y-%m-%d %H:%M:%S.%3N')"
  now_csv="$(date +'%Y-%m-%dT%H:%M:%S.%3N')"
  {
    printf 'LAST_STAGE=%q\n' "$stage"
    printf 'LAST_STAGE_LOCAL=%q\n' "$now_local"
    printf 'LAST_STAGE_CSV=%q\n' "$now_csv"
  } > "$STATUS_FILE"
  printf '%s stage=%s\n' "$now_local" "$stage" >> "$RUN_LOG"
}

find_nvidia_bus_id() {
  local device
  while read -r device; do
    [[ -n "$device" ]] || continue
    if lspci -s "$device" -nn | grep -qi 'NVIDIA'; then
      printf '%s\n' "$device"
      return 0
    fi
  done < <(lspci -D -d ::0300 | awk '{print $1}')
  return 1
}

capture_sysfs_value() {
  local src="$1"
  local dst="$2"
  if [[ -r "$src" ]]; then
    cat "$src" > "$dst" 2>/dev/null || true
  fi
}

collect_snapshot() {
  local suffix="$1"
  local snapshot_dir="${RUN_DIR}/${suffix}"
  local nvidia_bus

  mkdir -p "$snapshot_dir"
  date --iso-8601=seconds > "${snapshot_dir}/timestamp.txt"
  uname -a > "${snapshot_dir}/uname.txt"
  uptime > "${snapshot_dir}/uptime.txt"
  free -h > "${snapshot_dir}/memory.txt"
  lsmod > "${snapshot_dir}/lsmod.txt"
  sensors > "${snapshot_dir}/sensors.txt" 2>&1 || true
  nvidia-smi -q > "${snapshot_dir}/nvidia-smi-q.txt" 2>&1 || true
  nvidia-smi --query-gpu=temperature.gpu,power.draw,power.limit,utilization.gpu,utilization.memory,clocks.current.graphics,clocks.current.memory,pstate,pcie.link.gen.gpucurrent,pcie.link.width.current --format=csv > "${snapshot_dir}/nvidia-smi-summary.csv" 2>&1 || true
  journalctl -k -b -n 400 > "${snapshot_dir}/kernel-tail.txt" 2>&1 || true
  journalctl -b -n 400 > "${snapshot_dir}/journal-tail.txt" 2>&1 || true
  ps -eo pid,ppid,comm,%cpu,%mem,etimes,args --sort=pid > "${snapshot_dir}/ps.txt"

  if nvidia_bus="$(find_nvidia_bus_id 2>/dev/null)"; then
    lspci -s "$nvidia_bus" -nnk > "${snapshot_dir}/lspci-nnk.txt" 2>&1 || true
    lspci -s "$nvidia_bus" -vv > "${snapshot_dir}/lspci-vv.txt" 2>&1 || true
    local sysfs_base="/sys/bus/pci/devices/${nvidia_bus}"
    capture_sysfs_value "${sysfs_base}/current_link_speed" "${snapshot_dir}/pcie-current-link-speed.txt"
    capture_sysfs_value "${sysfs_base}/current_link_width" "${snapshot_dir}/pcie-current-link-width.txt"
    capture_sysfs_value "${sysfs_base}/max_link_speed" "${snapshot_dir}/pcie-max-link-speed.txt"
    capture_sysfs_value "${sysfs_base}/max_link_width" "${snapshot_dir}/pcie-max-link-width.txt"
    capture_sysfs_value "${sysfs_base}/power/runtime_status" "${snapshot_dir}/runtime-status.txt"
    capture_sysfs_value "${sysfs_base}/power/control" "${snapshot_dir}/runtime-control.txt"
  fi
}

start_monitors() {
  : > "${RUN_DIR}/journal-kernel-live.log"
  : > "${RUN_DIR}/journal-targeted.log"
  : > "${RUN_DIR}/process-watch.log"
  : > "${RUN_DIR}/nvidia-live.csv"
  : > "${RUN_DIR}/udev-monitor.log"

  stdbuf -oL -eL journalctl -kf -o short-iso > "${RUN_DIR}/journal-kernel-live.log" 2>&1 &
  MONITOR_PIDS+=("$!")

  stdbuf -oL -eL journalctl -f -o short-iso \
    -g 'Hyprland|uwsm|google-chrome|chrome|chromium|Xwayland|waybar|xdg-desktop-portal-hyprland|nvidia|NVRM|Xid|AER|pcie|drm|gpu|r8169|igc|resolved|NetworkManager|usb|hid|keyboard|solaar|acpid|xhci' \
    > "${RUN_DIR}/journal-targeted.log" 2>&1 &
  MONITOR_PIDS+=("$!")

  RUN_DIR="$RUN_DIR" PROCESS_WATCH_INTERVAL_SEC="$PROCESS_WATCH_INTERVAL_SEC" stdbuf -oL -eL bash -c '
    while true; do
      ts="$(date +'"'"'%Y-%m-%d %H:%M:%S.%3N'"'"')"
      printf "# %s\n" "$ts"
      if [[ -r "$RUN_DIR/child.pid" ]]; then
        child_pid="$(cat "$RUN_DIR/child.pid" 2>/dev/null || true)"
        if [[ -n "$child_pid" ]]; then
          printf "child_pid=%s\n" "$child_pid"
          ps -p "$child_pid" -o pid,ppid,pgid,sid,stat,etimes,%cpu,%mem,comm,args --no-headers || true
        fi
      fi
      ps -eo pid=,ppid=,pgid=,sid=,stat=,etimes=,%cpu=,%mem=,comm=,args= --sort=pid | \
        awk '"'"'$9 ~ /^(Hyprland|uwsm|google-chrome|google-chrome-stable|chromium|Xwayland|waybar|xdg-desktop-portal-hyprland|gpu-transition-lab|dmabuf-import-lab|wayland-egl-swap-lab|chrome-gpu-child-lab|drm-atomic-lab)$/ { print }'"'"' || true
      printf "\n"
      sleep "$PROCESS_WATCH_INTERVAL_SEC"
    done
  ' > "${RUN_DIR}/process-watch.log" 2>&1 &
  MONITOR_PIDS+=("$!")

  if command -v nvidia-smi >/dev/null 2>&1; then
    GPU_POLL_INTERVAL_SEC="$GPU_POLL_INTERVAL_SEC" stdbuf -oL -eL bash -c '
      printf "timestamp,temperature.gpu,power.draw,power.limit,utilization.gpu,utilization.memory,clocks.current.graphics,clocks.current.memory,pstate,pcie.link.gen.gpucurrent,pcie.link.width.current\n"
      while true; do
        printf "%s," "$(date +'"'"'%Y-%m-%dT%H:%M:%S.%3N'"'"')"
        nvidia-smi --query-gpu=temperature.gpu,power.draw,power.limit,utilization.gpu,utilization.memory,clocks.current.graphics,clocks.current.memory,pstate,pcie.link.gen.gpucurrent,pcie.link.width.current --format=csv,noheader,nounits 2>/dev/null || echo "0,0,0,0,0,0,0,P0,0,0"
        sleep "$GPU_POLL_INTERVAL_SEC"
      done
    ' > "${RUN_DIR}/nvidia-live.csv" 2>&1 &
    MONITOR_PIDS+=("$!")
  fi

  if command -v udevadm >/dev/null 2>&1; then
    stdbuf -oL -eL udevadm monitor --kernel --udev --property > "${RUN_DIR}/udev-monitor.log" 2>&1 &
    MONITOR_PIDS+=("$!")
  fi
}

stop_monitors() {
  local pid
  for pid in "${MONITOR_PIDS[@]:-}"; do
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
    fi
  done
}

cleanup() {
  local exit_code="$1"
  set +e
  stop_monitors
  collect_snapshot after
  {
    printf 'END_LOCAL=%q\n' "$(date +'%Y-%m-%d %H:%M:%S')"
    printf 'END_CSV=%q\n' "$(date +'%Y-%m-%dT%H:%M:%S')"
    printf 'EXIT_STATUS=%q\n' "$exit_code"
  } >> "$RUN_META"
}

trap 'cleanup $?' EXIT

record_stage monitor_starting
start_monitors
record_stage monitor_started
collect_snapshot before
record_stage pre_exec

CHILD_STDOUT="${RUN_DIR}/child.stdout.log"
CHILD_STDERR="${RUN_DIR}/child.stderr.log"
TARGET_CMD=("$@")

TARGET_ENV=()
if [[ $ENABLE_WAYLAND_DEBUG -eq 1 ]]; then
  TARGET_ENV+=(WAYLAND_DEBUG=1)
fi

if [[ "$MODE" == "chrome" ]]; then
  TARGET_ENV+=(
    CHROME_LOG_FILE="${RUN_DIR}/chrome.log"
  )
  TARGET_CMD=(
    "${TARGET_CMD[0]}"
    --enable-logging=stderr
    --log-level=0
    --v=1
    "${TARGET_CMD[@]:1}"
  )
fi

if [[ $ENABLE_STRACE -eq 1 ]]; then
  mkdir -p "${RUN_DIR}/strace"
fi

{
  printf 'launch-trigger-capture: mode=%s run_dir=%s\n' "$MODE" "$RUN_DIR"
  printf 'launch-trigger-capture: exec'
  if [[ $ENABLE_STRACE -eq 1 ]]; then
    printf ' %q' strace -ff -ttt -yy -s 256 -o "${RUN_DIR}/strace/trace"
  fi
  printf ' %q' env "${TARGET_ENV[@]}" "${TARGET_CMD[@]}"
  printf '\n'
} >> "$RUN_LOG"

record_stage child_launching
if [[ $ENABLE_STRACE -eq 1 ]]; then
  strace -ff -ttt -yy -s 256 -o "${RUN_DIR}/strace/trace" \
    env "${TARGET_ENV[@]}" "${TARGET_CMD[@]}" >"$CHILD_STDOUT" 2>"$CHILD_STDERR" &
else
  env "${TARGET_ENV[@]}" "${TARGET_CMD[@]}" >"$CHILD_STDOUT" 2>"$CHILD_STDERR" &
fi
child_pid="$!"
printf '%s\n' "$child_pid" > "$CHILD_PID_FILE"
{
  printf 'CHILD_PID=%q\n' "$child_pid"
  printf 'CHILD_PID_RECORDED_LOCAL=%q\n' "$(date +'%Y-%m-%d %H:%M:%S.%3N')"
  printf 'CHILD_PID_RECORDED_CSV=%q\n' "$(date +'%Y-%m-%dT%H:%M:%S.%3N')"
} >> "$RUN_META"
record_stage "child_started:${child_pid}"
if wait "$child_pid"; then
  exit_code=0
else
  exit_code="$?"
fi
record_stage "child_exit:${exit_code}"
exit "$exit_code"

#!/usr/bin/env bash
# Cross-project observability entrypoint for the workstation.

set -euo pipefail

SINEX_ROOT="${SINEX_ROOT:-/realm/project/sinex}"
POLYLOGUE_ROOT="${POLYLOGUE_ROOT:-/realm/project/polylogue}"

section() {
  printf '\n== %s ==\n' "$1"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

sqlite_read() {
  local db="$1"
  local sql="$2"
  sqlite3 -readonly -header -column "$db" "$sql" 2>/dev/null || true
}

first_existing() {
  local path
  for path in "$@"; do
    if [ -e "$path" ]; then
      printf '%s\n' "$path"
      return 0
    fi
  done
  return 1
}

table_exists() {
  local db="$1"
  local table="$2"
  [ -e "$db" ] || return 1
  [ "$(sqlite3 -readonly "$db" "select count(*) from sqlite_master where type='table' and name='$table';" 2>/dev/null || echo 0)" = "1" ]
}

polylogue_db() {
  local db
  for db in \
    "${POLYLOGUE_DB_PATH:-}" \
    "$HOME/.local/share/polylogue/polylogue.db" \
    "$HOME/.local/share/polylogue/archive.db" \
    "$HOME/.local/share/polylogue/polylogue.sqlite" \
    "$POLYLOGUE_ROOT/.local/browser-capture/xdg-data/polylogue/polylogue.db"
  do
    [ -n "$db" ] || continue
    if table_exists "$db" runs; then
      printf '%s\n' "$db"
      return 0
    fi
  done
  return 1
}

pressure_summary() {
  section "live pressure"
  date --iso-8601=seconds
  printf 'cpu    '; cat /proc/pressure/cpu
  printf 'memory '; cat /proc/pressure/memory
  printf 'io     '; cat /proc/pressure/io
  free -h
}

blocked_tasks() {
  section "blocked tasks"
  ps -eo stat,pid,ppid,etime,pcpu,pmem,rss,wchan:24,comm,args \
    | awk 'NR == 1 || $1 ~ /D/' \
    | sed -n '1,40p'
}

systemd_units() {
  section "managed workload units"
  local units=(
    below.service
    sinnix-pressure-watchdog.service
    sinex-runtime.target
    sinex-runtime.timer
    sinex-ingestd.service
    nats.service
    postgresql.service
    btrbk.service
    borgbackup-job-realm.service
    borgbackup-job-persist.service
  )
  local unit
  for unit in "${units[@]}"; do
    if systemctl list-unit-files "$unit" >/dev/null 2>&1; then
      systemctl show "$unit" \
        -p Id -p ActiveState -p SubState -p MainPID -p Slice \
        -p MemoryCurrent -p MemoryHigh -p MemoryMax -p IOReadBandwidthMax \
        -p IOWriteBandwidthMax \
        | awk -v unit="$unit" '
          BEGIN { FS="=" }
          $1 == "ActiveState" { active=$2 }
          $1 == "SubState" { unit_sub=$2 }
          $1 == "MainPID" { pid=$2 }
          $1 == "Slice" { slice=$2 }
          $1 == "MemoryCurrent" { mem=$2 }
          $1 == "MemoryHigh" { high=$2 }
          $1 == "MemoryMax" { max=$2 }
          $1 == "IOReadBandwidthMax" { read=$2 }
          $1 == "IOWriteBandwidthMax" { write=$2 }
          END {
            printf "%-34s active=%s/%s pid=%s slice=%s mem=%s high=%s max=%s readcap=%s writecap=%s\n",
              unit, active, unit_sub, pid, slice, mem, high, max, read, write
          }'
    fi
  done

  if systemctl --user list-unit-files polylogue-run.service >/dev/null 2>&1; then
    systemctl --user show polylogue-run.service \
      -p Id -p ActiveState -p SubState -p MainPID -p Slice \
      -p MemoryCurrent -p MemoryHigh -p MemoryMax -p IOReadBandwidthMax \
      -p IOWriteBandwidthMax \
      | awk '
        BEGIN { FS="=" }
        $1 == "ActiveState" { active=$2 }
        $1 == "SubState" { unit_sub=$2 }
        $1 == "MainPID" { pid=$2 }
        $1 == "Slice" { slice=$2 }
        $1 == "MemoryCurrent" { mem=$2 }
        $1 == "MemoryHigh" { high=$2 }
        $1 == "MemoryMax" { max=$2 }
        $1 == "IOReadBandwidthMax" { read=$2 }
        $1 == "IOWriteBandwidthMax" { write=$2 }
        END {
          printf "%-34s active=%s/%s pid=%s slice=%s mem=%s high=%s max=%s readcap=%s writecap=%s\n",
            "polylogue-run.service", active, unit_sub, pid, slice, mem, high, max, read, write
        }'
  fi
}

sentinel_state() {
  section "sentinel policy"
  if systemctl list-unit-files sinnix-sentinel.service >/dev/null 2>&1; then
    systemctl show sinnix-sentinel.service \
      -p ActiveState -p SubState -p Result -p TriggeredBy -p Environment \
      | awk '
        BEGIN { FS="=" }
        $1 == "ActiveState" { active=$2 }
        $1 == "SubState" { sub_state=$2 }
        $1 == "Result" { result=$2 }
        $1 == "TriggeredBy" { triggered=$2 }
        $1 == "Environment" { env=$0; sub(/^Environment=/, "", env) }
        END {
          printf "sinnix-sentinel.service active=%s/%s result=%s triggered_by=%s\n", active, sub_state, result, triggered
          if (env != "") print "environment=" env
        }'
  fi

  if [ -r /etc/sinnix/health-policy.json ]; then
    echo "health policy services:"
    jq -r '.services[] | "  \(.name) unit=\(.unit) type=\(.type) restartable=\(.restartable)"' \
      /etc/sinnix/health-policy.json 2>/dev/null || true
  fi

  if [ -r /run/sinnix/health.json ]; then
    echo "latest health:"
    jq -r '"  timestamp=\(.timestamp) overall=\(.overall) ok=\(.summary.ok) warn=\(.summary.warn) fail=\(.summary.fail)"' \
      /run/sinnix/health.json 2>/dev/null || true
  fi

  local event_log="${SINNIX_EVENT_LOG:-/var/log/sinnix-sentinel/events.jsonl}"
  if [ -r "$event_log" ]; then
    echo "recent sentinel events:"
    tail -n 20 "$event_log" \
      | jq -r 'select(.source == "sinnix-sentinel") | "  \(.timestamp) \(.event) severity=\(.severity // "normal")\(.name? // "" | if . == "" then "" else " name=" + . end)\(.unit? // "" | if . == "" then "" else " unit=" + . end)"' \
      2>/dev/null || true
  elif [ -e "$event_log" ]; then
    echo "recent sentinel events: unreadable ($event_log)"
  else
    echo "recent sentinel events: none yet"
  fi
}

slice_state() {
  section "resource slices"
  local specs=(
    "user build.slice"
    "user nix-build.slice"
    "user background.slice"
    "system nix-build.slice"
    "system background.slice"
  )
  local spec scope slice
  for spec in "${specs[@]}"; do
    scope="${spec%% *}"
    slice="${spec#* }"
    if [ "$scope" = user ]; then
      systemctl --user show "$slice" -p ActiveState -p MemoryCurrent -p MemoryHigh -p MemoryMax -p IOReadBandwidthMax -p IOWriteBandwidthMax 2>/dev/null \
        | awk -v slice="user/$slice" '
          BEGIN { FS="=" }
          $1 == "ActiveState" { active=$2 }
          $1 == "MemoryCurrent" { current=$2 }
          $1 == "MemoryHigh" { high=$2 }
          $1 == "MemoryMax" { max=$2 }
          $1 == "IOReadBandwidthMax" { read=$2 }
          $1 == "IOWriteBandwidthMax" { write=$2 }
          END { printf "%-24s active=%s current=%s high=%s max=%s readcap=%s writecap=%s\n", slice, active, current, high, max, read, write }'
    else
      systemctl show "$slice" -p ActiveState -p MemoryCurrent -p MemoryHigh -p MemoryMax -p IOReadBandwidthMax -p IOWriteBandwidthMax 2>/dev/null \
        | awk -v slice="system/$slice" '
          BEGIN { FS="=" }
          $1 == "ActiveState" { active=$2 }
          $1 == "MemoryCurrent" { current=$2 }
          $1 == "MemoryHigh" { high=$2 }
          $1 == "MemoryMax" { max=$2 }
          $1 == "IOReadBandwidthMax" { read=$2 }
          $1 == "IOWriteBandwidthMax" { write=$2 }
          END { printf "%-24s active=%s current=%s high=%s max=%s readcap=%s writecap=%s\n", slice, active, current, high, max, read, write }'
    fi
  done
}

active_heavy_processes() {
  section "heavy process snapshot"
  ps -eo pid,stat,pcpu,pmem,rss,comm,args --sort=-pcpu \
    | awk 'NR == 1 || $6 ~ /^(cargo|cargo-nextest|rustc|pytest|nix|nix-daemon|borg|btrbk|nats-server|postgres|polylogue|xtask)$/ || $7 ~ /(polylogue|xtask|cargo nextest|pytest|borgbackup)/' \
    | sed -n '1,40p'
}

sinex_xtask_history() {
  section "sinex xtask history"
  local db
  db="$(first_existing \
    "$SINEX_ROOT/.sinex/state/xtask-history.db" \
    "$HOME/.sinex/history.db" \
    "${XTASK_HISTORY_DB:-}" \
    2>/dev/null || true)"
  if [ -z "$db" ]; then
    echo "no xtask history DB found"
    return
  fi
  printf 'db=%s\n' "$db"
  sqlite_read "$db" "
    select
      id,
      command,
      coalesce(subcommand, '') as subcommand,
      status,
      started_at,
      round(duration_secs, 1) as secs,
      round(process_memory_usage_max_mb, 1) as rss_mb,
      round(shared_background_slice_memory_usage_max_mb, 1) as bg_mb,
      round(shared_nix_build_slice_memory_usage_max_mb, 1) as nix_mb
    from invocations
    order by started_at desc
    limit 10;"
}

polylogue_runs() {
  section "polylogue runs"
  local db
  db="$(polylogue_db || true)"
  if [ -n "$db" ]; then
    printf 'db=%s\n' "$db"
    sqlite_read "$db" "
      select
        case
          when timestamp glob '[0-9]*' then datetime(cast(timestamp as integer), 'unixepoch')
          else timestamp
        end as timestamp,
        run_id,
        round(duration_ms / 1000.0, 1) as secs,
        substr(coalesce(counts_json, ''), 1, 96) as counts
      from runs
      order by timestamp desc
      limit 10;"
    return
  fi

  local runs_dir
  runs_dir="$(first_existing \
    "$HOME/.local/share/polylogue/runs" \
    "$POLYLOGUE_ROOT/runs" \
    "$POLYLOGUE_ROOT/archive/runs" \
    2>/dev/null || true)"
  if [ -z "$runs_dir" ]; then
    echo "no Polylogue runs DB or runs directory found"
    return
  fi
  printf 'runs_dir=%s\n' "$runs_dir"
  find "$runs_dir" -maxdepth 1 -type f -name 'run-*.json' -printf '%T+\t%p\n' \
    | sort -r \
    | sed -n '1,10p'
}

below_hint() {
  section "below hint"
  if have below; then
    echo "interactive replay: below replay -t '${SINNIX_OBSERVE_BEGIN:-10 min ago}'"
  else
    echo "below not on PATH"
  fi
}

below_recent_history() {
  section "below recent history"
  if ! have below; then
    echo "below not on PATH"
    return
  fi

  local begin duration cgroup_rows process_rows
  begin="${SINNIX_OBSERVE_BEGIN:-10 min ago}"
  duration="${SINNIX_OBSERVE_DURATION:-10 min}"
  printf 'window: begin=%s duration=%s\n' "$begin" "$duration"

  cgroup_rows="$(
    below dump cgroup \
      -b "$begin" \
      --duration "$duration" \
      -f datetime name full_path cpu.usage_pct mem.total io.rwbytes_per_sec pressure.io_full_pct pressure.memory_full_pct \
      -O tsv \
      --raw \
      --disable-title 2>/dev/null \
      | awk -F '\t' '
          NF >= 8 && $3 != "" {
            path = $3
            io = $6 + 0
            mem = $5 + 0
            cpu = $4 + 0
            io_full = $7 + 0
            mem_full = $8 + 0
            samples[path]++
            if (io > max_io[path]) max_io[path] = io
            if (mem > max_mem[path]) max_mem[path] = mem
            if (cpu > max_cpu[path]) max_cpu[path] = cpu
            if (io_full > max_io_full[path]) max_io_full[path] = io_full
            if (mem_full > max_mem_full[path]) max_mem_full[path] = mem_full
          }
          END {
            for (path in samples) {
              printf "%.0f\t%.2f\t%.2f\t%.0f\t%.1f\t%d\t%s\n",
                max_io[path], max_io_full[path], max_mem_full[path],
                max_mem[path], max_cpu[path], samples[path], path
            }
          }' \
      | LC_ALL=C sort -nr -k1,1 \
      | sed -n '1,12p'
  )"

  echo "cgroup peaks:"
  if [ -n "$cgroup_rows" ]; then
    printf '  %-12s %-10s %-10s %-10s %-8s %s\n' \
      "rw_Bps" "io_full%" "mem_full%" "rss_MiB" "cpu%" "cgroup"
    printf '%s\n' "$cgroup_rows" \
      | awk -F '\t' '{
          printf "  %-12.0f %-10.2f %-10.2f %-10.1f %-8.1f %s\n",
            $1, $2, $3, $4 / 1048576, $5, $7
        }'
  else
    echo "  no below cgroup samples for window"
  fi

  process_rows="$(
    below dump process \
      -b "$begin" \
      --duration "$duration" \
      -f datetime pid comm state cgroup io.rwbytes_per_sec mem.rss_bytes cpu.usage_pct cmdline \
      -O tsv \
      --raw \
      --disable-title 2>/dev/null \
      | awk -F '\t' '
          NF >= 9 && $2 ~ /^[0-9]+$/ {
            pid = $2
            io = $6 + 0
            rss = $7 + 0
            cpu = $8 + 0
            samples[pid]++
            if (io > max_io[pid]) {
              max_io[pid] = io
              comm[pid] = $3
              state[pid] = $4
              cgroup[pid] = $5
              cmdline[pid] = substr($9, 1, 120)
            }
            if (rss > max_rss[pid]) max_rss[pid] = rss
            if (cpu > max_cpu[pid]) max_cpu[pid] = cpu
          }
          END {
            for (pid in samples) {
              printf "%.0f\t%.0f\t%.1f\t%d\t%s\t%s\t%s\t%s\n",
                max_io[pid], max_rss[pid], max_cpu[pid], pid,
                comm[pid], state[pid], cgroup[pid], cmdline[pid]
            }
          }' \
      | LC_ALL=C sort -nr -k1,1 \
      | sed -n '1,12p'
  )"

  echo "process I/O peaks:"
  if [ -n "$process_rows" ]; then
    printf '  %-12s %-9s %-7s %-8s %-18s %s\n' \
      "rw_Bps" "rss_MiB" "cpu%" "pid" "comm" "cmdline"
    printf '%s\n' "$process_rows" \
      | awk -F '\t' '{
          printf "  %-12.0f %-9.1f %-7.1f %-8d %-18s %s\n",
            $1, $2 / 1048576, $3, $4, $5, $8
        }'
  else
    echo "  no below process samples for window"
  fi
}

pressure_summary
blocked_tasks
systemd_units
sentinel_state
slice_state
active_heavy_processes
sinex_xtask_history
polylogue_runs
below_recent_history
below_hint

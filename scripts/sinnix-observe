DEFAULT_BEGIN = os.environ.get("SINNIX_OBSERVE_BEGIN", "10 min ago")
DEFAULT_DURATION = os.environ.get("SINNIX_OBSERVE_DURATION", "10 min")
DEFAULT_LIMIT = int(os.environ.get("SINNIX_OBSERVE_LIMIT", "10"))


#!/usr/bin/env bash
# @sinnix-package
# description: Launch mcp-chrome-devtools against a private, live-state-seeded Chrome profile
# runtimeInputs: bash coreutils google-chrome
#
# Gives agents the same DevTools tool shape as the user's live Chrome, but
# against a private persistent profile initially seeded from live Chrome state.
# Existing state is preserved across restart. It stays separate from the shell CDP helper's private profile so
# concurrent MCP and shell browser sessions cannot fight over a Chrome
# profile lock. It is headless by default; set SINNIX_AGENT_CHROME_HEADLESS=0
# when a visible private browser window is desired for operator inspection.
#
# Required environment:
#   SINNIX_MCP_CHROME_DEVTOOLS_BIN — absolute path to the mcp-chrome-devtools binary
set -euo pipefail

: "${SINNIX_MCP_CHROME_DEVTOOLS_BIN:?SINNIX_MCP_CHROME_DEVTOOLS_BIN must name the mcp-chrome-devtools binary}"

profile_dir="${SINNIX_AGENT_CHROME_PROFILE:-$HOME/.local/share/sinnix-browser/chrome-devtools-private-live-state}"
viewport="${SINNIX_AGENT_CHROME_VIEWPORT:-1440x1000}"
headless="${SINNIX_AGENT_CHROME_HEADLESS:-1}"
chrome_bin="${SINNIX_AGENT_CHROME_EXECUTABLE:-$(command -v google-chrome-stable || true)}"
if [ -z "$chrome_bin" ] || [ ! -x "$chrome_bin" ]; then
  echo "SINNIX_AGENT_CHROME_EXECUTABLE does not name an executable Chrome: $chrome_bin" >&2
  exit 2
fi
SINNIX_AGENT_CHROME_PROFILE="$profile_dir" \
  "$HOME/.local/bin/sinnix-chrome-control" --target private private-sync-state

args=(
  --executablePath "$chrome_bin"
  --userDataDir "$profile_dir"
  --viewport "$viewport"
  --no-usage-statistics
)
if [ "$headless" != "0" ]; then
  args+=(--headless)
fi

exec "$SINNIX_MCP_CHROME_DEVTOOLS_BIN" "${args[@]}" "$@"

#!/usr/bin/env bash
# @sinnix-package
# description: Record systemd-oomd memory-pressure events and notify the desktop
# runtimeInputs: bash coreutils jq libnotify systemd util-linux

set -euo pipefail

events_dir="${SINNIX_OOMD_EVENTS_DIR:-/realm/data/captures/syslog/oomd-events}"
state_dir="${SINNIX_OOMD_STATE_DIR:-/var/lib/sinnix-oomd-watch}"
events_file="$events_dir/events.jsonl"
cursor_file="$state_dir/journal.cursor"
notify_user="${SINNIX_NOTIFY_USER:-sinity}"

mkdir -p "$events_dir"
mkdir -p "$state_dir"
touch "$events_file"
chmod 0750 "$events_dir"
chmod 0750 "$state_dir"
chmod 0640 "$events_file"
if id "$notify_user" >/dev/null 2>&1; then
  chown "$notify_user:users" "$events_dir" "$events_file" 2>/dev/null || true
fi

notify_desktop() {
  local unit="$1"
  local message="$2"
  local uid

  if ! command -v notify-send >/dev/null 2>&1; then
    return 0
  fi
  uid="$(id -u "$notify_user" 2>/dev/null || true)"
  if [ -z "$uid" ] || [ ! -S "/run/user/$uid/bus" ]; then
    return 0
  fi

  runuser -u "$notify_user" -- \
    env \
      XDG_RUNTIME_DIR="/run/user/$uid" \
      DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
      notify-send \
        --urgency=critical \
        --expire-time=12000 \
        "systemd-oomd kill" \
        "$unit
${message:0:320}

events: $events_file" >/dev/null 2>&1 || true
}

record_event() {
  local line="$1"
  local captured_at

  captured_at="$(date --iso-8601=seconds)"
  printf '%s\n' "$line" \
    | jq -c --arg captured_at "$captured_at" '{
        captured_at: $captured_at,
        realtime_usec: .__REALTIME_TIMESTAMP,
        boot_id: ._BOOT_ID,
        system_unit: ._SYSTEMD_UNIT,
        user_unit: ._SYSTEMD_USER_UNIT,
        slice: ._SYSTEMD_SLICE,
        cgroup: ._SYSTEMD_CGROUP,
        syslog_identifier: .SYSLOG_IDENTIFIER,
        pid: ._PID,
        message: .MESSAGE
      }' >> "$events_file"
}

initialize_cursor() {
  local cursor

  cursor="$(
    journalctl --lines=0 --show-cursor --no-pager \
      | sed -n 's/^-- cursor: //p'
  )"
  if [ -n "$cursor" ]; then
    printf '%s\n' "$cursor" > "$cursor_file"
    chmod 0640 "$cursor_file"
  fi
}

if [ ! -s "$cursor_file" ]; then
  initialize_cursor
  exit 0
fi

journalctl \
  --cursor-file="$cursor_file" \
  --output=json \
  --no-pager \
  | while IFS= read -r line; do
      message="$(printf '%s\n' "$line" | jq -r '.MESSAGE // empty' 2>/dev/null || true)"
      case "$message" in
        *"systemd-oomd killed"*|*"result 'oom-kill'"*|*"candidate for killing due to memory pressure"*)
          record_event "$line"
          ;;
        *)
          continue
          ;;
      esac

      case "$message" in
        *"systemd-oomd killed"*|*"result 'oom-kill'"*)
          unit="$(printf '%s\n' "$line" | jq -r '._SYSTEMD_USER_UNIT // ._SYSTEMD_UNIT // "unknown unit"' 2>/dev/null || true)"
          if [ -z "$unit" ] || [ "$unit" = "null" ]; then
            unit="unknown unit"
          fi
          notify_desktop "$unit" "$message"
          ;;
      esac
    done

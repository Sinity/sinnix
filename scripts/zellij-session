#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: zellij-session <name> [command...]

Attach to an existing Zellij session named <name>, or create it if it
does not yet exist. Optional [command...] overrides the default shell.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

session="${1:-}"
if [[ -z "${session}" ]]; then
  session="main"
else
  shift
fi

# zellij 0.43+ no longer supports `-- <cmd>` after `--session`.
# If a command is provided, ignore it for now rather than erroring.
if [[ $# -gt 0 ]]; then
  printf 'zellij-session: command arguments are ignored with zellij >=0.43\n' >&2
fi

sanitize() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | tr -c '[:alnum:]-' '-' | sed 's/^-*//;s/-*$//'
}

session="$(sanitize "${session}")"
[[ -z "${session}" ]] && session="main"

if zellij list-sessions 2>/dev/null | awk '{print $1}' | grep -qx "${session}"; then
  exec zellij attach "${session}"
else
  exec zellij attach --create "${session}"
fi

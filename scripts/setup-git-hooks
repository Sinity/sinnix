#!/usr/bin/env bash
set -euo pipefail

# Setup git hooks for sinnix repository

REPO_ROOT="$(git rev-parse --show-toplevel)"
HOOKS_DIR="$REPO_ROOT/.git/hooks"

echo "Setting up git hooks in $HOOKS_DIR"

# Install pre-commit hook
cat > "$HOOKS_DIR/pre-commit" << 'EOF'
#!/usr/bin/env bash
exec "$(git rev-parse --show-toplevel)/scripts/pre-commit-check"
EOF

chmod +x "$HOOKS_DIR/pre-commit"

echo "✓ Git hooks installed"
echo ""
echo "The following checks will run before each commit:"
echo "  • Nix flake evaluation and syntax"
echo "  • Service conflict detection"
echo "  • Critical directory tmpfiles verification"
echo "  • Untracked .nix file detection"
echo ""
echo "To skip hooks temporarily: git commit --no-verify"

#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: normalize-agent-projects [--write|--check|--dry-run] [ROOT] [MAX_DEPTH]

Modes:
  --write    Apply normalization changes (default)
  --check    Verify repositories are normalized and in sync; exit non-zero if not
  --dry-run  Print planned changes without writing; exits zero unless hard errors occur
USAGE
}

MODE="write"
declare -a positionals=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --write)
      MODE="write"
      ;;
    --check)
      MODE="check"
      ;;
    --dry-run)
      MODE="dry-run"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [ "$#" -gt 0 ]; do
        positionals+=("$1")
        shift
      done
      break
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      positionals+=("$1")
      ;;
  esac
  shift
done

if [ "${#positionals[@]}" -gt 2 ]; then
  echo "error: too many positional arguments" >&2
  usage >&2
  exit 2
fi

ROOT="${positionals[0]:-/realm/project}"
MAX_DEPTH="${positionals[1]:-4}"
RENDER_BIN="${RENDER_BIN:-$(dirname "$0")/render-agents}"

if [ ! -x "$RENDER_BIN" ]; then
  echo "error: render-agents not executable: $RENDER_BIN" >&2
  exit 1
fi

if [ ! -d "$ROOT" ]; then
  echo "error: root directory not found: $ROOT" >&2
  exit 1
fi

mapfile -t doc_dirs < <(
  find "$ROOT" -maxdepth "$MAX_DEPTH" \( -type f -o -type l \) \( -name "AGENTS.md" -o -name "CLAUDE.md" -o -name "AGENTS.override.md" \) -printf "%h\n" | sort -u
)

if [ "${#doc_dirs[@]}" -eq 0 ]; then
  echo "no AGENTS.md or CLAUDE.md found under $ROOT"
  exit 0
fi

declare -A seen_git=()
processed=0
rendered=0
claude_promoted=0
claude_created=0
overrides_removed=0
gitignores_updated=0
changes_needed=0
issues=0

is_write=0
if [ "$MODE" = "write" ]; then
  is_write=1
fi

plan() {
  local msg="$1"
  if [ "$is_write" -eq 0 ]; then
    echo "plan: $msg"
  fi
}

mark_change() {
  changes_needed=$((changes_needed + 1))
}

ensure_ignore_entry() {
  local git_root="$1"
  local entry="$2"
  local gi="$git_root/.gitignore"
  if [ ! -f "$gi" ]; then
    mark_change
    if [ "$is_write" -eq 1 ]; then
      touch "$gi"
    else
      plan "create $gi"
      return
    fi
  fi
  if ! grep -qx "$entry" "$gi"; then
    mark_change
    if [ "$is_write" -eq 1 ]; then
      printf '\n%s\n' "$entry" >>"$gi"
      gitignores_updated=$((gitignores_updated + 1))
    else
      plan "append '$entry' to $gi"
    fi
  fi
}

for dir in "${doc_dirs[@]}"; do
  git_root="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -n "$git_root" ] && [ "$dir" != "$git_root" ]; then
    continue
  fi

  claude="$dir/CLAUDE.md"
  agents="$dir/AGENTS.md"
  override="$dir/AGENTS.override.md"
  decision=""

  if [ -L "$claude" ]; then
    target="$(readlink "$claude" || true)"
    if [ "$target" = "AGENTS.md" ] && [ -f "$agents" ]; then
      mark_change
      if [ "$is_write" -eq 1 ]; then
        tmp="$(mktemp)"
        cp "$agents" "$tmp"
        rm "$claude"
        mv "$tmp" "$claude"
      else
        plan "promote $claude symlink into real source file copied from $agents"
      fi
      claude_promoted=$((claude_promoted + 1))
      decision="promoted-claude-from-symlink"
    fi
  fi

  if [ ! -f "$claude" ] && [ -f "$agents" ]; then
    mark_change
    if [ "$is_write" -eq 1 ]; then
      cp "$agents" "$claude"
    else
      plan "create $claude from existing $agents"
    fi
    claude_created=$((claude_created + 1))
    decision="created-claude-from-agents"
  fi

  if [ -f "$claude" ] && [ -f "$agents" ] && ! cmp -s "$claude" "$agents"; then
    if [ -z "$decision" ]; then
      decision="kept-claude-as-source"
    fi
  elif [ -z "$decision" ] && [ -f "$claude" ]; then
    decision="kept-claude-as-source"
  fi

  if [ -f "$claude" ]; then
    if [ "$is_write" -eq 1 ]; then
      if ! "$RENDER_BIN" --input "$claude" --output "$agents"; then
        echo "error: failed to render $dir/AGENTS.md" >&2
        issues=$((issues + 1))
      else
        rendered=$((rendered + 1))
      fi
      processed=$((processed + 1))
      echo "normalized: $dir ($decision)"
    else
      check_output=""
      if ! check_output="$("$RENDER_BIN" --input "$claude" --output "$agents" --check 2>&1)"; then
        if echo "$check_output" | grep -q "out of sync"; then
          mark_change
          plan "render AGENTS.md from $claude"
        else
          echo "error: render check failed for $claude" >&2
          echo "$check_output" >&2
          issues=$((issues + 1))
        fi
      fi
      rendered=$((rendered + 1))
      processed=$((processed + 1))
      echo "checked: $dir ($decision)"
    fi
  fi

  if [ -f "$override" ]; then
    mark_change
    if [ "$is_write" -eq 1 ]; then
      rm "$override"
    else
      plan "remove legacy override file $override"
    fi
    overrides_removed=$((overrides_removed + 1))
  fi

  if [ -n "$git_root" ] && [ -z "${seen_git[$git_root]:-}" ]; then
    seen_git["$git_root"]=1
    ensure_ignore_entry "$git_root" "AGENTS.md"
  fi
done

echo "mode=$MODE normalized_dirs=$processed rendered_agents=$rendered claude_promoted=$claude_promoted claude_created=$claude_created overrides_removed=$overrides_removed gitignores_updated=$gitignores_updated changes_needed=$changes_needed issues=$issues"

if [ "$MODE" = "check" ]; then
  if [ "$issues" -gt 0 ] || [ "$changes_needed" -gt 0 ]; then
    exit 1
  fi
fi

if [ "$MODE" = "dry-run" ] && [ "$issues" -gt 0 ]; then
  exit 1
fi

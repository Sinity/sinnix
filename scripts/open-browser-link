#!/usr/bin/env bash
# @sinnix-package: skip
set -euo pipefail

if [ "$#" -eq 0 ]; then
  echo "usage: open-browser-link <url> [more-urls...]" >&2
  exit 1
fi

browser_cmd="${SINNIX_BROWSER_COMMAND:-sinnix-chrome}"
if ! command -v "$browser_cmd" >/dev/null 2>&1; then
  browser_cmd=google-chrome-stable
fi

setsid -f "$browser_cmd" "$@" >/dev/null 2>&1 < /dev/null

#!/usr/bin/env bash
# @sinnix-package
# description: Reset the zram swap device after known-heavy maintenance
# runtimeInputs: bash coreutils gnugrep systemd util-linux

set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: sinnix-zram-reset [--yes]

Reset /dev/zram0 after a known-heavy build or maintenance run leaves cold pages
compressed in zram despite plenty of available RAM.

This is intentionally manual. It is not a polling swap-drain service.
EOF
}

restore_zram() {
  systemctl reset-failed systemd-zram-setup@zram0.service dev-zram0.swap || true
  systemctl start systemd-zram-setup@zram0.service || true
  systemctl start dev-zram0.swap || true
}

reset_zram_device() {
  local attempt
  for attempt in $(seq 1 20); do
    if printf 1 > /sys/block/zram0/reset 2>/dev/null; then
      return 0
    fi
    sleep 0.25
  done
  return 1
}

confirm=0
if (($#)); then
  case "$1" in
    --yes)
      confirm=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 64
      ;;
  esac
fi

if (($#)); then
  usage
  exit 64
fi

if [ "$(id -u)" -ne 0 ]; then
  echo "sinnix-zram-reset: run as root, for example: sudo sinnix-zram-reset --yes" >&2
  exit 77
fi

if [ ! -e /sys/block/zram0/reset ]; then
  echo "sinnix-zram-reset: /sys/block/zram0/reset does not exist" >&2
  exit 69
fi

active_swaps="$(swapon --noheadings --raw --show=NAME 2>/dev/null || true)"
if [ "$active_swaps" != "/dev/zram0" ]; then
  echo "sinnix-zram-reset: refusing because active swap is not exactly /dev/zram0" >&2
  swapon --show >&2 || true
  exit 69
fi

used_bytes="$(swapon --bytes --noheadings --raw --show=USED /dev/zram0 2>/dev/null || echo 0)"
if [ "${used_bytes:-0}" = "0" ]; then
  echo "zram already empty"
  swapon --show
  exit 0
fi

if [ "$confirm" -ne 1 ]; then
  echo "zram currently has $used_bytes bytes in use." >&2
  echo "Re-run with --yes to reset /dev/zram0." >&2
  exit 64
fi

echo "Before:"
swapon --show
free -h

systemctl stop dev-zram0.swap
systemctl stop systemd-zram-setup@zram0.service || true
if ! reset_zram_device; then
  echo "sinnix-zram-reset: /sys/block/zram0/reset stayed busy; restoring zram swap" >&2
  restore_zram
  exit 75
fi
systemctl reset-failed systemd-zram-setup@zram0.service dev-zram0.swap
systemctl start systemd-zram-setup@zram0.service
systemctl start dev-zram0.swap

echo
echo "After:"
swapon --show
free -h

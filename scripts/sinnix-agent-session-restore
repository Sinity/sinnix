#!/usr/bin/env python3

import argparse
import json
import os
import shlex
import stat
import subprocess
import sys
import time
from dataclasses import dataclass, asdict
from datetime import datetime, timedelta
from pathlib import Path


STATE_VERSION = 1
DEFAULT_LOOKBACK_HOURS = 72
DEFAULT_MAX_SESSIONS = 8
DEFAULT_SETTLE_SECONDS = 4
VERBOSE = False
AGENT_TOKEN_MAP = {
    "codex": "codex",
    "claude": "claude",
    "claude-team": "claude",
    "gemini": "gemini",
}


@dataclass(frozen=True)
class Candidate:
    session_id: str
    tty: str
    agent: str
    command: str
    normalized_command: str
    cwd: str
    started_at_ms: int
    source_path: str

    @property
    def dedupe_key(self) -> str:
        return f"{self.agent}|{self.cwd}|{self.normalized_command}"


def eprint(*args: object) -> None:
    print(*args, file=sys.stderr)


def load_json(path: Path) -> dict | None:
    try:
        return json.loads(path.read_text())
    except FileNotFoundError:
        return None
    except json.JSONDecodeError as exc:
        if VERBOSE:
            eprint(f"warning: failed to parse {path}: {exc}")
        return None


def current_boot_started_at_ms() -> int:
    with open("/proc/stat", "r", encoding="utf-8") as handle:
        for line in handle:
            if line.startswith("btime "):
                return int(line.split()[1]) * 1000
    raise RuntimeError("unable to determine current boot time from /proc/stat")


def current_boot_id() -> str:
    return Path("/proc/sys/kernel/random/boot_id").read_text().strip()


def previous_boot_started_at_ms() -> int | None:
    cp = subprocess.run(
        ["journalctl", "--list-boots", "--no-pager"],
        text=True,
        capture_output=True,
        check=False,
    )
    if cp.returncode != 0:
        return None

    for line in cp.stdout.splitlines():
        line = line.strip()
        if not line.startswith("-1 "):
            continue
        parts = line.split()
        if len(parts) < 7:
            return None
        candidate = " ".join(parts[2:7])
        for fmt in ("%a %Y-%m-%d %H:%M:%S %Z", "%a %Y-%m-%d %H:%M:%S"):
            try:
                dt = datetime.strptime(candidate, fmt)
                return int(dt.timestamp() * 1000)
            except ValueError:
                continue
        return None
    return None


def recent_capture_days(capture_root: Path, lookback_hours: int) -> list[Path]:
    today = datetime.now().date()
    days = max(1, int((lookback_hours + 23) / 24) + 1)
    out: list[Path] = []
    for offset in range(days):
        day = today - timedelta(days=offset)
        candidate = capture_root / day.strftime("%Y/%m/%d")
        if candidate.is_dir():
            out.append(candidate)
    return out


def normalized_command(command: str) -> str:
    command = command.strip()
    if not command:
        return command
    try:
        return " ".join(shlex.split(command))
    except ValueError:
        return " ".join(command.split())


def classify_agent(command: str) -> str | None:
    command = command.strip()
    if not command:
        return None
    try:
        token = shlex.split(command)[0]
    except ValueError:
        token = command.split()[0]
    return AGENT_TOKEN_MAP.get(token)


def active_agent_command_from_path(path: Path) -> dict | None:
    try:
        with path.open("r", encoding="utf-8") as handle:
            active: dict | None = None
            for line in handle:
                if not line.strip():
                    continue
                try:
                    event = json.loads(line)
                except json.JSONDecodeError as exc:
                    if VERBOSE:
                        eprint(f"warning: failed to parse line in {path}: {exc}")
                    continue
                kind = event.get("type")
                if kind == "command_start":
                    if classify_agent(str(event.get("command", ""))):
                        active = event
                    else:
                        active = {"non_agent": True}
                elif kind == "command_end":
                    active = None
    except FileNotFoundError:
        return None

    if active and active.get("non_agent"):
        return None
    return active


def candidate_from_session(session_file: Path) -> Candidate | None:
    session = load_json(session_file)
    if not session:
        return None

    events_path = Path(session.get("events_path") or session_file.with_name("events.jsonl"))
    active = active_agent_command_from_path(events_path)
    if not active:
        return None

    command = str(active.get("command", "")).strip()
    agent = classify_agent(command)
    if not agent:
        return None

    cwd = (
        active.get("cwd")
        or session.get("final_cwd")
        or session.get("start_cwd")
        or active.get("project_root")
        or active.get("repo_root")
    )
    if not cwd:
        return None

    started_at_ms = int(session.get("started_at_ms") or active.get("ts_ms") or 0)
    if started_at_ms <= 0:
        return None

    return Candidate(
        session_id=str(session.get("session_id") or session_file.parent.name),
        tty=str(session.get("tty") or ""),
        agent=agent,
        command=command,
        normalized_command=normalized_command(command),
        cwd=str(cwd),
        started_at_ms=started_at_ms,
        source_path=str(session_file),
    )


def build_plan(capture_root: Path, lookback_hours: int, max_sessions: int) -> tuple[list[Candidate], dict[str, int]]:
    boot_ms = current_boot_started_at_ms()
    previous_boot_ms = previous_boot_started_at_ms()
    previous_by_tty: dict[str, Candidate] = {}
    current_counts: dict[str, int] = {}

    for day_dir in recent_capture_days(capture_root, lookback_hours):
        for session_file in sorted(day_dir.glob("sinnix-prime-*/session.json")):
            candidate = candidate_from_session(session_file)
            if not candidate:
                continue

            if candidate.started_at_ms >= boot_ms:
                current_counts[candidate.dedupe_key] = current_counts.get(candidate.dedupe_key, 0) + 1
                continue
            if previous_boot_ms is not None and candidate.started_at_ms < previous_boot_ms:
                continue

            existing = previous_by_tty.get(candidate.tty)
            if existing is None or existing.started_at_ms < candidate.started_at_ms:
                previous_by_tty[candidate.tty] = candidate

    ordered = sorted(previous_by_tty.values(), key=lambda c: c.started_at_ms, reverse=True)
    return ordered[:max_sessions], current_counts


def default_state_path() -> Path:
    state_home = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state"))
    return state_home / "sinnix/agent-session-restore/state.json"


def load_state(path: Path) -> dict:
    state = load_json(path)
    if not state:
        return {
            "version": STATE_VERSION,
            "restored_source_sessions": [],
            "auto_boot_ids": [],
        }
    return {
        "version": state.get("version", STATE_VERSION),
        "restored_source_sessions": list(state.get("restored_source_sessions", [])),
        "auto_boot_ids": list(state.get("auto_boot_ids", [])),
    }


def save_state(path: Path, state: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n")


def kitty_socket() -> str:
    env_socket = os.environ.get("KITTY_LISTEN_ON")
    if env_socket:
        return env_socket
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    user = os.environ.get("USER")
    if runtime_dir and user:
        return f"unix:{runtime_dir}/kitty-{user}"
    raise RuntimeError("unable to determine kitty socket path")


def candidate_kitty_sockets(preferred_socket: str | None = None) -> list[str]:
    sockets: list[str] = []
    seen: set[str] = set()

    def add(socket: str | None) -> None:
        if socket and socket not in seen:
            sockets.append(socket)
            seen.add(socket)

    add(preferred_socket)
    add(os.environ.get("KITTY_LISTEN_ON"))

    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    user = os.environ.get("USER")
    if runtime_dir and user:
        runtime_path = Path(runtime_dir)
        socket_paths = [runtime_path / f"kitty-{user}"]
        socket_paths.extend(
            sorted(
                runtime_path.glob(f"kitty-{user}-*"),
                key=lambda path: path.stat().st_mtime,
                reverse=True,
            )
        )
        for path in socket_paths:
            try:
                mode = path.stat().st_mode
            except FileNotFoundError:
                continue
            if stat.S_ISSOCK(mode):
                add(f"unix:{path}")

    return sockets


def run(cmd: list[str], *, input_text: str | None = None, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        cmd,
        input=input_text,
        text=True,
        capture_output=True,
        check=check,
    )


def kitty_windows(kitty_bin: str, socket: str) -> list[dict]:
    cp = run([kitty_bin, "@", "--to", socket, "ls"])
    raw = json.loads(cp.stdout)
    windows: list[dict] = []
    for os_window in raw:
        for tab in os_window.get("tabs", []):
            tab_id = tab.get("id")
            for window in tab.get("windows", []):
                windows.append(
                    {
                        "id": window.get("id"),
                        "tab_id": tab_id,
                        "title": window.get("title"),
                        "at_prompt": window.get("at_prompt"),
                    }
                )
    return windows


def kitty_socket_ready(kitty_bin: str, socket: str) -> bool:
    cp = subprocess.run(
        [kitty_bin, "@", "--to", socket, "ls"],
        text=True,
        capture_output=True,
    )
    return cp.returncode == 0


def wait_for_socket(kitty_bin: str, socket: str, timeout_sec: float = 15.0) -> None:
    deadline = time.time() + timeout_sec
    while time.time() < deadline:
        if kitty_socket_ready(kitty_bin, socket):
            return
        time.sleep(0.2)
    raise RuntimeError(f"kitty socket did not become ready: {socket}")


def wait_for_prompt(kitty_bin: str, socket: str, window_id: int, timeout_sec: float = 2.0) -> bool:
    deadline = time.time() + timeout_sec
    while time.time() < deadline:
        for window in kitty_windows(kitty_bin, socket):
            if int(window["id"]) == int(window_id) and window.get("at_prompt"):
                return True
        time.sleep(0.2)
    return False


def spawn_first_window(kitty_bin: str, socket: str) -> int:
    subprocess.Popen([kitty_bin, "--detach", "--listen-on", socket])
    wait_for_socket(kitty_bin, socket)
    windows = kitty_windows(kitty_bin, socket)
    if not windows:
        raise RuntimeError("kitty started but no windows were reported")
    return int(max(windows, key=lambda w: int(w["id"]))["id"])


def resolve_socket(kitty_bin: str, preferred_socket: str | None = None) -> str:
    for socket in candidate_kitty_sockets(preferred_socket):
        if kitty_socket_ready(kitty_bin, socket):
            return socket
    if preferred_socket:
        return preferred_socket
    return kitty_socket()


def launch_tab(kitty_bin: str, socket: str, title: str) -> int:
    cp = run(
        [
            kitty_bin,
            "@",
            "--to",
            socket,
            "launch",
            "--type=tab",
            "--keep-focus",
            "--tab-title",
            title,
        ]
    )
    return int(cp.stdout.strip())


def temporary_title(kitty_bin: str, socket: str, window_id: int, title: str) -> None:
    run(
        [
            kitty_bin,
            "@",
            "--to",
            socket,
            "set-window-title",
            "--temporary",
            "--match",
            f"id:{window_id}",
            title,
        ]
    )


def send_command(kitty_bin: str, socket: str, window_id: int, cwd: str, command: str) -> None:
    lines = [f"cd -- {shlex.quote(cwd)}", command, ""]
    text = "\n".join(lines)
    run(
        [
            kitty_bin,
            "@",
            "--to",
            socket,
            "send-text",
            "--match",
            f"id:{window_id}",
            "--stdin",
        ],
        input_text=text,
    )


def print_human_plan(candidates: list[Candidate], current_counts: dict[str, int], restored_ids: set[str]) -> None:
    if not candidates:
        print("No interrupted agent sessions found.")
        return

    print("TTY\tAGENT\tSTATUS\tCWD\tCOMMAND")
    consumed_counts: dict[str, int] = {}
    for candidate in candidates:
        if candidate.session_id in restored_ids:
            status = "seen"
        elif consumed_counts.get(candidate.dedupe_key, 0) < current_counts.get(candidate.dedupe_key, 0):
            status = "already-open"
            consumed_counts[candidate.dedupe_key] = consumed_counts.get(candidate.dedupe_key, 0) + 1
        else:
            status = "pending"
        print(
            "\t".join(
                [
                    candidate.tty or "?",
                    candidate.agent,
                    status,
                    candidate.cwd,
                    candidate.command,
                ]
            )
        )


def restore(args: argparse.Namespace) -> int:
    state = load_state(args.state_file)
    restored_ids = set(state["restored_source_sessions"])
    boot_id = current_boot_id()
    if args.auto and not args.force and boot_id in set(state["auto_boot_ids"]):
        print("Auto-restore already processed for this boot.")
        return 0

    candidates, current_counts = build_plan(args.capture_root, args.lookback_hours, args.max_sessions)
    pending: list[Candidate] = []
    satisfied: list[Candidate] = []
    consumed_counts: dict[str, int] = {}
    for candidate in candidates:
        if candidate.session_id in restored_ids:
            continue
        if consumed_counts.get(candidate.dedupe_key, 0) < current_counts.get(candidate.dedupe_key, 0):
            satisfied.append(candidate)
            consumed_counts[candidate.dedupe_key] = consumed_counts.get(candidate.dedupe_key, 0) + 1
        else:
            pending.append(candidate)

    for candidate in satisfied:
        print(f"Already open: {candidate.cwd} :: {candidate.command}")
        restored_ids.add(candidate.session_id)

    if args.settle_seconds > 0 and not args.dry_run:
        time.sleep(args.settle_seconds)

    if args.dry_run:
        for candidate in pending:
            print(f"Would restore: {candidate.cwd} :: {candidate.command}")
    else:
        if pending:
            socket = resolve_socket(args.kitty_bin, args.socket)
            first = True
            for candidate in pending:
                title = candidate.command
                if first and not kitty_socket_ready(args.kitty_bin, socket):
                    window_id = spawn_first_window(args.kitty_bin, socket)
                    first = False
                else:
                    window_id = launch_tab(args.kitty_bin, socket, title)
                    first = False
                temporary_title(args.kitty_bin, socket, window_id, title)
                prompt_ready = wait_for_prompt(args.kitty_bin, socket, window_id)
                if not prompt_ready and VERBOSE:
                    eprint(
                        f"warning: window {window_id} did not report at_prompt; continuing with buffered send-text"
                    )
                send_command(args.kitty_bin, socket, window_id, candidate.cwd, candidate.command)
                print(f"Restored: {candidate.cwd} :: {candidate.command}")
                restored_ids.add(candidate.session_id)
        else:
            print("No pending agent sessions to restore.")

    state["restored_source_sessions"] = sorted(restored_ids)
    auto_boot_ids = set(state["auto_boot_ids"])
    if args.auto:
        auto_boot_ids.add(boot_id)
    state["auto_boot_ids"] = sorted(auto_boot_ids)
    if not args.dry_run:
        save_state(args.state_file, state)
    return 0


def plan(args: argparse.Namespace) -> int:
    state = load_state(args.state_file)
    restored_ids = set(state["restored_source_sessions"])
    candidates, current_counts = build_plan(args.capture_root, args.lookback_hours, args.max_sessions)
    if args.json:
        consumed_counts: dict[str, int] = {}
        serialized = []
        for candidate in candidates:
            if candidate.session_id in restored_ids:
                status = "seen"
            elif consumed_counts.get(candidate.dedupe_key, 0) < current_counts.get(candidate.dedupe_key, 0):
                status = "already-open"
                consumed_counts[candidate.dedupe_key] = consumed_counts.get(candidate.dedupe_key, 0) + 1
            else:
                status = "pending"
            serialized.append({**asdict(candidate), "status": status})
        payload = {
            "candidates": serialized
        }
        print(json.dumps(payload, indent=2))
    else:
        print_human_plan(candidates, current_counts, restored_ids)
    return 0


def clear_state(args: argparse.Namespace) -> int:
    if args.state_file.exists():
        args.state_file.unlink()
        print(f"Cleared {args.state_file}")
    else:
        print("State file already absent.")
    return 0


def parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="Restore interrupted Codex/Claude/Gemini terminal sessions.")
    p.set_defaults(func=None)
    p.add_argument(
        "--capture-root",
        type=Path,
        default=Path(os.environ.get("SINNIX_CAPTURE_ROOT", "/realm/data/captures/asciinema")),
        help="Root directory that contains terminal capture sessions.",
    )
    p.add_argument(
        "--state-file",
        type=Path,
        default=default_state_path(),
        help="State file used to avoid re-restoring the same interrupted sessions.",
    )
    p.add_argument("--lookback-hours", type=int, default=DEFAULT_LOOKBACK_HOURS)
    p.add_argument("--max-sessions", type=int, default=DEFAULT_MAX_SESSIONS)
    p.add_argument("--verbose", action="store_true")

    sub = p.add_subparsers(dest="command")

    p_plan = sub.add_parser("plan", help="Show interrupted agent sessions from previous boots.")
    p_plan.add_argument("--json", action="store_true")
    p_plan.set_defaults(func=plan)

    p_restore = sub.add_parser("restore", help="Restore interrupted agent sessions.")
    p_restore.add_argument("--dry-run", action="store_true")
    p_restore.add_argument("--auto", action="store_true", help="Mark this boot as processed in the restore state.")
    p_restore.add_argument("--force", action="store_true", help="Ignore the per-boot auto-run guard.")
    p_restore.add_argument("--settle-seconds", type=int, default=DEFAULT_SETTLE_SECONDS)
    p_restore.add_argument("--kitty-bin", default=os.environ.get("SINNIX_AGENT_RESTORE_KITTY", "kitty"))
    p_restore.add_argument("--socket", default=os.environ.get("SINNIX_AGENT_RESTORE_SOCKET"))
    p_restore.set_defaults(func=restore)

    p_clear = sub.add_parser("clear-state", help="Forget all previously restored source sessions.")
    p_clear.set_defaults(func=clear_state)
    return p


def main() -> int:
    args = parser().parse_args()
    global VERBOSE
    VERBOSE = args.verbose
    if args.func is None:
        parser().print_help()
        return 2
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())

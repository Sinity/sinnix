#!/usr/bin/env bash
# Finds the root of the current flake/project context.

if [ -n "$FLAKE" ]; then
  printf '%s\n' "$FLAKE"
  exit 0
fi
if command -v git >/dev/null 2>&1; then
  if git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
    printf '%s\n' "$git_root"
    exit 0
  fi
fi
if [ -n "$PRJ_ROOT" ]; then
  printf '%s\n' "$PRJ_ROOT"
  exit 0
fi
if [ -n "$DEVENV_ROOT" ]; then
  printf '%s\n' "$DEVENV_ROOT"
  exit 0
fi
printf '%s\n' "$PWD"

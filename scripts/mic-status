#!/usr/bin/env bash
set -euo pipefail

status=$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ 2>/dev/null || true)
if [[ -z "$status" ]]; then
  jq -n '{text:"󰍭 mic", tooltip:"No default microphone", class:"missing"}'
  exit 0
fi

volume=$(printf '%s\n' "$status" | awk '{for (i=1; i<=NF; i++) if ($i ~ /^[0-9.]+$/) {print $i; exit}}')
muted="false"
if printf '%s\n' "$status" | grep -q '\[muted\]'; then
  muted="true"
fi

icon="󰍬"
class="active"
tooltip="Microphone active"
if [[ "$muted" == "true" ]]; then
  icon="󰍭"
  class="muted"
  tooltip="Microphone muted"
fi

if [[ -n "$volume" ]]; then
  percent=$(awk -v vol="$volume" 'BEGIN {printf "%.0f", vol*100}')
  tooltip="$tooltip"$'\n'"Level: ${percent}%"
fi

jq -n --arg text "$icon mic" --arg tooltip "$tooltip" --arg class "$class" '{text:$text, tooltip:$tooltip, class:$class}'

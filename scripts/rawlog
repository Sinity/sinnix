#!/usr/bin/env bash
set -euo pipefail

# Quick append-only logger for knowledgebase raw-log
# Usage: rawlog [message...]

DEFAULT_REALM_ROOT=${REALM_ROOT:-/realm}
if [ -z "${KB_ROOT:-}" ]; then
  for candidate in "${DEFAULT_REALM_ROOT}/knowledgebase" "$HOME/knowledgebase"; do
    if [ -d "$candidate" ]; then
      KB_ROOT="$candidate"
      break
    fi
  done
fi
KB_ROOT=${KB_ROOT:-${DEFAULT_REALM_ROOT}/knowledgebase}
LOG_DIR="$KB_ROOT/50_logs"
LOG_FILE="$LOG_DIR/raw-log.md"
PICKER=${PICKER:-tofi}
RECENT_COUNT=${RECENT_COUNT:-5}

die() { echo "rawlog: $*" >&2; exit 1; }

[ -d "$KB_ROOT" ] || die "KB root not found: $KB_ROOT"
mkdir -p "$LOG_DIR"
command -v "$PICKER" >/dev/null 2>&1 || die "picker '$PICKER' not found"

prompt_text() {
  local prompt="$1"
  local input_data="$2"
  local selection
  selection=$(printf '%s\n' "$input_data" |
    "$PICKER" \
      --prompt-text "$prompt" \
      --horizontal false \
      --require-match false \
      --print-query || true)
  printf '%s\n' "$selection" | tail -n 1 | sed 's/\r$//'
}

recent_entries() {
  if [ ! -f "$LOG_FILE" ]; then
    return
  fi
  # Extract the Markdown bullet entries and turn them into compact lines with timestamp context
  tail -n 200 "$LOG_FILE" |
    sed -En 's/^- \*\*([^*]+)\*\* (.*)$/[\1] \2/p' |
    tail -n "$RECENT_COUNT"
}

show_context() {
  local history
  history=$(recent_entries)
  [ -z "$history" ] && return

  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl notify 0 6000 "Recent raw log entries:\n$history" >/dev/null 2>&1 || true
  elif command -v notify-send >/dev/null 2>&1; then
    notify-send -t 6000 "Raw log — recent entries" "$history"
  fi
}

pick_message() {
  local history
  history=$(recent_entries)
  local prompt_suffix="Type a new entry"
  if [ -n "$history" ]; then
    last_line=$(printf '%s\n' "$history" | tail -n 1)
    prompt_suffix="Last: ${last_line}"
  fi
  show_context
  prompt_text "Raw log — ${prompt_suffix}:" ""
}

msg="${*:-}"
if [ -z "$msg" ]; then
  msg=$(pick_message)
fi

# Trim message
msg=$(echo -n "$msg" | sed -e 's/^[[:space:]]\+//' -e 's/[[:space:]]\+$//')
[ -n "$msg" ] || exit 0

ts=$(date +"%Y-%m-%d %H:%M:%S")
line="- **$ts** $msg"

# Ensure file exists with a minimal header if missing
if [ ! -f "$LOG_FILE" ]; then
  {
    echo "---"
    echo "id: raw-log"
    echo "aliases: []"
    echo "tags:"
    echo "  - log"
    echo "  - self"
    echo "dr-contextualization: Append-only raw thought log."
    echo "---"
    echo
    echo "# Raw log"
    echo
  } >>"$LOG_FILE"
fi

echo "$line" >>"$LOG_FILE"

if command -v notify-send >/dev/null 2>&1; then
  recent_preview=$(recent_entries | tail -n "$RECENT_COUNT")
  notify_body="$msg"
  if [ -n "$recent_preview" ]; then
    notify_body="$msg\n\nRecent:\n$recent_preview"
  fi
  notify-send -t 1200 "Raw log saved" "$notify_body"
fi

echo "$line"

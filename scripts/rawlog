#!/usr/bin/env bash
set -euo pipefail

# Usage: rawlog [message...]

DEFAULT_REALM_ROOT=${REALM_ROOT:-/realm/project}
fi
LOG_FILE="$LOG_DIR/raw-log.md"
PICKER=${PICKER:-tofi}
RECENT_COUNT=${RECENT_COUNT:-5}

die() { echo "rawlog: $*" >&2; exit 1; }

mkdir -p "$LOG_DIR"
command -v "$PICKER" >/dev/null 2>&1 || die "picker '$PICKER' not found"

prompt_text() {
  local prompt="$1"
  local input_data="$2"
  local selection
  selection=$(printf '%s\n' "$input_data" |
    "$PICKER" \
      --prompt-text "$prompt" \
      --horizontal false \
      --require-match false \
      --print-query || true)
  printf '%s\n' "$selection" | tail -n 1 | sed 's/\r$//'
}

recent_entries() {
  if [ ! -f "$LOG_FILE" ]; then
    return
  fi
  # Extract the Markdown bullet entries and turn them into compact lines with timestamp context
  tail -n 200 "$LOG_FILE" |
    sed -En 's/^- \*\*([^*]+)\*\* (.*)$/[\1] \2/p' |
    tail -n "$RECENT_COUNT"
}

show_context() {
  local history
  history=$(recent_entries)
  [ -z "$history" ] && return

  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl notify 0 6000 "Recent raw log entries:\n$history" >/dev/null 2>&1 || true
  elif command -v notify-send >/dev/null 2>&1; then
    notify-send -t 6000 "Raw log — recent entries" "$history"
  fi
}

pick_message() {
  local history
  history=$(recent_entries)
  local prompt_suffix="Type a new entry"
  if [ -n "$history" ]; then
    last_line=$(printf '%s\n' "$history" | tail -n 1)
    prompt_suffix="Last: ${last_line}"
  fi
  show_context
  prompt_text "Raw log — ${prompt_suffix}:" ""
}

msg="${*:-}"
if [ -z "$msg" ]; then
  msg=$(pick_message)
fi

# Trim message
msg=$(echo -n "$msg" | sed -e 's/^[[:space:]]\+//' -e 's/[[:space:]]\+$//')
[ -n "$msg" ] || exit 0

ts=$(date +"%Y-%m-%d %H:%M:%S")
line="- **$ts** $msg"

# Ensure file exists with a minimal header if missing
if [ ! -f "$LOG_FILE" ]; then
  {
    echo "---"
    echo "title: Log — raw-log"
    echo "type: memoir"
    echo "kind: log"
    echo "tags: [gen/self, memoir, log, self]"
    echo "started: $(date +%Y-%m-%d)"
    echo "status: active"
    echo "---"
    echo
    echo "# Raw log"
    echo
  } >>"$LOG_FILE"
fi

echo "$line" >>"$LOG_FILE"

if command -v notify-send >/dev/null 2>&1; then
  # Just show the saved message, not the entire recent history
  notify-send -t 1200 "📝 Logged" "$msg"
fi

echo "$line"

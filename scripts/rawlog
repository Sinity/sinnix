#!/usr/bin/env bash
# @sinnix-package
# description: Append and browse the operator raw-log stream
# runtimeInputs: coreutils less gnused tofi libnotify
set -euo pipefail

# Quick append-only logger for the raw-log stream.
# Usage: rawlog [message...]
#
# Default target: $KNOWLEDGEBASE_ROOT/logs.raw-log.md.
# Override with RAWLOG_FILE=/some/path/file.md.

DEFAULT_DATA_ROOT=${REALM_DATA_ROOT:-/realm/data}
KNOWLEDGEBASE_ROOT=${KNOWLEDGEBASE_ROOT:-${DEFAULT_DATA_ROOT}/knowledgebase}
LOG_FILE=${RAWLOG_FILE:-${KNOWLEDGEBASE_ROOT}/logs.raw-log.md}
LOG_DIR=$(dirname "$LOG_FILE")
PICKER=${PICKER:-tofi}
RECENT_COUNT=${RECENT_COUNT:-5}

die() { echo "rawlog: $*" >&2; exit 1; }

[ -d "$LOG_DIR" ] || die "Log directory not found: $LOG_DIR"

prompt_text() {
  local prompt="$1"
  local input_data="$2"
  local selection
  selection=$(printf '%s\n' "$input_data" |
    "$PICKER" \
      --prompt-text "$prompt" \
      --horizontal false \
      --require-match false \
      --print-query || true)
  printf '%s\n' "$selection" | tail -n 1 | sed 's/\r$//'
}

recent_entries() {
  if [ ! -f "$LOG_FILE" ]; then
    return
  fi
  tail -n 200 "$LOG_FILE" |
    sed -En 's/^- \*\*([^*]+)\*\* (.*)$/[\1] \2/p' |
    tail -n "$RECENT_COUNT"
}

show_context() {
  local history
  history=$(recent_entries)
  [ -z "$history" ] && return

  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl notify 0 6000 "rgb(33ccff)" "Recent raw log entries:\n$history" >/dev/null 2>&1 || true
  elif command -v notify-send >/dev/null 2>&1; then
    notify-send -t 6000 "Raw log — recent entries" "$history"
  fi
}

pick_message() {
  local history
  history=$(recent_entries)
  local prompt_suffix="Type a new entry"
  if [ -n "$history" ]; then
    last_line=$(printf '%s\n' "$history" | tail -n 1)
    prompt_suffix="Last: ${last_line}"
  fi
  show_context
  prompt_text "Raw log — ${prompt_suffix}:" ""
}

msg="${*:-}"
if [ -z "$msg" ]; then
  command -v "$PICKER" >/dev/null 2>&1 || die "picker '$PICKER' not found"
  msg=$(pick_message)
fi

msg=$(echo -n "$msg" | sed -e 's/^[[:space:]]\+//' -e 's/[[:space:]]\+$//')
[ -n "$msg" ] || exit 0

ts=$(date +"%Y-%m-%d %H:%M:%S")
line="- **$ts** $msg"

# Ensure file exists with a Dendron-style frontmatter if missing
# (matches the knowledgebase logs.raw-log.md schema).
if [ ! -f "$LOG_FILE" ]; then
  {
    echo "---"
    echo "id: logs.raw-log"
    echo "aliases: []"
    echo "tags:"
    echo "  - log"
    echo "  - self"
    echo "dr-contextualization: Append-only raw thought log."
    echo "---"
    echo
    echo "# Raw log"
    echo
  } >>"$LOG_FILE"
fi

echo "$line" >>"$LOG_FILE"

if command -v notify-send >/dev/null 2>&1; then
  notify-send -t 1200 "📝 Logged" "$msg"
fi

echo "$line"

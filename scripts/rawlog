#!/usr/bin/env bash
set -euo pipefail

# Quick append-only logger for knowledgebase raw-log
# Usage: rawlog [message...]

KB_ROOT=${KB_ROOT:-/realm/knowledgebase}
LOG_DIR="$KB_ROOT/50_logs"
LOG_FILE="$LOG_DIR/raw-log.md"
PICKER=${PICKER:-tofi}

die() { echo "rawlog: $*" >&2; exit 1; }

[ -d "$KB_ROOT" ] || die "KB root not found: $KB_ROOT"
mkdir -p "$LOG_DIR"
command -v "$PICKER" >/dev/null 2>&1 || die "picker '$PICKER' not found"

prompt_text() {
  local prompt="$1"
  "$PICKER" --prompt "$prompt: " --horizontal=false <<< "" | sed 's/\r$//'
}

msg="${*:-}"
if [ -z "$msg" ]; then
  msg=$(prompt_text "Raw log")
fi

# Trim message
msg=$(echo -n "$msg" | sed -e 's/^[[:space:]]\+//' -e 's/[[:space:]]\+$//')
[ -n "$msg" ] || exit 0

ts=$(date +"%Y-%m-%d %H:%M:%S")
line="- **$ts** $msg"

# Ensure file exists with a minimal header if missing
if [ ! -f "$LOG_FILE" ]; then
  {
    echo "---"
    echo "id: raw-log"
    echo "aliases: []"
    echo "tags:"
    echo "  - log"
    echo "  - self"
    echo "dr-contextualization: Append-only raw thought log."
    echo "---"
    echo
    echo "# Raw log"
    echo
  } >>"$LOG_FILE"
fi

echo "$line" >>"$LOG_FILE"

if command -v notify-send >/dev/null 2>&1; then
  notify-send -t 1200 "Raw log saved" "$msg"
fi

echo "$line"

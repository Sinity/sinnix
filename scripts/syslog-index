#!/usr/bin/env python3
# @sinnix-package
# description: Build a no-loss index for canonical syslog/journal captures
# runtimeInputs: python3 systemd coreutils
"""Build derived indexes for /realm/data/captures/syslog.

The index is not a summary replacement. It records where raw journal and
boot-metric files live, with enough metadata to navigate them quickly. Raw logs
remain canonical and are never modified by this command.
"""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import json
import os
import shutil
import subprocess
import tempfile
from pathlib import Path
from typing import Any

SCHEMA = "sinnix-syslog-index-v1"
DEFAULT_ROOT = Path("/realm/data/captures/syslog")
OUTPUT_MODE = 0o640


def utc_now() -> str:
    return dt.datetime.now(dt.UTC).replace(microsecond=0).isoformat()


def file_sha256(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def journal_edge(path: Path, *, reverse: bool) -> dict[str, Any]:
    journalctl = shutil.which("journalctl")
    if journalctl is None:
        return {"status": "unavailable", "reason": "journalctl not found"}
    cmd = [
        journalctl,
        "--file",
        str(path),
        "--output=json",
        "--no-pager",
        "--lines=1",
    ]
    if reverse:
        cmd.append("--reverse")
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=8, check=False)
    except (OSError, subprocess.TimeoutExpired) as exc:
        return {"status": "error", "reason": str(exc)}
    if proc.returncode != 0:
        return {"status": "error", "reason": proc.stderr.strip() or proc.stdout.strip()}
    line = next((item for item in proc.stdout.splitlines() if item.strip()), "")
    if not line:
        return {"status": "empty"}
    try:
        payload = json.loads(line)
    except json.JSONDecodeError as exc:
        return {"status": "error", "reason": f"invalid json: {exc}"}
    return {
        "status": "ok",
        "realtime_usec": int(payload["_SOURCE_REALTIME_TIMESTAMP"])
        if str(payload.get("_SOURCE_REALTIME_TIMESTAMP", "")).isdigit()
        else None,
        "monotonic_usec": int(payload["__MONOTONIC_TIMESTAMP"])
        if str(payload.get("__MONOTONIC_TIMESTAMP", "")).isdigit()
        else None,
        "boot_id": payload.get("_BOOT_ID"),
        "cursor": payload.get("__CURSOR"),
        "priority": payload.get("PRIORITY"),
        "unit": payload.get("_SYSTEMD_UNIT") or payload.get("_SYSTEMD_USER_UNIT"),
        "syslog_identifier": payload.get("SYSLOG_IDENTIFIER"),
    }


def stat_payload(path: Path, root: Path, *, include_hash: bool) -> dict[str, Any]:
    stat = path.stat()
    payload: dict[str, Any] = {
        "path": str(path),
        "relative_path": str(path.relative_to(root)),
        "bytes": stat.st_size,
        "mtime": dt.datetime.fromtimestamp(stat.st_mtime, dt.UTC).replace(microsecond=0).isoformat(),
        "mode": oct(stat.st_mode & 0o777),
        "inode": stat.st_ino,
    }
    if include_hash:
        payload["sha256"] = file_sha256(path)
    return payload


def journal_rows(root: Path, *, include_hash: bool, inspect_edges: bool) -> list[dict[str, Any]]:
    journal_root = root / "journal"
    rows: list[dict[str, Any]] = []
    if not journal_root.exists():
        return rows
    for path in sorted(item for item in journal_root.rglob("*") if item.is_file()):
        row = stat_payload(path, root, include_hash=include_hash)
        row["kind"] = "journal_file"
        rel = path.relative_to(journal_root)
        row["machine_id"] = rel.parts[0] if rel.parts else None
        row["journal_format"] = path.suffix in {".journal", ".journal~"} or ".journal" in path.name
        if row["journal_format"] and inspect_edges:
            row["first_entry"] = journal_edge(path, reverse=False)
            row["last_entry"] = journal_edge(path, reverse=True)
        rows.append(row)
    return rows


def boot_metric_rows(root: Path, *, include_hash: bool) -> list[dict[str, Any]]:
    metrics_root = root / "boot-metrics"
    rows: list[dict[str, Any]] = []
    if not metrics_root.exists():
        return rows
    for boot_dir in sorted(path for path in metrics_root.iterdir() if path.is_dir()):
        files = [path for path in sorted(boot_dir.rglob("*")) if path.is_file()]
        rows.append(
            {
                "kind": "boot_metrics_dir",
                "boot_id": boot_dir.name,
                "path": str(boot_dir),
                "relative_path": str(boot_dir.relative_to(root)),
                "bytes": sum(path.stat().st_size for path in files),
                "files": [stat_payload(path, root, include_hash=include_hash) for path in files],
            }
        )
    return rows


def publish_atomic(tmp_path: Path, path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    parent_stat = path.parent.stat()
    tmp_path.replace(path)
    try:
        os.chown(path, parent_stat.st_uid, parent_stat.st_gid)
    except PermissionError:
        pass
    path.chmod(OUTPUT_MODE)


def write_jsonl_atomic(path: Path, rows: list[dict[str, Any]]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=path.parent, delete=False) as tmp:
        tmp_path = Path(tmp.name)
        for row in rows:
            tmp.write(json.dumps(row, sort_keys=True) + "\n")
    publish_atomic(tmp_path, path)


def write_json_atomic(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=path.parent, delete=False) as tmp:
        tmp_path = Path(tmp.name)
        json.dump(payload, tmp, indent=2, sort_keys=True)
        tmp.write("\n")
    publish_atomic(tmp_path, path)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--root", type=Path, default=DEFAULT_ROOT)
    parser.add_argument("--output", type=Path)
    parser.add_argument("--hash", action="store_true", help="Hash raw files; slow but stronger for audits.")
    parser.add_argument("--no-edge-inspect", action="store_true", help="Skip journalctl first/last entry probes.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    root = args.root.resolve()
    output = (args.output or (root / "index")).resolve()
    if not root.exists():
        raise SystemExit(f"syslog root does not exist: {root}")

    journal = journal_rows(root, include_hash=args.hash, inspect_edges=not args.no_edge_inspect)
    boot_metrics = boot_metric_rows(root, include_hash=args.hash)
    write_jsonl_atomic(output / "journal-files.jsonl", journal)
    write_jsonl_atomic(output / "boot-metrics.jsonl", boot_metrics)
    write_json_atomic(
        output / "manifest.json",
        {
            "schema": SCHEMA,
            "created_at": utc_now(),
            "root": str(root),
            "output": str(output),
            "policy": "derived no-loss index; raw journal and boot metric files remain canonical",
            "counts": {
                "journal_files": len(journal),
                "boot_metric_dirs": len(boot_metrics),
            },
            "hashes_included": bool(args.hash),
            "journal_edges_inspected": not args.no_edge_inspect,
        },
    )
    print(output / "manifest.json")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

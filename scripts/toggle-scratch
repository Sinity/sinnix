#!/usr/bin/env bash
# @sinnix-package: skip
set -euo pipefail

CONFIG_DIR=${SCRATCHPAD_CONFIG_DIR:-$HOME/.config/scratchpads}
SPECIAL_PREFIX=${SCRATCHPAD_SPECIAL_PREFIX:-scratch}

usage() {
  echo "Usage: toggle-scratch <name>" >&2
  exit 1
}

NAME=${1:-}
[ -n "$NAME" ] || usage
CONFIG_FILE="$CONFIG_DIR/${NAME}.conf"

if [ ! -f "$CONFIG_FILE" ]; then
  echo "toggle-scratch: config not found: $CONFIG_FILE" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$CONFIG_FILE"

: "${CLASS:?toggle-scratch: CLASS not set in $CONFIG_FILE}"
WORKSPACE=${WORKSPACE:-${SPECIAL_PREFIX}_${NAME}}
CLASS_PATTERN=${CLASS_PATTERN:-}
WIDTH_RATIO=${WIDTH_RATIO:-}
HEIGHT_RATIO=${HEIGHT_RATIO:-}
if ! declare -p COMMAND >/dev/null 2>&1; then
  echo "toggle-scratch: COMMAND array not set in $CONFIG_FILE" >&2
  exit 1
fi

command -v hyprctl >/dev/null 2>&1 || {
  echo "toggle-scratch: hyprctl not found" >&2
  exit 1
}

has_window() {
  local clients
  clients=$(hyprctl -j clients 2>/dev/null) || return 1
  [ -n "$clients" ] || return 1
  if HYPR_CLIENTS="$clients" python3 - "$CLASS" "$CLASS_PATTERN" <<'PY'
import json, os, re, sys
class_name = sys.argv[1]
pattern = sys.argv[2]
use_pattern = bool(pattern)
try:
    clients = json.loads(os.environ.get("HYPR_CLIENTS") or "[]")
except json.JSONDecodeError:
    sys.exit(1)
for client in clients:
    name = client.get("class") or ""
    if use_pattern:
        try:
            if re.search(pattern, name):
                sys.exit(0)
        except re.error:
            pass
    elif name == class_name:
        sys.exit(0)
sys.exit(1)
PY
  then
    return 0
  else
    return 1
  fi
}

spawn_window() {
  if [ -n "${WORKDIR:-}" ]; then
    (cd "$WORKDIR" && "${COMMAND[@]}") &
  else
    "${COMMAND[@]}" &
  fi
  disown
}

wait_for_window() {
  local tries=${WAIT_FOR_WINDOW_TRIES:-30}
  local delay=${WAIT_FOR_WINDOW_DELAY:-0.1}
  while [ "$tries" -gt 0 ]; do
    if has_window; then
      return 0
    fi
    tries=$(( tries - 1 ))
    sleep "$delay"
  done
  echo "toggle-scratch: timed out waiting for $CLASS" >&2
  return 1
}

LAST_WINDOW_ADDRESS=""

center_and_focus_window() {
  local regex="$1"
  local clients address cx cy
  clients=$(hyprctl -j clients 2>/dev/null) || return 0
  read -r address cx cy <<EOF || true
$(HYPR_CLIENTS="$clients" python3 - "$regex" <<'PY'
import json, os, re, sys
regex = sys.argv[1]
clients_raw = os.environ.get("HYPR_CLIENTS") or "[]"
try:
    clients = json.loads(clients_raw)
except json.JSONDecodeError:
    sys.exit(0)
for client in clients:
    cls = client.get("class") or ""
    addr = client.get("address")
    if not re.search(regex, cls):
        continue
    at = client.get("at") or [0, 0]
    size = client.get("size") or [0, 0]
    cx = at[0] + size[0] / 2
    cy = at[1] + size[1] / 2
    print(f"{addr} {cx} {cy}")
    break
PY
)
EOF
  if [ -n "${address:-}" ]; then
    LAST_WINDOW_ADDRESS="$address"
    hyprctl dispatch focuswindow "$address" >/dev/null 2>&1 || true
    if [ -n "${cx:-}" ] && [ -n "${cy:-}" ]; then
      hyprctl dispatch movecursor "$cx" "$cy" >/dev/null 2>&1 || true
    fi
  fi
}

resize_window_if_needed() {
  local width_ratio height_ratio address monitors dims width height
  width_ratio=${WIDTH_RATIO:-}
  height_ratio=${HEIGHT_RATIO:-}
  address=${LAST_WINDOW_ADDRESS:-}
  if [ -z "$width_ratio" ] || [ -z "$height_ratio" ] || [ -z "$address" ]; then
    return 0
  fi
  monitors=$(hyprctl -j monitors 2>/dev/null) || return 0
  read -r width height <<EOF || return 0
$(HYPR_MONITORS="$monitors" python3 - "$width_ratio" "$height_ratio" <<'PY'
import json, os, sys
try:
    monitors = json.loads(os.environ.get("HYPR_MONITORS") or "[]")
except json.JSONDecodeError:
    sys.exit(0)
try:
    ratio_w = float(sys.argv[1])
    ratio_h = float(sys.argv[2])
except ValueError:
    sys.exit(0)
focused = next((m for m in monitors if m.get("focused")), None)
if not focused:
    sys.exit(0)
width_px = focused.get("width") or 0
height_px = focused.get("height") or 0
width = max(1, int(width_px * ratio_w))
height = max(1, int(height_px * ratio_h))
print(width, height)
PY
)
EOF
  hyprctl dispatch resizewindowpixel exact "$width" "${height},address:${address}" >/dev/null 2>&1 || true
}

if ! has_window; then
  spawn_window
  wait_for_window || exit 1
fi

current_ws=$(hyprctl -j activeworkspace 2>/dev/null | python3 -c 'import json,sys; d=json.loads(sys.stdin.read() or "{}"); print(d.get("name",""))' 2>/dev/null || true)
hyprctl dispatch togglespecialworkspace "$WORKSPACE" >/dev/null
if [ "special:${WORKSPACE}" != "${current_ws}" ]; then
  pattern=${CLASS_PATTERN:-^${CLASS}$}
  center_and_focus_window "$pattern"
  resize_window_if_needed
  center_and_focus_window "$pattern"
fi

#!/usr/bin/env bash
set -euo pipefail

# Pre-commit validation script for sinnix
# Catches common issues before they reach git history

echo "Running pre-commit checks..."

# Check 1: Nix syntax and evaluation
SKIP_FLAKE=${PRE_COMMIT_SKIP_FLAKE:-0}
SKIP_FMT=${PRE_COMMIT_SKIP_FMT:-0}
SKIP_LINT=${PRE_COMMIT_SKIP_LINT:-0}
# Allow WARN-level findings to pass only when explicitly requested.
ALLOW_WARNINGS=${PRE_COMMIT_ALLOW_WARNINGS:-0}

GIT_DIR_ROOT="$(git rev-parse --git-dir 2>/dev/null || true)"
PRIMARY_INDEX=""
if [ -n "$GIT_DIR_ROOT" ] && [ -f "$GIT_DIR_ROOT/index" ]; then
  PRIMARY_INDEX="$GIT_DIR_ROOT/index"
fi

readarray -t STAGED_NIX < <(git diff --cached --name-only -- '*.nix' 2>/dev/null)
readarray -t STAGED_SHELL < <(git diff --cached --name-only -- '*.sh' 'scripts/*' 2>/dev/null)

should_run_flake() {
  if [ "$SKIP_FLAKE" = "1" ]; then
    echo "→ PRE_COMMIT_SKIP_FLAKE=1 set; skipping nix flake check."
    return 1
  fi
  if git diff --cached --name-only | grep -Eq '\.(nix|lock)$|flake\.nix'; then
    return 0
  fi
  echo "→ No staged Nix changes detected; skipping nix flake check."
  return 1
}

if should_run_flake; then
  echo "→ Checking nix syntax and evaluation..."
  if ! nix flake check --no-build 2>&1 | tee /tmp/flake-check.log; then
    echo "❌ Flake check failed!"
    echo "Review output above or see /tmp/flake-check.log"
    exit 1
  fi
fi

if [ "$SKIP_FMT" != "1" ] && [ "${#STAGED_NIX[@]}" -gt 0 ]; then
  echo "→ Checking nixfmt formatting..."
  if ! nix run .#fmt-check -- "${STAGED_NIX[@]}"; then
    echo "❌ Formatting check failed. Run 'nix fmt' or 'nix run .#format' to fix."
    exit 1
  fi
elif [ "$SKIP_FMT" = "1" ] && [ "${#STAGED_NIX[@]}" -gt 0 ]; then
  echo "→ PRE_COMMIT_SKIP_FMT=1 set; skipping nixfmt check."
fi

lint_needed=0
if [ "${#STAGED_NIX[@]}" -gt 0 ] || [ "${#STAGED_SHELL[@]}" -gt 0 ]; then
  lint_needed=1
fi

if [ "$SKIP_LINT" != "1" ] && [ "$lint_needed" -eq 1 ]; then
  echo "→ Lint tools available via 'nix run .#lint' (skipped by default)."
elif [ "$SKIP_LINT" = "1" ] && [ "$lint_needed" -eq 1 ]; then
  echo "→ PRE_COMMIT_SKIP_LINT=1 set; skipping lint checks."
fi

# Check 2: Look for potential service conflicts
echo "→ Scanning for potential service conflicts..."
warning_count=0

# Check for manual systemd services that might conflict with package defaults
if git diff --cached --name-only | grep -q ".nix$"; then
  for service in hyprpaper waybar mako fnott; do
    if git diff --cached | grep -q "systemd.user.services.$service" && \
       git diff --cached | grep -q "home.packages.*$service"; then
      echo "⚠️  Warning: Found both systemd service definition AND package for $service"
      echo "   This might cause conflicts. Verify the service isn't auto-provided."
      warning_count=$((warning_count + 1))
    fi
  done
fi

# Check 3: Ensure no untracked Nix files that should be committed
echo "→ Checking for untracked .nix files..."
if [ -n "$PRIMARY_INDEX" ]; then
  untracked=$(GIT_INDEX_FILE="$PRIMARY_INDEX" git ls-files --others --exclude-standard "*.nix" || true)
else
  untracked=$(git ls-files --others --exclude-standard "*.nix" || true)
fi
if [ -n "$untracked" ]; then
  echo "⚠️  Warning: Found untracked .nix files:"
  echo "$untracked"
  echo "   These won't be included in nix builds. Add them or add to .gitignore"
  warning_count=$((warning_count + 1))
fi

if [ "$warning_count" -gt 0 ]; then
  if [ "$ALLOW_WARNINGS" = "1" ]; then
    echo "→ PRE_COMMIT_ALLOW_WARNINGS=1 set; continuing despite ${warning_count} warning(s)."
  else
    echo ""
    echo "❌ Pre-commit warnings detected. Resolve the issues above"
    echo "   or rerun with PRE_COMMIT_ALLOW_WARNINGS=1 to bypass temporarily."
    exit 1
  fi
fi

echo "✓ All checks passed"

#!/usr/bin/env bash
# toggle-audio-output - Cycle between PipeWire audio sinks
#
# Usage: toggle-audio-output [--help]
#
# Cycles to the next available audio sink (speakers → headphones → etc.)
# and moves all active streams to the new sink. Sends RTMIN+12 to Waybar
# for immediate status refresh.
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  sed -n '2,7p' "$0" | sed 's/^# //'
  exit 0
fi

inspect=$(wpctl inspect @DEFAULT_AUDIO_SINK@ 2>/dev/null || true)
if [[ -z "$inspect" ]]; then
  exit 1
fi

current_line=$(printf '%s\n' "$inspect" | head -n1)
current_id=$(printf '%s\n' "$current_line" | awk '{print $2}' | tr -d ',')

dump=$(pw-dump)

mapfile -t sinks < <(printf '%s\n' "$dump" | jq -r '.[] | select(.type == "PipeWire:Interface:Node") | select(.info.props["media.class"] == "Audio/Sink") | .id' | sort -n | uniq)

sinks_count=${#sinks[@]}
if (( sinks_count == 0 )); then
  exit 1
fi

next="${sinks[0]}"
for idx in "${!sinks[@]}"; do
  if [[ "${sinks[$idx]}" == "$current_id" ]]; then
    next="${sinks[$(((idx + 1) % sinks_count))]}"
    break
  fi
done

if [[ "$next" == "$current_id" ]]; then
  exit 0
fi

wpctl set-default "$next"

dump_after=$(pw-dump)
mapfile -t streams < <(printf '%s\n' "$dump_after" | jq -r '.[] | select(.type == "PipeWire:Interface:Node") | select(.info.props["media.class"] == "Stream/Output/Audio") | .id')
for stream in "${streams[@]}"; do
  wpctl set-target "$stream" "$next" || true
done

# Allow the status bar to poll for the new sink; Waybar refreshes every couple seconds.
if command -v pkill >/dev/null 2>&1; then
  pkill -RTMIN+12 waybar || true
fi

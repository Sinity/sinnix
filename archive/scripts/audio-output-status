#!/usr/bin/env bash
# audio-output-status - Output current audio sink status as Waybar JSON
#
# Usage: audio-output-status [--help]
#
# Outputs JSON with: text, tooltip, class, volume (%), muted (bool)
# For use in Waybar custom modules.
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  sed -n '2,7p' "$0" | sed 's/^# //'
  exit 0
fi

if ! command -v wpctl >/dev/null 2>&1; then
  jq -n --arg text "󰓃" --arg tooltip "wpctl unavailable" --arg class "unavailable" '{text:$text, tooltip:$tooltip, class:$class}'
  exit 0
fi

inspect=$(wpctl inspect @DEFAULT_AUDIO_SINK@ 2>/dev/null || true)
if [[ -z "$inspect" ]]; then
  jq -n --arg text "󰓃" --arg tooltip "No default audio sink" --arg class "missing" '{text:$text, tooltip:$tooltip, class:$class}'
  exit 0
fi

description=$(printf '%s\n' "$inspect" | awk -F ' = ' '/node.description/ {gsub(/"/, "", $2); print $2; exit}')
nick=$(printf '%s\n' "$inspect" | awk -F ' = ' '/node.nick/ {gsub(/"/, "", $2); print $2; exit}')
name=$(printf '%s\n' "$inspect" | awk -F ' = ' '/node.name/ {gsub(/"/, "", $2); print $2; exit}')
device=$(printf '%s\n' "$inspect" | awk -F ' = ' '/device.description/ {gsub(/"/, "", $2); print $2; exit}')

label="$description"
if [[ -z "$label" ]]; then
  label="$nick"
fi
if [[ -z "$label" ]]; then
  label="$name"
fi
if [[ -z "$label" ]]; then
  label="Audio Sink"
fi

lowered=$(printf '%s' "$label" | tr '[:upper:]' '[:lower:]')

status=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null || true)
volume_raw=""
muted="false"
if [[ -n "$status" ]]; then
  volume_raw=$(printf '%s\n' "$status" | awk '{for (i=1; i<=NF; i++) if ($i ~ /^[0-9.]+$/) {print $i; exit}}')
  if printf '%s\n' "$status" | grep -q '\[MUTED\]'; then
    muted="true"
  fi
fi

if [[ -z "$volume_raw" ]]; then
  volume_raw="0"
fi

percent=$(awk -v vol="$volume_raw" 'BEGIN {printf "%.0f", vol * 100 }')

icon="󰓃"
class="speaker"

if [[ "$lowered" == *"wh-1000xm5"* || "$lowered" == *"galaxy buds2 pro"* ]]; then
  icon="󰋋"
  class="headphones"
elif [[ "$lowered" == *"headphone"* || "$lowered" == *"headset"* ]]; then
  icon="󰋋"
  class="headphones"
elif [[ "$lowered" == *"bluetooth"* || "$lowered" == *"bt"* ]]; then
  icon="󰂯"
  class="bluetooth"
elif [[ "$lowered" == *"monitor"* || "$lowered" == *"display"* ]]; then
  icon="󰹑"
  class="monitor"
elif [[ "$lowered" == *"hdmi"* || "$lowered" == *"digital"* ]]; then
  icon="󰡁"
  class="hdmi"
elif [[ "$lowered" == *"usb"* || "$lowered" == *"dac"* || "$lowered" == *"ifi"* || "$lowered" == *"fiio"* || "$lowered" == *"e10k"* || "$lowered" == *"ultima 40"* ]]; then
  icon="󰓃"
  class="speaker"
fi

tooltip="$label"
if [[ -n "$device" && "$device" != "$label" ]]; then
  tooltip="$label"$'\n'"$device"
fi
display="$label"
case "$lowered" in
  *"xm4"*) display="XM4" ;;
  *"xm5"*) display="XM5" ;;
  *"headphone"*|*"headset"*) display="Headphones" ;;
  *"bluetooth"*) display="Bluetooth" ;;
  *"speaker"*|*"monitor"*|*"display"*) display="Speakers" ;;
  *"dac"*|*"usb"*) display="DAC" ;;
esac

display=$(printf '%s' "$display" | awk '{print $1}')

if [[ "$muted" == "true" ]]; then
  icon="󰖁"
  class="$class muted"
fi

text_output="$icon ${percent}% · $display"

jq -nc \
  --arg text "$text_output" \
  --arg tooltip "$tooltip" \
  --arg class "$class" \
  --arg volume "$percent" \
  --arg muted "$muted" \
  '{text:$text, tooltip:$tooltip, class:$class, volume:($volume|tonumber), muted:($muted == "true")}'

# Exclude lockfiles from git diffs and language statistics
*.lock linguist-generated=true
**/package-lock.json linguist-generated=true

# Operational state is not part of the repository language composition.
.beads/** linguist-detectable=false
.agent/** linguist-detectable=false

# Treat agenix secrets as binary to prevent diffs and text processing
*.age binary
*.age -diff -text

# Other common binary or generated files
*.sqlite binary
*.sqlite3 binary
*.db binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary

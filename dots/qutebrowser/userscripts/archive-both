#!/usr/bin/env bash
set -euo pipefail

fifo="${QUTE_FIFO:-}"
url="${QUTE_URL:-}"

if [[ -z "${fifo}" || ! -p "${fifo}" ]]; then
  notify-send "archive-both" "QUTE_FIFO is not available."
  exit 1
fi

if [[ -z "${url}" ]]; then
  url="${QUTE_SELECTED_TEXT:-}"
fi

if [[ -z "${url}" ]]; then
  notify-send "archive-both" "No URL to archive."
  exit 0
fi

wayback="https://web.archive.org/save/${url}"
archive_today="https://archive.today/?run=1&url=${url}"

printf 'open -w %s\n' "${wayback}" >> "${fifo}"
printf 'open -w %s\n' "${archive_today}" >> "${fifo}"

notify-send "archive-both" "Submitting to Wayback Machine & archive.today"

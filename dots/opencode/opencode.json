{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-openai-codex-auth"
  ],
  "model": "openai/gpt-5-codex",
  "instructions": [
    "/home/sinity/.config/claude/CLAUDE.md.hm-bak",
    "/home/sinity/.codex/AGENTS.md"
  ],
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "webfetch": "allow"
  },
  "tools": {
    "bash": true,
    "edit": true,
    "write": true,
    "webfetch": true,
    "glob": true,
    "grep": true,
    "list": true,
    "patch": true,
    "todowrite": true,
    "todoread": true
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "high",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      },
      "models": {
        "gpt-5-codex": {
          "name": "GPT-5 Codex (OAuth)",
          "options": {
            "reasoningEffort": "high",
            "include": [
              "reasoning.encrypted_content"
            ],
            "store": false
          }
        },
        "gpt-5-codex-low": {
          "name": "GPT-5 Codex Low (OAuth)",
          "options": {
            "reasoningEffort": "low",
            "include": [
              "reasoning.encrypted_content"
            ],
            "store": false
          }
        }
      }
    }
  },
  "mcp": {
    "github-copilot": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "postgres-local": {
      "type": "local",
      "command": [
        "/home/sinity/.local/bin/mcp-postgres"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "exec npx -y @upstash/context7-mcp@latest --api-key \"$CONTEXT7_API_KEY\""
      ]
    },
    "firecrawl": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "exec env FIRECRAWL_API_KEY=\"$(< /run/agenix/firecrawl-api-key)\" npx -y firecrawl-mcp@latest"
      ]
    },
    "qdrant": {
      "type": "local",
      "command": [
        "/home/sinity/.local/bin/mcp-qdrant"
      ],
      "environment": {
        "QDRANT_URL": "http://127.0.0.1:6333"
      }
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "exa": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}"
      ]
    },
    "cclsp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "cclsp@latest"
      ],
      "environment": {
        "CCLSP_CONFIG_PATH": "/home/sinity/.config/claude/cclsp.json"
      }
    }
  }
}

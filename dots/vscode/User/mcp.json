{
	"inputs": [],
	"servers": {
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/",
			"gallery": true
		},
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": true
		},
		"context7": {
			"type": "stdio",
			"command": "bash",
			"args": [
				"-lc",
				"exec npx -y @upstash/context7-mcp@latest --api-key \"$CONTEXT7_API_KEY\""
			],
			"gallery": true
		},
		"firecrawl": {
			"type": "stdio",
			"command": "bash",
			"args": [
				"-lc",
				"exec env FIRECRAWL_API_KEY=\"$FIRECRAWL_API_KEY\" npx -y firecrawl-mcp@latest"
			],
			"gallery": true
		},
		"postgres-local": {
			"type": "stdio",
			"command": "/home/sinity/.local/bin/mcp-postgres",
			"gallery": false
		},
		"Parallel Search MCP": {
			"type": "http",
			"url": "https://search-mcp.parallel.ai/mcp"
		}
	}
}
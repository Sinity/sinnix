        },
        {
          "key": "p",
          "name": "Peek Definition",
          "type": "command",
          "command": "editor.action.peekDefinition"
        },
        {
          "key": "r",
          "name": "Rename Symbol",
          "type": "command",
          "command": "editor.action.rename"
        },
        {
          "key": "f",
          "name": "Format Document",
          "type": "command",
          "command": "editor.action.formatDocument"
        },
        {
          "key": "a",
          "name": "Code Actions",
          "type": "command",
          "command": "editor.action.codeAction"
        }
      ]
    },
    {
      "key": "g",
      "name": "Git",
      "type": "bindings",
      "bindings": [
        {
          "key": "g",
          "name": "Source Control",
          "type": "command",
          "command": "workbench.view.scm"
        },
        {
          "key": "b",
          "name": "GitLens: Toggle Blame",
          "type": "command",
          "command": "gitlens.toggleLineBlame"
        },
        {
          "key": "f",
          "name": "Fetch",
          "type": "command",
          "command": "git.fetch"
        },
        {
          "key": "p",
          "name": "Pull",
          "type": "command",
          "command": "git.pull"
        },
        {
          "key": "u",
          "name": "Push",
          "type": "command",
          "command": "git.push"
        },
        {
          "key": "h",
          "name": "File History (GitLens)",
          "type": "command",
          "command": "gitlens.showQuickFileHistory"
        },
        {
          "key": "r",
          "name": "Repo History (GitLens)",
          "type": "command",
          "command": "gitlens.showQuickRepoHistory"
        }
      ]
    },
    {
      "key": "x",
      "name": "Diagnostics",
      "type": "bindings",
      "bindings": [
        {
          "key": "x",
          "name": "Problems",
          "type": "command",
          "command": "workbench.actions.view.problems"
        },
        {
          "key": "n",
          "name": "Next Problem",
          "type": "command",
          "command": "editor.action.marker.next"
        },
        {
          "key": "p",
          "name": "Prev Problem",
          "type": "command",
          "command": "editor.action.marker.prev"
        }
      ]
    },
    {
      "key": "t",
      "name": "Terminal/Tasks",
      "type": "bindings",
      "bindings": [
        {
          "key": "t",
          "name": "Toggle Terminal",
          "type": "command",
          "command": "workbench.action.terminal.toggleTerminal"
        },
        {
          "key": "n",
          "name": "New Terminal",
          "type": "command",
          "command": "workbench.action.terminal.new"
        },
        {
          "key": "r",
          "name": "Run Task…",
          "type": "command",
          "command": "workbench.action.tasks.runTask"
        }
      ]
    },
    {
      "key": "d",
      "name": "Debug",
      "type": "bindings",
      "bindings": [
        {
          "key": "d",
          "name": "Debug View",
          "type": "command",
          "command": "workbench.view.debug"
        },
        {
          "key": "b",
          "name": "Toggle Breakpoint",
          "type": "command",
          "command": "editor.debug.action.toggleBreakpoint"
        },
        {
          "key": "c",
          "name": "Continue",
          "type": "command",
          "command": "workbench.action.debug.continue"
        },
        {
          "key": "o",
          "name": "Step Over",
          "type": "command",
          "command": "workbench.action.debug.stepOver"
        },
        {
          "key": "i",
          "name": "Step Into",
          "type": "command",
          "command": "workbench.action.debug.stepInto"
        }
      ]
    },
    {
      "key": "r",
      "name": "Rust",
      "type": "bindings",
      "bindings": [
        {
          "key": "a",
          "name": "Code Action",
          "type": "command",
          "command": "editor.action.codeAction"
        },
        {
          "key": "r",
          "name": "RA: Run",
          "type": "command",
          "command": "rust-analyzer.run"
        },
        {
          "key": "t",
          "name": "Run All Tests",
          "type": "command",
          "command": "testing.runAll"
        }
      ]
    },
    {
      "key": "n",
      "name": "Nix",
      "type": "bindings",
      "bindings": [
        {
          "key": "c",
          "name": "Run Task…",
          "type": "command",
          "command": "workbench.action.tasks.runTask"
        },
        {
          "key": "s",
          "name": "nix: switch",
          "type": "command",
          "command": "workbench.action.tasks.runTask",
          "args": "nix: switch"
        },
        {
          "key": "f",
          "name": "nix: flake check",
          "type": "command",
          "command": "workbench.action.tasks.runTask",
          "args": "nix: flake check"
        }
      ]
    },
    {
      "key": "m",
      "name": "Notes",
      "type": "bindings",
      "bindings": [
        {
          "key": "p",
          "name": "Markdown Preview",
          "type": "command",
          "command": "markdown.showPreviewToSide"
        },
        {
          "key": "g",
          "name": "Foam: Show Graph",
          "type": "command",
          "command": "foam-vscode.show-graph"
        }
      ]

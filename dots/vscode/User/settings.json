  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.ai.largePromptWarningThreshold": 100000,
  "claudeCode.allowDangerouslySkipPermissions": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "editor.inlineSuggest.experimental.showOnSuggestConflict": "always",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "wakatime.apiKey": "REDACTED_WAKATIME_KEY",
  "explorer.confirmDelete": false,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.mouseWheelZoom": true,
  "files.autoSave": "onFocusChange",
  "editor.aiStats.enabled": true,
  "editor.autoIndentOnPaste": true,
  "editor.experimental.preferTreeSitter.css": true,
  "editor.experimental.preferTreeSitter.ini": true,
  "editor.experimental.treeSitterTelemetry": true,
  "editor.experimental.preferTreeSitter.regex": true,
  "editor.experimental.preferTreeSitter.typescript": true,
  "editor.guides.bracketPairsHorizontal": true,
  "editor.guides.highlightActiveIndentation": "always",
  "editor.hover.delay": 250,
  "editor.hover.hidingDelay": 250,
  "editor.inlayHints.enabled": "onUnlessPressed",
  "editor.inlayHints.maximumLength": 0,
  "editor.lightbulb.enabled": "on",
  "editor.linkedEditing": true,
  "editor.maxTokenizationLineLength": 200000,
  "editor.occurrencesHighlight": "multiFile",
  "editor.selectionHighlightMaxLength": 20000,
  "editor.selectionHighlightMultiline": true,
  "editor.smoothScrolling": true,
  "editor.stickyScroll.maxLineCount": 20,
  "editor.tabCompletion": "on",
  "editor.trimWhitespaceOnDelete": true,
  "editor.wordWrapColumn": 120,
  "editor.wrapOnEscapedLineFeeds": true,
  "editor.wrappingStrategy": "advanced",
  "diffEditor.codeLens": true,
  "diffEditor.experimental.showMoves": true,
  "diffEditor.experimental.useTrueInlineView": true,
  "diffEditor.maxFileSize": 0,
  "diffEditor.renderSideBySide": false,
  "editor.suggest.matchOnWordStartOnly": false,
  "files.autoGuessEncoding": true,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "workbench.commandPalette.experimental.suggestCommands": true,
  "workbench.experimental.cloudChanges.autoStore": "onShutdown",
  "workbench.experimental.cloudChanges.partialMatches.enabled": true,
  "workbench.list.smoothScrolling": true,
  "workbench.navigationControl.enabled": false,
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.preferredDarkColorTheme": "GitHub Dark Default",
  "workbench.preferredLightColorTheme": "GitHub Light Default",
  "workbench.editor.alwaysShowEditorActions": true,
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.pinnedTabsOnSeparateRow": true,
  "workbench.editor.preferHistoryBasedLanguageDetection": true,
  "workbench.settings.openDefaultKeybindings": true,
  "workbench.settings.openDefaultSettings": true,
  "zenMode.restore": false,
  "zenMode.hideStatusBar": false,
  "files.trimTrailingWhitespaceInRegexAndStrings": false,
  "workbench.editor.wrapTabs": true,
  "explorer.fileNesting.enabled": true,
  "explorer.incrementalNaming": "smart",
  "search.defaultViewMode": "tree",
  "search.showLineNumbers": true,
  "search.smartCase": true,
  "search.useGlobalIgnoreFiles": true,
  "search.useParentIgnoreFiles": true,
  "debug.closeReadonlyTabsOnEnd": true,

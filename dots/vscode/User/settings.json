    {
      "key": "a",
      "name": "AI / Copilot",
      "type": "bindings",
      "bindings": [
        {
          "key": "c",
          "name": "Open Chat",
          "type": "command",
          "command": "workbench.action.copilot.chat.open"
        },
        {
          "key": "i",
          "name": "Inline Chat",
          "type": "command",
          "command": "editor.action.copilot.inlineChat.start"
        }
      ]
    },
    {
      "key": "w",
      "name": "Window",
      "type": "bindings",
      "bindings": [
        {
          "key": "v",
          "name": "Split Right",
          "type": "command",
          "command": "workbench.action.splitEditorRight"
        },
        {
          "key": "s",

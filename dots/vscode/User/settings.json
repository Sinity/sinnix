  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.shellIntegration.enabled": false,
  "task.verboseLogging": true,
  "chat.agent.thinkingStyle": "collapsedPreview",

{
  // ——— Existing preferences preserved ———
  "chat.editor.fontFamily": "SauceCodePro Nerd Font Mono",
  "chat.editor.fontSize": 22,
  "debug.console.fontFamily": "SauceCodePro Nerd Font Mono",
  "debug.console.fontSize": 22,
  "editor.fontFamily": "SauceCodePro Nerd Font Mono, 'Sauce Code Pro', monospace",
  "editor.fontSize": 16,
  "editor.fontLigatures": false,
  "editor.inlayHints.fontFamily": "SauceCodePro Nerd Font Mono",
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.fontFamily": "SauceCodePro Nerd Font Mono",
  "editor.guides.bracketPairs": "active",
  "editor.minimap.enabled": false,
  "editor.minimap.sectionHeaderFontSize": 14,
  "markdown.preview.fontFamily": "Liberation Sans",
  "markdown.preview.fontSize": 22,
  "scm.inputFontFamily": "SauceCodePro Nerd Font Mono",
  "scm.inputFontSize": 20,
  "screencastMode.fontSize": 85,

  // ——— VSCode-Neovim integration ———
  // Rely on PATH for nvim, avoid hard-coding Nix path.
  // Remove any composite jk escape. Keep Linux key handling sane.
  "vscode-neovim.compositeKeys": {},
  "keyboard.dispatch": "keyCode",
  "vscode-neovim.useCtrlKeys": true,

  // ——— Editor ergonomics ———
  "editor.lineNumbers": "relative",
  "workbench.editor.showTabs": "single",
  "workbench.editor.enablePreview": false,
  "workbench.startupEditor": "none",

  // ——— Copilot / Chat Agent ———
  "chat.agent.enabled": true,

  // ——— Rust Analyzer ———
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.cargo.allFeatures": true,
  "rust-analyzer.procMacro.enable": true,

  // ——— Nix ———
  "nix.formatterPath": "nixfmt",

  // ——— Terminal ———
  "terminal.integrated.inheritEnv": true,
  "terminal.integrated.fontFamily": "SauceCodePro Nerd Font Mono",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.drawBoldTextInBrightColors": false,
  "terminal.integrated.enableFileLinks": "off",
  "terminal.integrated.enableMultiLinePasteWarning": "auto",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.profiles.linux": {
    "opencode": { "path": "opencode" },
    "codex": { "path": "codex" }
  },

  // ——— Performance ———
  "files.watcherExclude": {
    "**/target/**": true,
    "**/.direnv/**": true,
    "**/node_modules/**": true
  },

  // ——— Foam / Markdown ———
  "foam.edit.linkReferenceDefinitions": "withExtensions",
  "markdown.references.preferredLocation": "endOfFile",

  // ——— Editor QoL ———
  "breadcrumbs.enabled": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "selection",
  "editor.rulers": [100],
  "explorer.autoReveal": false,
  "explorer.excludeGitIgnore": true,
  "search.useIgnoreFiles": true,
  "telemetry.telemetryLevel": "off",
  "update.mode": "manual",
  "window.titleBarStyle": "custom",
  "window.openFoldersInNewWindow": "off",
  "window.restoreWindows": "none",

  // ——— Git ergonomics ———
  "git.autofetch": true,
  "git.confirmSync": false,

  // ——— Files hygiene ———
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  // ——— WhichKey menu (VS Code) ———
  "whichkey.bindings": [
    { "key": "?", "name": "Commands", "type": "command", "command": "workbench.action.showCommands" },
    { "key": "f", "name": "Files", "type": "bindings", "bindings": [
      { "key": "f", "name": "Quick Open", "type": "command", "command": "workbench.action.quickOpen" },
      { "key": "e", "name": "Explorer",   "type": "command", "command": "workbench.view.explorer" },
      { "key": "r", "name": "Open Recent", "type": "command", "command": "workbench.action.openRecent" },
      { "key": "s", "name": "Save All",    "type": "command", "command": "workbench.action.files.saveAll" }
    ] },
    { "key": "s", "name": "Search", "type": "bindings", "bindings": [
      { "key": "s", "name": "Find in Files",       "type": "command", "command": "workbench.action.findInFiles" },
      { "key": "/", "name": "Find in Files",       "type": "command", "command": "workbench.action.findInFiles" },
      { "key": "h", "name": "Search: Focus View",  "type": "command", "command": "workbench.view.search" },
      { "key": "i", "name": "Symbols in File",     "type": "command", "command": "workbench.action.gotoSymbol" },
      { "key": "w", "name": "Symbols in Workspace", "type": "command", "command": "workbench.action.showAllSymbols" }
    ] },
    { "key": "l", "name": "LSP", "type": "bindings", "bindings": [
      { "key": "d", "name": "Go to Definition",        "type": "command", "command": "editor.action.revealDefinition" },
      { "key": "D", "name": "Go to Declaration",       "type": "command", "command": "editor.action.revealDeclaration" },
      { "key": "I", "name": "Go to Implementation",    "type": "command", "command": "editor.action.goToImplementation" },
      { "key": "T", "name": "Go to Type Definition",   "type": "command", "command": "editor.action.goToTypeDefinition" },
      { "key": "R", "name": "Find References",         "type": "command", "command": "editor.action.referenceSearch.trigger" },
      { "key": "p", "name": "Peek Definition",          "type": "command", "command": "editor.action.peekDefinition" },
      { "key": "r", "name": "Rename Symbol",            "type": "command", "command": "editor.action.rename" },
      { "key": "f", "name": "Format Document",          "type": "command", "command": "editor.action.formatDocument" },
      { "key": "a", "name": "Code Actions",              "type": "command", "command": "editor.action.codeAction" }
    ] },
    { "key": "g", "name": "Git", "type": "bindings", "bindings": [
      { "key": "g", "name": "Source Control",       "type": "command", "command": "workbench.view.scm" },
      { "key": "b", "name": "GitLens: Toggle Blame", "type": "command", "command": "gitlens.toggleLineBlame" },
      { "key": "f", "name": "Fetch",                 "type": "command", "command": "git.fetch" },
      { "key": "p", "name": "Pull",                  "type": "command", "command": "git.pull" },
      { "key": "u", "name": "Push",                  "type": "command", "command": "git.push" },
      { "key": "h", "name": "File History (GitLens)", "type": "command", "command": "gitlens.showQuickFileHistory" },
      { "key": "r", "name": "Repo History (GitLens)", "type": "command", "command": "gitlens.showQuickRepoHistory" }
    ] },
    { "key": "x", "name": "Diagnostics", "type": "bindings", "bindings": [
      { "key": "x", "name": "Problems",     "type": "command", "command": "workbench.actions.view.problems" },
      { "key": "n", "name": "Next Problem", "type": "command", "command": "editor.action.marker.next" },
      { "key": "p", "name": "Prev Problem", "type": "command", "command": "editor.action.marker.prev" }
    ] },
    { "key": "t", "name": "Terminal/Tasks", "type": "bindings", "bindings": [
      { "key": "t", "name": "Toggle Terminal", "type": "command", "command": "workbench.action.terminal.toggleTerminal" },
      { "key": "n", "name": "New Terminal",    "type": "command", "command": "workbench.action.terminal.new" },
      { "key": "r", "name": "Run Task…",       "type": "command", "command": "workbench.action.tasks.runTask" }
    ] },
    { "key": "d", "name": "Debug", "type": "bindings", "bindings": [
      { "key": "d", "name": "Debug View",       "type": "command", "command": "workbench.view.debug" },
      { "key": "b", "name": "Toggle Breakpoint", "type": "command", "command": "editor.debug.action.toggleBreakpoint" },
      { "key": "c", "name": "Continue",          "type": "command", "command": "workbench.action.debug.continue" },
      { "key": "o", "name": "Step Over",         "type": "command", "command": "workbench.action.debug.stepOver" },
      { "key": "i", "name": "Step Into",         "type": "command", "command": "workbench.action.debug.stepInto" }
    ] },
    { "key": "r", "name": "Rust", "type": "bindings", "bindings": [
      { "key": "a", "name": "Code Action", "type": "command", "command": "editor.action.codeAction" },
      { "key": "r", "name": "RA: Run",    "type": "command", "command": "rust-analyzer.run" },
      { "key": "t", "name": "Run All Tests", "type": "command", "command": "testing.runAll" }
    ] },
    { "key": "n", "name": "Nix", "type": "bindings", "bindings": [
      { "key": "c", "name": "Run Task…",         "type": "command", "command": "workbench.action.tasks.runTask" },
      { "key": "s", "name": "nix: switch",       "type": "command", "command": "workbench.action.tasks.runTask", "args": "nix: switch" },
      { "key": "f", "name": "nix: flake check",  "type": "command", "command": "workbench.action.tasks.runTask", "args": "nix: flake check" }
    ] },
    { "key": "m", "name": "Notes", "type": "bindings", "bindings": [
      { "key": "p", "name": "Markdown Preview", "type": "command", "command": "markdown.showPreviewToSide" },
      { "key": "g", "name": "Foam: Show Graph",  "type": "command", "command": "foam-vscode.show-graph" }
    ] },
    { "key": "a", "name": "AI / Copilot", "type": "bindings", "bindings": [
      { "key": "c", "name": "Open Chat",    "type": "command", "command": "workbench.action.copilot.chat.open" },
      { "key": "i", "name": "Inline Chat",  "type": "command", "command": "editor.action.copilot.inlineChat.start" }
    ] },
    { "key": "w", "name": "Window", "type": "bindings", "bindings": [
      { "key": "v", "name": "Split Right",     "type": "command", "command": "workbench.action.splitEditorRight" },
      { "key": "s", "name": "Split Down",      "type": "command", "command": "workbench.action.splitEditorDown" },
      { "key": "=", "name": "Even Widths",     "type": "command", "command": "workbench.action.evenEditorWidths" },
      { "key": "h", "name": "Focus Left",      "type": "command", "command": "workbench.action.focusLeftGroup" },
      { "key": "j", "name": "Focus Down",      "type": "command", "command": "workbench.action.focusBelowGroup" },
      { "key": "k", "name": "Focus Up",        "type": "command", "command": "workbench.action.focusAboveGroup" },
      { "key": "l", "name": "Focus Right",     "type": "command", "command": "workbench.action.focusRightGroup" }
    ] },
    { "key": "b", "name": "Buffers", "type": "bindings", "bindings": [
      { "key": "n", "name": "Next Editor",     "type": "command", "command": "workbench.action.nextEditor" },
      { "key": "p", "name": "Prev Editor",     "type": "command", "command": "workbench.action.previousEditor" },
      { "key": "d", "name": "Close Editor",    "type": "command", "command": "workbench.action.closeActiveEditor" }
    ] }
  ],
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.ai.largePromptWarningThreshold": 100000,
  "claudeCode.allowDangerouslySkipPermissions": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "editor.inlineSuggest.experimental.showOnSuggestConflict": "always",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "update.showReleaseNotes": false,
  "workbench.colorTheme": "GitHub Dark",
  "wakatime.apiKey": "REDACTED_WAKATIME_KEY",
  "explorer.confirmDelete": false,
  "workbench.sideBar.location": "right"
}

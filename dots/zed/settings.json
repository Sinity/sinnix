{
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "The Dark Side"
  },
  "ui_font_size": 18.0,
  "ui_font_weight": 500.0,
  "buffer_font_size": 18.0,
  "buffer_line_height": "standard",
  "icon_theme": "Material Icon Theme",
  "minimum_contrast_for_highlights": 50.0,
  "unnecessary_code_fade": 0.4,
  "vim_mode": true,
  "close_on_file_delete": true,
  "use_smartcase_search": true,
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "title_bar": {
    "show_menus": true,
    "show_branch_icon": true
  },
  "preview_tabs": {
    "enable_preview_from_code_navigation": true,
    "enable_preview_from_file_finder": true
  },
  "search": {
    "case_sensitive": false
  },
  "inlay_hints": {
    "enabled": true
  },
  "toolbar": {
    "code_actions": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "terminal": {
    "shell": {
      "program": "zsh",
      "args": []
    },
    "max_scroll_history_lines": 10000,
    "toolbar": {
      "breadcrumbs": true
    }
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "agent": {
    "play_sound_when_agent_done": true,
    "always_allow_tool_actions": false,
    "model_parameters": []
  },
  "assistant": {
    "default_provider": "anthropic",
    "providers": {
      "anthropic": {
        "api_key": { "env": "ANTHROPIC_API_KEY" }
      }
    }
  },
  "context_servers": {
    "mcp-server-github": {
      "source": "extension",
      "enabled": true,
      "settings": {
        "github_personal_access_token": { "env": "GITHUB_TOKEN" }
      }
    },
    "postgres-context-server": {
      "source": "extension",
      "enabled": true,
      "settings": {
        "database_url": { "env": "SINEX_DATABASE_URL" }
      }
    },
    "mcp-server-context7": {
      "source": "extension",
      "enabled": true,
      "settings": {
        "context7_api_key": { "env": "CONTEXT7_API_KEY" }
      }
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}

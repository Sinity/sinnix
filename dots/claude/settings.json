{
  "cleanupPeriodDays": 99999,
  "env": {},
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Agent",
      "Skill",
      "SendMessage",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskStop",
      "TaskOutput",
      "EnterPlanMode",
      "ExitPlanMode",
      "CronCreate",
      "CronDelete",
      "CronList",
      "RemoteTrigger",
      "EnterWorktree",
      "ExitWorktree",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_SimpleScraper__*",
      "mcp__claude_ai_Mermaid_Chart__*"
    ],
    "deny": ["Bash(rm -rf /:*)"],
    "ask": [],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__serena__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/serena-hooks auto-approve --client=claude-code",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pretooluse-bash.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/posttooluse-agent-event.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "case \"${SINNIX_CLAUDE_PROFILE:-full}\" in full|browser|deepseek|local) ~/.local/bin/serena-hooks cleanup --client=claude-code ;; esac",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-agent-event.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "case \"${SINNIX_CLAUDE_PROFILE:-full}\" in full|browser|deepseek|local) ~/.local/bin/serena-hooks activate --client=claude-code ;; esac",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-polylogue-recall.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-sinex-recall.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-beads-prime.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-beads-prime.sh --memories-only",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/sinity/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "semgrep@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "atomic-agents@claude-plugins-official": false
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}

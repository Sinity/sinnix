{
  "cleanupPeriodDays": 99999,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Agent",
      "Skill",
      "SendMessage",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskStop",
      "TaskOutput",
      "EnterPlanMode",
      "ExitPlanMode",
      "LSP",
      "CronCreate",
      "CronDelete",
      "CronList",
      "RemoteTrigger",
      "EnterWorktree",
      "ExitWorktree",
      "TeamCreate",
      "TeamDelete",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_SimpleScraper__*",
      "mcp__claude_ai_Mermaid_Chart__*"
    ],
    "deny": ["Bash(rm -rf /:*)"],
    "ask": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/serena-hooks remind --client=claude-code",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "mcp__serena__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/serena-hooks auto-approve --client=claude-code",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pretooluse-bash.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/posttooluse-agent-event.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/serena-hooks cleanup --client=claude-code",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-agent-event.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/serena-hooks activate --client=claude-code",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-polylogue-recall.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "playground@claude-plugins-official": false,
    "semgrep@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "atomic-agents@claude-plugins-official": false
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "bash /home/sinity/.claude/statusline-command.sh"
  }
}

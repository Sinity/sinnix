{
  "servers": [
    {
      "extensions": ["py", "pyi"],
      "command": ["uvx", "--from", "python-lsp-server", "pylsp"],
      "rootDir": "."
    },
    {
      "extensions": ["rs"],
      "command": ["rust-analyzer"],
      "rootDir": "."
    },
    {
      "extensions": ["ts", "tsx", "js", "jsx"],
      "command": [
        "npx",
        "-y",
        "-p",
        "typescript",
        "-p",
        "typescript-language-server",
        "typescript-language-server",
        "--stdio"
      ],
      "rootDir": "."
    }
  ]
}
